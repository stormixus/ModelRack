                            height: 430px;
                            Image { x: (parent.width - 96px) / 2; y: 22px; width: 96px; height: 96px; source: @image-url("../assets/AppIcon.iconset/icon_128x128.png"); image-fit: contain; }
                            Text { x: 0; y: 132px; width: parent.width; text: "ModelRack"; color: Theme.fg-0; font-size: 22px; font-weight: 600; horizontal-alignment: center; }
                            Text { x: 0; y: 163px; width: parent.width; text: "A workshop tool for your 3D model library"; color: Theme.fg-2; font-size: Theme.font-body; horizontal-alignment: center; }
                            Rectangle { x: 120px; y: 205px; width: parent.width - 240px; height: 116px; background: Theme.bg-2; border-color: Theme.line; border-width: 1px; border-radius: 8px; Text { x: 18px; y: 17px; text: "Version"; color: Theme.fg-2; font-size: 12px; } Text { x: parent.width - self.width - 18px; y: 17px; text: app-version; color: Theme.fg-0; font-family: "JetBrains Mono"; font-size: 12px; } Text { x: 18px; y: 45px; text: "Build"; color: Theme.fg-2; font-size: 12px; } Text { x: parent.width - self.width - 18px; y: 45px; text: "2026.05.10"; color: Theme.fg-0; font-family: "JetBrains Mono"; font-size: 12px; } Text { x: 18px; y: 73px; text: "Stack"; color: Theme.fg-2; font-size: 12px; } Text { x: parent.width - self.width - 18px; y: 73px; text: "Rust + Slint"; color: Theme.fg-0; font-family: "JetBrains Mono"; font-size: 12px; } }
                            Rectangle { x: 120px; y: 336px; width: parent.width - 240px; height: 70px; background: Theme.bg-2; border-color: Theme.line; border-width: 1px; border-radius: 8px;
                                Text { x: 18px; y: 13px; text: "Updates"; color: Theme.fg-0; font-size: Theme.font-body; font-weight: 600; }
                                Text { x: 18px; y: 34px; width: parent.width - 164px; text: settings-update-status; color: Theme.fg-2; font-family: "JetBrains Mono"; font-size: 10.5px; overflow: elide; }
                                SettingsActionButton { x: parent.width - 134px; y: 21px; button-width: 116px; label: "Check"; icon: @image-url("../assets/icons/refresh.svg"); activated => { check-updates(); } }
                            }
                        }
                    }
                }
            }
        }
    }


}
