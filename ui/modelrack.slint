import { Button, LineEdit, ScrollView, TextEdit } from "std-widgets.slint";
import { Theme } from "theme.slint";
export { Theme } from "theme.slint";

// ─── Data structs ────────────────────────────────────────

export struct BrowserCard {
    stable-key: string,
    slot-index: int,
    title: string,
    subtitle: string,
    author: string,
    relative-modified: string,
    thumb-key: string,
    thumb-image: image,
    thumb-ready: bool,
    badge: string,
    printed-count: int,
    favorite: bool,
    printed: bool,
    error: bool,
}

export struct SidebarItem {
    key: string,
    label: string,
    count: int,
    depth: int,
    expandable: bool,
    expanded: bool,
}

export struct PrintHistoryRow {
    date: string,
    material: string,
    printer: string,
    profile: string,
    nozzle: string,
    layer-height: string,
    duration: string,
    notes: string,
    success: bool,
}

export struct TagChip {
    label: string,
}

export struct PlateTab {
    label: string,
    index: int,
    selected: bool,
}

export struct SlicerCandidate {
    label: string,
    path: string,
    detail: string,
    icon-image: image,
    icon-ready: bool,
    selected: bool,
}

export struct PrinterProfileChoice {
    key: string,
    label: string,
    detail: string,
    selected: bool,
    defaulted: bool,
}

export struct ChoiceRow {
    key: string,
    label: string,
    selected: bool,
}

// ─── Reusable components ─────────────────────────────────

component SvgIcon inherits Image {
    in property <image> icon;
    in property <brush> tint: Theme.fg-2;

    source: icon;
    image-fit: contain;
    colorize: tint;
}

component ThumbImage inherits Image {
    in property <string> thumb-key: "rack";

    image-fit: contain;
    source: thumb-key == "clip" ? @image-url("../assets/thumbs/thumb-clip.svg") :
            thumb-key == "panel" ? @image-url("../assets/thumbs/thumb-panel.svg") :
            thumb-key == "mount" ? @image-url("../assets/thumbs/thumb-mount.svg") :
            thumb-key == "bracket" ? @image-url("../assets/thumbs/thumb-bracket.svg") :
            thumb-key == "caddy" ? @image-url("../assets/thumbs/thumb-caddy.svg") :
            thumb-key == "spool" ? @image-url("../assets/thumbs/thumb-spool.svg") :
            thumb-key == "therm" ? @image-url("../assets/thumbs/thumb-therm.svg") :
            thumb-key == "chain" ? @image-url("../assets/thumbs/thumb-chain.svg") :
            thumb-key == "link" ? @image-url("../assets/thumbs/thumb-link.svg") :
            thumb-key == "case" ? @image-url("../assets/thumbs/thumb-case.svg") :
            thumb-key == "holder" ? @image-url("../assets/thumbs/thumb-holder.svg") :
            thumb-key == "keycap" ? @image-url("../assets/thumbs/thumb-keycap.svg") :
            thumb-key == "fox" ? @image-url("../assets/thumbs/thumb-fox.svg") :
            thumb-key == "voro" ? @image-url("../assets/thumbs/thumb-voro.svg") :
            thumb-key == "vase" ? @image-url("../assets/thumbs/thumb-vase.svg") :
            thumb-key == "drag" ? @image-url("../assets/thumbs/thumb-drag.svg") :
            thumb-key == "benchy" ? @image-url("../assets/thumbs/thumb-benchy.svg") :
            thumb-key == "cube" ? @image-url("../assets/thumbs/thumb-cube.svg") :
            thumb-key == "test" ? @image-url("../assets/thumbs/thumb-test.svg") :
            thumb-key == "err" ? @image-url("../assets/thumbs/thumb-err.svg") :
            thumb-key == "ascii" ? @image-url("../assets/thumbs/thumb-ascii.svg") :
            thumb-key == "damp" ? @image-url("../assets/thumbs/thumb-damp.svg") :
            thumb-key == "batt" ? @image-url("../assets/thumbs/thumb-batt.svg") :
            thumb-key == "fan" ? @image-url("../assets/thumbs/thumb-fan.svg") :
            thumb-key == "shroud" ? @image-url("../assets/thumbs/thumb-shroud.svg") :
            thumb-key == "vesa" ? @image-url("../assets/thumbs/thumb-vesa.svg") :
            thumb-key == "mclip" ? @image-url("../assets/thumbs/thumb-mclip.svg") :
            thumb-key == "anc" ? @image-url("../assets/thumbs/thumb-anc.svg") :
            thumb-key == "string" ? @image-url("../assets/thumbs/thumb-string.svg") :
            thumb-key == "over" ? @image-url("../assets/thumbs/thumb-over.svg") :
            thumb-key == "temp" ? @image-url("../assets/thumbs/thumb-temp.svg") :
            thumb-key == "celt" ? @image-url("../assets/thumbs/thumb-celt.svg") :
            thumb-key == "hex" ? @image-url("../assets/thumbs/thumb-hex.svg") :
            thumb-key == "grid" ? @image-url("../assets/thumbs/thumb-grid.svg") :
            thumb-key == "bin" ? @image-url("../assets/thumbs/thumb-bin.svg") :
            @image-url("../assets/thumbs/thumb-rack.svg");
}

component CachedThumb inherits Rectangle {
    in property <string> thumb-key: "rack";
    in property <image> cached-image;
    in property <bool> thumb-ready: false;

    if thumb-ready: Image {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        source: cached-image;
        image-fit: contain;
    }

    if !thumb-ready: ThumbImage {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        thumb-key: root.thumb-key;
    }
}

component SidebarLine inherits Rectangle {
    in property <string> label;
    in property <image> icon;
    in property <int> count;
    in property <int> depth: 0;
    in property <bool> reserve-leading: false;
    in property <bool> expandable: false;
    in property <bool> expanded: false;
    in property <bool> selected: false;
    in property <bool> drop-enabled: false;
    callback activated();
    callback toggle-requested();
    callback context-requested(length, length);
    callback model-dropped(string, string);

    height: 26px;
    background: tag-drop.contains-drag ? Theme.accent-dim : selected ? Theme.accent-dim : ta-line.has-hover ? Theme.bg-3 : transparent;
    border-color: tag-drop.contains-drag ? Theme.accent-line : transparent;
    border-width: tag-drop.contains-drag ? 1px : 0px;
    border-radius: Theme.radius-btn;

    // Active indicator bar
    if selected: Rectangle {
        x: 0;
        y: 4px;
        width: 2px;
        height: parent.height - 8px;
        border-radius: 1px;
        background: Theme.accent;
    }

    if reserve-leading: SvgIcon {
        x: 8px + depth * 14px;
        y: (parent.height - 10px) / 2;
        width: 10px;
        height: 10px;
        icon: @image-url("../assets/icons/chevron-right.svg");
        tint: expandable ? Theme.fg-3 : transparent;
        transform-origin: { x: 5px, y: 5px };
        transform-rotation: expanded ? 90deg : 0deg;
    }

    SvgIcon {
        x: 8px + depth * 14px + (reserve-leading ? 14px : 0px);
        y: (parent.height - 14px) / 2;
        width: 14px;
        height: 14px;
        icon: root.icon;
        tint: selected ? Theme.accent : Theme.fg-2;
    }

    Text {
        x: 30px + depth * 14px + (reserve-leading ? 14px : 0px);
        y: (parent.height - self.height) / 2;
        width: parent.width - self.x - 42px;
        text: label;
        color: selected ? Theme.fg-0 : Theme.fg-1;
        font-size: Theme.font-body;
        overflow: elide;
    }

    Text {
        x: parent.width - self.width - 10px;
        y: (parent.height - self.height) / 2;
        text: count;
        color: selected ? Theme.fg-1 : Theme.fg-3;
        font-family: "JetBrains Mono";
        font-size: Theme.font-overline;
    }

    ta-line := TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => {
            if (root.expandable && ta-line.mouse-x < 24px + root.depth * 14px) {
                root.toggle-requested();
            } else {
                root.activated();
            }
        }
        pointer-event(event) => {
            if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                root.context-requested(ta-line.mouse-x, ta-line.mouse-y);
            }
        }
    }

    tag-drop := DropArea {
        width: parent.width;
        height: parent.height;
        enabled: root.drop-enabled;
        can-drop(event) => {
            event.mime-type == "application/x-modelrack-model-index";
        }
        dropped(event) => {
            root.model-dropped(event.data, root.label);
        }
    }
}

component SectionHeader inherits Rectangle {
    in property <string> label;
    in property <bool> inset: false;
    in property <bool> show-add: false;
    height: 24px;

    Text {
        x: inset || show-add ? 8px : 0px;
        y: (parent.height - self.height) / 2;
        text: label;
        color: Theme.fg-2;
        font-size: Theme.font-overline;
        font-weight: 600;
        letter-spacing: 0.8px;
    }

    if show-add: Rectangle {
        x: parent.width - 24px;
        y: (parent.height - 16px) / 2;
        width: 16px;
        height: 16px;
        border-radius: 3px;
        background: plus-touch.has-hover ? Theme.bg-3 : transparent;

        SvgIcon {
            x: (parent.width - 12px) / 2;
            y: (parent.height - 12px) / 2;
            width: 12px;
            height: 12px;
            icon: @image-url("../assets/icons/plus.svg");
            tint: plus-touch.has-hover ? Theme.fg-0 : Theme.fg-2;
        }

        plus-touch := TouchArea {}
    }
}

component ContextMenuItem inherits Rectangle {
    in property <string> label;
    in property <string> hint;
    in property <image> icon;
    callback activated();

    height: hint == "" ? 30px : 38px;
    background: ta-menu-item.has-hover ? Theme.bg-4 : transparent;
    border-radius: 5px;

    SvgIcon {
        x: 8px;
        y: (parent.height - 14px) / 2;
        width: 14px;
        height: 14px;
        icon: root.icon;
        tint: ta-menu-item.has-hover ? Theme.fg-0 : Theme.fg-2;
    }

    Text {
        x: 30px;
        y: hint == "" ? (parent.height - self.height) / 2 : 6px;
        width: parent.width - 38px;
        text: label;
        color: Theme.fg-0;
        font-size: Theme.font-body;
        overflow: elide;
    }

    if hint != "": Text {
        x: 30px;
        y: 21px;
        width: parent.width - 38px;
        text: hint;
        color: Theme.fg-3;
        font-family: "JetBrains Mono";
        font-size: Theme.font-overline;
        overflow: elide;
    }

    ta-menu-item := TouchArea {
        clicked => { root.activated(); }
    }
}

component SidebarContextMenu inherits Rectangle {
    in property <string> target-label;
    in property <bool> target-is-folder;
    callback action(string);

    width: 188px;
    height: target-is-folder ? 232px : 96px;
    background: Theme.bg-2;
    border-color: Theme.line-2;
    border-width: 1px;
    border-radius: 8px;

    VerticalLayout {
        padding: 4px;
        spacing: 1px;

        Text {
            height: 20px;
            text: target-label;
            color: Theme.fg-3;
            font-family: "JetBrains Mono";
            font-size: Theme.font-overline;
            overflow: elide;
        }

        ContextMenuItem {
            label: target-is-folder ? "Filter this folder" : "Filter this tag";
            hint: "";
            icon: @image-url("../assets/icons/filter.svg");
            activated => { root.action("filter"); }
        }

        if target-is-folder: ContextMenuItem {
            label: "Remove from Library";
            hint: "";
            icon: @image-url("../assets/icons/minus.svg");
            activated => { root.action("remove"); }
        }

        if target-is-folder: ContextMenuItem {
            label: "Reveal in Finder";
            hint: "";
            icon: @image-url("../assets/icons/folder-open.svg");
            activated => { root.action("reveal"); }
        }

        if target-is-folder: ContextMenuItem {
            label: "Rescan folder";
            hint: "";
            icon: @image-url("../assets/icons/refresh.svg");
            activated => { root.action("rescan"); }
        }

        if target-is-folder: ContextMenuItem {
            label: "Delete Folder…";
            hint: "";
            icon: @image-url("../assets/icons/trash.svg");
            activated => { root.action("trash"); }
        }

        ContextMenuItem {
            label: target-is-folder ? "Copy path" : "Copy tag";
            hint: "";
            icon: @image-url("../assets/icons/duplicate.svg");
            activated => { root.action("copy"); }
        }
    }
}

component SlicerMenuItem inherits Rectangle {
    in property <string> label;
    in property <string> detail;
    in property <image> icon-image;
    in property <bool> icon-ready: false;
    in property <bool> selected;
    callback activated();

    height: 40px;
    background: selected ? Theme.accent-dim : ta-slicer-menu-item.has-hover ? Theme.bg-4 : transparent;
    border-radius: 5px;

    Rectangle {
        x: 8px;
        y: (parent.height - 22px) / 2;
        width: 22px;
        height: 22px;
        background: selected ? Theme.accent : Theme.bg-3;
        border-color: selected ? Theme.accent : Theme.line;
        border-width: 1px;
        border-radius: 5px;

        if icon-ready: Image {
            x: 3px;
            y: 3px;
            width: parent.width - 6px;
            height: parent.height - 6px;
            source: root.icon-image;
            image-fit: contain;
        }

        if !icon-ready: Text {
            x: 0;
            y: 0;
            width: parent.width;
            height: parent.height;
            text: label == "System default STL opener" ? "D" : "S";
            color: selected ? #0e2a32 : Theme.fg-1;
            font-size: 11px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    Text {
        x: 38px;
        y: 6px;
        width: parent.width - 62px;
        text: label;
        color: Theme.fg-0;
        font-size: Theme.font-body;
        overflow: elide;
    }

    Text {
        x: 38px;
        y: 22px;
        width: parent.width - 62px;
        text: detail;
        color: Theme.fg-3;
        font-family: "JetBrains Mono";
        font-size: Theme.font-overline;
        overflow: elide;
    }

    if selected: Text {
        x: parent.width - 20px;
        y: (parent.height - self.height) / 2;
        text: "✓";
        color: Theme.accent;
        font-size: 14px;
        font-weight: 600;
    }

    ta-slicer-menu-item := TouchArea {
        clicked => { root.activated(); }
    }
}

component FilterChip inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    callback dismiss();

    height: 22px;
    width: chip-text.width + 32px;
    background: active ? Theme.accent-dim : Theme.bg-1;
    border-color: active ? Theme.accent-line : Theme.line-2;
    border-width: 1px;
    border-radius: Theme.radius-pill;

    chip-text := Text {
        x: 8px;
        y: (parent.height - self.height) / 2;
        text: label;
        color: active ? Theme.fg-0 : Theme.fg-1;
        font-size: Theme.font-meta;
    }

    SvgIcon {
        x: parent.width - 16px;
        y: (parent.height - 10px) / 2;
        width: 10px;
        height: 10px;
        icon: @image-url("../assets/icons/close.svg");
        tint: Theme.fg-2;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => { root.dismiss(); }
    }
}

component PlateDropdown inherits Rectangle {
    in property <[PlateTab]> tabs;
    in property <string> current-label;
    in property <bool> open: false;
    callback activated(int);
    callback toggled();
    callback dismissed();

    property <length> row-height: 28px;
    property <length> menu-height: min(188px, tabs.length * row-height);

    width: 220px;
    height: open ? 32px + menu-height : 28px;
    background: transparent;

    Rectangle {
        width: parent.width;
        height: 28px;
        background: plate-dropdown-touch.has-hover || root.open ? #000000cc : #00000088;
        border-color: root.open ? Theme.accent-line : #ffffff24;
        border-width: 1px;
        border-radius: 6px;

        Text {
            x: 9px;
            y: (parent.height - self.height) / 2;
            width: parent.width - 34px;
            text: root.current-label;
            color: Theme.fg-1;
            font-family: "JetBrains Mono";
            font-size: 11px;
            font-weight: 700;
            overflow: elide;
        }

        Text {
            x: parent.width - 20px;
            y: (parent.height - self.height) / 2 - 1px;
            text: root.open ? "⌃" : "⌄";
            color: Theme.fg-2;
            font-size: 12px;
            font-weight: 700;
        }

        plate-dropdown-touch := TouchArea {
            clicked => { root.toggled(); }
        }
    }

    if open: TouchArea {
        x: -3000px;
        y: -3000px;
        width: 7000px;
        height: 7000px;
        z: 10;
        clicked => { root.dismissed(); }
    }

    if open: Rectangle {
        y: 32px;
        width: parent.width;
        height: root.menu-height;
        z: 20;
        background: #202329fa;
        border-color: Theme.line-3;
        border-width: 1px;
        border-radius: 8px;

        Flickable {
            x: 1px;
            y: 1px;
            width: parent.width - 2px;
            height: parent.height - 2px;
            viewport-height: tabs.length * root.row-height;

            for tab[index] in tabs: Rectangle {
                x: 3px;
                y: index * root.row-height;
                width: parent.width - 6px;
                height: root.row-height;
                background: tab.selected ? Theme.accent-dim : plate-row-touch.has-hover ? Theme.bg-4 : transparent;
                border-radius: 5px;

                Text {
                    x: 8px;
                    y: (parent.height - self.height) / 2;
                    width: parent.width - 30px;
                    text: tab.label;
                    color: tab.selected ? Theme.fg-0 : Theme.fg-1;
                    font-family: "JetBrains Mono";
                    font-size: 11px;
                    font-weight: tab.selected ? 700 : 500;
                    overflow: elide;
                }

                if tab.selected: Text {
                    x: parent.width - 18px;
                    y: (parent.height - self.height) / 2;
                    text: "✓";
                    color: Theme.accent;
                    font-size: 12px;
                    font-weight: 700;
                }

                plate-row-touch := TouchArea {
                    clicked => { root.activated(tab.index); }
                }
            }
        }
    }
}

component EstimatePrinterDropdown inherits Rectangle {
    in property <[PrinterProfileChoice]> printers;
    in property <string> current-label;
    in property <bool> open: false;
    callback activated(string);
    callback toggled();
    callback dismissed();

    property <length> row-height: 36px;
    property <length> menu-height: min(178px, printers.length * row-height);

    width: 220px;
    height: open ? 30px + menu-height : 26px;
    background: transparent;

    Rectangle {
        width: parent.width;
        height: 26px;
        background: printer-dropdown-touch.has-hover || root.open ? Theme.bg-4 : Theme.bg-2;
        border-color: root.open ? Theme.accent-line : Theme.line;
        border-width: 1px;
        border-radius: 6px;

        Text {
            x: 9px;
            y: (parent.height - self.height) / 2;
            width: parent.width - 34px;
            text: root.current-label;
            color: Theme.fg-0;
            font-family: "JetBrains Mono";
            font-size: 10.5px;
            font-weight: 700;
            overflow: elide;
        }

        Text {
            x: parent.width - 20px;
            y: (parent.height - self.height) / 2 - 1px;
            text: root.open ? "⌃" : "⌄";
            color: Theme.fg-2;
            font-size: 12px;
            font-weight: 700;
        }

        printer-dropdown-touch := TouchArea {
            clicked => { root.toggled(); }
        }
    }

    if open: TouchArea {
        x: -3000px;
        y: -3000px;
        width: 7000px;
        height: 7000px;
        z: 10;
        clicked => { root.dismissed(); }
    }

    if open: Rectangle {
        y: 30px;
        width: parent.width;
        height: root.menu-height;
        z: 20;
        background: #202329fa;
        border-color: Theme.line-3;
        border-width: 1px;
        border-radius: 8px;

        Flickable {
            x: 1px;
            y: 1px;
            width: parent.width - 2px;
            height: parent.height - 2px;
            viewport-height: printers.length * root.row-height;

            for printer[index] in printers: Rectangle {
                x: 3px;
                y: index * root.row-height;
                width: parent.width - 6px;
                height: root.row-height;
                background: printer.selected ? Theme.accent-dim : printer-row-touch.has-hover ? Theme.bg-4 : transparent;
                border-radius: 5px;

                Text {
                    x: 8px;
                    y: 5px;
                    width: parent.width - 32px;
                    text: printer.label;
                    color: printer.selected ? Theme.fg-0 : Theme.fg-1;
                    font-size: Theme.font-body;
                    font-weight: printer.selected ? 700 : 500;
                    overflow: elide;
                }

                Text {
                    x: 8px;
                    y: 20px;
                    width: parent.width - 32px;
                    text: printer.detail;
                    color: Theme.fg-3;
                    font-family: "JetBrains Mono";
                    font-size: Theme.font-overline;
                    overflow: elide;
                }

                if printer.selected: Text {
                    x: parent.width - 18px;
                    y: (parent.height - self.height) / 2;
                    text: "✓";
                    color: Theme.accent;
                    font-size: 12px;
                    font-weight: 700;
                }

                printer-row-touch := TouchArea {
                    clicked => { root.activated(printer.key); }
                }
            }
        }
    }
}

component ModelCard inherits Rectangle {
    in property <BrowserCard> card;
    in property <bool> selected: false;
    in property <bool> layout-motion: true;
    in property <int> card-index;
    callback clicked(int);

    background: selected ? Theme.bg-5 : Theme.bg-3;
    border-color: card.error ? Theme.error :
                  selected ? Theme.accent-line : Theme.line;
    border-width: 1px;
    border-radius: Theme.radius-card;
    animate x { duration: layout-motion ? 220ms : 0ms; easing: ease-in-out; }
    animate y { duration: layout-motion ? 220ms : 0ms; easing: ease-in-out; }
    animate width { duration: layout-motion ? 200ms : 0ms; easing: ease-in-out; }
    animate height { duration: layout-motion ? 200ms : 0ms; easing: ease-in-out; }
    animate background { duration: 120ms; easing: ease-in-out; }
    animate border-color { duration: 120ms; easing: ease-in-out; }

    VerticalLayout {
        // Thumbnail area
        Rectangle {
            height: root.width;
            background: Theme.bg-0;
            border-radius: Theme.radius-card;

            CachedThumb {
                x: 0;
                y: 0;
                width: parent.width;
                height: parent.height;
                thumb-key: card.thumb-key;
                cached-image: card.thumb-image;
                thumb-ready: card.thumb-ready;
            }

            // Badge
            if card.error: Rectangle {
                x: 6px;
                y: 6px;
                width: err-text.width + 12px;
                height: 18px;
                background: #3c151ccc;
                border-radius: 3px;

                err-text := Text {
                    x: 6px;
                    y: (parent.height - self.height) / 2;
                    text: "ERR";
                    color: #ff9b8e;
                    font-family: "JetBrains Mono";
                    font-size: 10px;
                    font-weight: 700;
                }
            }

            if !card.error && card.badge != "": Text {
                x: 6px;
                y: 6px;
                text: card.badge;
                color: card.error ? #ffb4b0 : Theme.fg-2;
                font-family: "JetBrains Mono";
                font-size: 10px;
                font-weight: 700;
            }

            // Favorite star
            if card.favorite: SvgIcon {
                x: parent.width - 24px;
                y: 6px;
                width: 18px;
                height: 18px;
                icon: @image-url("../assets/icons/star.svg");
                tint: #d4a84f;
            }

            // Printed badge
            if card.printed: Rectangle {
                x: 6px;
                y: parent.height - self.height - 6px;
                width: print-label.width + 12px;
                height: 18px;
                background: #00000088;
                border-radius: 3px;

                print-label := Text {
                    x: 6px;
                    y: (parent.height - self.height) / 2;
                    text: card.printed-count;
                    color: Theme.success;
                    font-size: 10px;
                }
            }
        }

        // Card body
        Rectangle {
            height: 62px;

            VerticalLayout {
                padding-left: 9px;
                padding-right: 9px;
                padding-top: 7px;
                padding-bottom: 8px;
                spacing: 3px;

                Text {
                    text: card.title;
                    color: Theme.fg-0;
                    font-size: 11.5px;
                    font-weight: 500;
                    overflow: elide;
                }

                Text {
                    text: card.subtitle;
                    color: Theme.fg-2;
                    font-family: "JetBrains Mono";
                    font-size: 10px;
                    overflow: elide;
                }

                Text {
                    text: card.relative-modified;
                    color: Theme.fg-3;
                    font-family: "JetBrains Mono";
                    font-size: 10px;
                    overflow: elide;
                }
            }
        }
    }

    DragArea {
        width: parent.width;
        height: parent.height;
        mime-type: "application/x-modelrack-model-index";
        data: "" + root.card-index;

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.clicked(root.card-index); }
        }
    }
}

component SettingsTabButton inherits Rectangle {
    in property <string> label;
    in property <string> key;
    in property <image> icon;
    in property <bool> selected: false;
    callback activated(string);

    height: 28px;
    background: selected ? Theme.accent-dim : transparent;
    border-radius: Theme.radius-btn;

    if selected: Rectangle {
        x: 0;
        y: 4px;
        width: 2px;
        height: parent.height - 8px;
        border-radius: 1px;
        background: Theme.accent;
    }

    SvgIcon {
        x: 10px;
        y: (parent.height - 13px) / 2;
        width: 13px;
        height: 13px;
        icon: root.icon;
        tint: selected ? Theme.accent : Theme.fg-2;
    }

    Text {
        x: 30px;
        y: (parent.height - self.height) / 2;
        text: label;
        color: selected ? Theme.fg-0 : Theme.fg-1;
        font-size: Theme.font-body;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => { root.activated(key); }
    }
}

component SettingsRow inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <string> hint: "";

    height: hint == "" ? 50px : 58px;
    background: transparent;
    border-width: 0;

    Rectangle {
        x: 0;
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Theme.line;
    }

    Text {
        x: 0;
        y: hint == "" ? (parent.height - self.height) / 2 : 13px;
        width: 180px;
        text: label;
        color: Theme.fg-1;
        font-size: Theme.font-body;
        font-weight: 500;
    }

    if hint != "": Text {
        x: 0;
        y: 31px;
        width: 180px;
        text: hint;
        color: Theme.fg-3;
        font-size: Theme.font-meta;
        overflow: elide;
    }

    Text {
        x: 196px;
        y: (parent.height - self.height) / 2;
        width: parent.width - 196px;
        text: value;
        horizontal-alignment: right;
        color: Theme.fg-2;
        font-family: "JetBrains Mono";
        font-size: Theme.font-meta;
        overflow: elide;
    }
}

component SettingsOptionButton inherits Rectangle {
    in property <string> label;
    in property <string> key;
    in property <bool> selected: false;
    callback activated(string);

    height: 24px;
    width: 82px;
    background: selected ? Theme.bg-4 : option-touch.has-hover ? Theme.bg-3 : transparent;
    border-width: 0;
    border-radius: 4px;

    Text {
        x: 8px;
        y: (parent.height - self.height) / 2;
        width: parent.width - 16px;
        text: root.label;
        color: selected ? Theme.fg-0 : Theme.fg-1;
        font-size: 12px;
        font-weight: selected ? 600 : 500;
        horizontal-alignment: center;
        overflow: elide;
    }

    option-touch := TouchArea {
        clicked => { root.activated(root.key); }
    }
}

component SettingsSegment inherits Rectangle {
    in property <string> a-label;
    in property <string> a-key;
    in property <string> b-label;
    in property <string> b-key;
    in property <string> c-label: "";
    in property <string> c-key: "";
    in property <string> d-label: "";
    in property <string> d-key: "";
    in property <string> selected-key;
    in property <length> button-width: 82px;
    callback activated(string);

    height: 30px;
    width: 6px + button-width * (d-label != "" ? 4 : c-label != "" ? 3 : 2);
    background: Theme.bg-2;
    border-color: Theme.line;
    border-width: 1px;
    border-radius: 6px;

    HorizontalLayout {
        x: 2px;
        y: 2px;
        width: parent.width - 4px;
        height: parent.height - 4px;
        spacing: 1px;

        SettingsOptionButton { width: root.button-width; label: root.a-label; key: root.a-key; selected: root.selected-key == root.a-key; activated(key) => { root.activated(key); } }
        SettingsOptionButton { width: root.button-width; label: root.b-label; key: root.b-key; selected: root.selected-key == root.b-key; activated(key) => { root.activated(key); } }
        if root.c-label != "": SettingsOptionButton { width: root.button-width; label: root.c-label; key: root.c-key; selected: root.selected-key == root.c-key; activated(key) => { root.activated(key); } }
        if root.d-label != "": SettingsOptionButton { width: root.button-width; label: root.d-label; key: root.d-key; selected: root.selected-key == root.d-key; activated(key) => { root.activated(key); } }
    }
}

component SettingsToggle inherits Rectangle {
    in property <bool> on: false;
    in property <bool> interactive: true;
    callback toggled(bool);

    width: 36px;
    height: 20px;
    background: on ? Theme.accent : Theme.bg-3;
    border-color: on ? Theme.accent : Theme.line;
    border-width: 1px;
    border-radius: 10px;

    Rectangle {
        x: root.on ? 18px : 2px;
        y: 2px;
        width: 14px;
        height: 14px;
        background: root.on ? #f4fbff : Theme.fg-1;
        border-radius: 7px;
    }

    if interactive: TouchArea {
        clicked => { root.toggled(!root.on); }
    }
}

component SettingsSwatch inherits Rectangle {
    in property <brush> fill;
    in property <bool> selected: false;

    width: 26px;
    height: 26px;
    background: fill;
    border-radius: 13px;
    border-color: selected ? Theme.fg-0 : transparent;
    border-width: 2px;
}

component SettingsActionButton inherits Rectangle {
    in property <string> label;
    in property <image> icon;
    in property <bool> danger: false;
    in property <length> button-width: 128px;
    callback activated();

    width: button-width;
    height: 28px;
    background: action-touch.has-hover ? Theme.bg-4 : Theme.bg-3;
    border-color: danger ? #c9504066 : Theme.line-2;
    border-width: 1px;
    border-radius: 5px;

    SvgIcon {
        x: 10px;
        y: (parent.height - 12px) / 2;
        width: 12px;
        height: 12px;
        icon: root.icon;
        tint: danger ? Theme.error : Theme.fg-1;
    }

    button-label := Text {
        x: 28px;
        y: (parent.height - self.height) / 2;
        text: root.label;
        color: danger ? Theme.error : Theme.fg-0;
        font-size: 12px;
    }

    action-touch := TouchArea {
        clicked => { root.activated(); }
    }
}

component SettingsKbd inherits Rectangle {
    in property <string> label;

    width: max(22px, key-label.width + 12px);
    height: 22px;
    background: Theme.bg-3;
    border-color: Theme.line-2;
    border-width: 1px;
    border-radius: 4px;

    key-label := Text {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        text: root.label;
        color: Theme.fg-1;
        font-family: "JetBrains Mono";
        font-size: 11px;
    }
}

component ModelListRow inherits Rectangle {
    in property <BrowserCard> card;
    in property <int> card-index;
    in property <bool> selected: false;
    callback clicked(int);

    height: 58px;
    background: selected ? Theme.bg-5 : list-touch.has-hover ? Theme.bg-3 : Theme.bg-1;
    border-color: selected ? Theme.accent-line : Theme.line;
    border-width: 1px;
    border-radius: 6px;

    CachedThumb {
        x: 8px;
        y: 6px;
        width: 46px;
        height: 46px;
        thumb-key: card.thumb-key;
        cached-image: card.thumb-image;
        thumb-ready: card.thumb-ready;
    }

    Text {
        x: 64px;
        y: 10px;
        width: parent.width - 360px;
        text: card.title;
        color: Theme.fg-0;
        font-size: Theme.font-body;
        font-weight: 600;
        overflow: elide;
    }

    Text {
        x: 64px;
        y: 31px;
        width: parent.width - 360px;
        text: card.subtitle;
        color: Theme.fg-2;
        font-family: "JetBrains Mono";
        font-size: Theme.font-overline;
        overflow: elide;
    }

    Text {
        x: parent.width - 230px;
        y: 20px;
        width: 110px;
        text: card.author;
        color: Theme.fg-2;
        font-size: Theme.font-meta;
        overflow: elide;
    }

    Text {
        x: parent.width - 108px;
        y: 20px;
        width: 92px;
        text: card.relative-modified;
        color: Theme.fg-3;
        font-family: "JetBrains Mono";
        font-size: Theme.font-overline;
        horizontal-alignment: right;
        overflow: elide;
    }

    list-drag := DragArea {
        width: parent.width;
        height: parent.height;
        mime-type: "application/x-modelrack-model-index";
        data: "" + root.card-index;

        list-touch := TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.clicked(root.card-index); }
        }
    }
}

component DetailKV inherits Rectangle {
    in property <string> label;
    in property <string> value;

    height: 22px;

    Text {
        x: 0;
        y: 0;
        width: 90px;
        text: label;
        color: Theme.fg-2;
        font-size: 12px;
    }

    Text {
        x: 90px;
        y: 0;
        text: value;
        color: Theme.fg-0;
        font-family: "JetBrains Mono";
        font-size: 11.5px;
    }
}

component TrafficLightButton inherits Rectangle {
    in property <brush> fill;
    in property <image> glyph;
    in property <brush> glyph-tint;
    in property <bool> controls-hover;
    out property <bool> hovered: ta-button.has-hover;
    callback activated();

    width: 12px;
    height: 12px;
    border-radius: 6px;
    background: fill;
    border-color: #00000033;
    border-width: 1px;

    SvgIcon {
        x: 2px;
        y: 2px;
        width: 8px;
        height: 8px;
        icon: glyph;
        tint: glyph-tint;
        visible: controls-hover || ta-button.has-hover;
    }

    ta-button := TouchArea {
        clicked => { activated(); }
    }
}

// ─── Main window ─────────────────────────────────────────

export component ModelRackWindow inherits Window {
    // Core properties
    in property <string> app-title: "ModelRack";
    in property <string> app-version: "v0.1.0";
    in property <string> library-label: "Sample library";
    in property <int> selected-card-index: -1;
    in property <string> selected-thumb-key: "rack";
    in property <image> selected-thumb-image;
    in property <bool> selected-thumb-ready: false;
    in property <string> status-text: "Ready";
    in property <int> scan-progress-percent: -1;
    in property <string> density-label: "M";
    in property <string> view-mode-label: "Grid";
    in-out property <string> search-text;
    in property <string> browser-message;
    in property <string> browser-count-label;
    in property <string> sort-label: "Name ↑";

    // Sidebar counts
    in property <int> all-count;
    in property <int> recent-count;
    in property <int> favorites-count;
    in property <int> printed-count;
    in property <int> duplicates-count;
    in property <int> ready-count;
    in property <int> errors-count;

    // Data models
    in property <[BrowserCard]> model-cards;
    in property <[SidebarItem]> folder-items;
    in property <[SidebarItem]> tag-items;
    in property <string> active-filter-key: "all";

    // Detail panel
    in property <bool> has-selection: false;
    in property <string> detail-name;
    in property <string> detail-path;
    in property <string> detail-format;
    in property <string> detail-tris;
    in property <string> detail-dims;
    in property <string> detail-volume;
    in property <string> detail-filesize;
    in property <string> detail-hash;
    in property <string> detail-modified;
    in property <string> detail-added;
    in property <string> detail-author;
    in property <bool> detail-has-plates: false;
    in property <string> detail-plate-summary;
    in property <string> detail-plate-selected-label;
    in property <[PlateTab]> detail-plate-tabs;
    in property <string> detail-tags-label;
    in property <string> detail-tags-input;
    in property <[TagChip]> detail-tag-chips;
    in property <string> detail-notes;
    in property <int> detail-printed-count;
    in property <[PrintHistoryRow]> detail-print-history;
    in property <int> detail-health-score;
    in property <bool> detail-manifold;
    in property <bool> detail-watertight;
    in property <bool> detail-normals;
    in property <string> detail-estimate-time;
    in property <string> detail-estimate-grams;
    in property <string> detail-estimate-layers;
    in property <string> detail-estimate-printer-label;
    in property <string> detail-estimate-printer-detail;
    in property <bool> detail-estimate-has-printer-choices: false;
    in property <[PrinterProfileChoice]> detail-estimate-printers;
    in property <bool> detail-bed-fit;
    in property <bool> detail-fav;

    // Settings
    in property <bool> settings-open;
    in property <string> settings-tab: "general";
    in property <string> settings-language-key: "en";
    in property <string> settings-language-label: "English";
    in property <string> settings-theme-key: "dark";
    in property <string> settings-theme-label: "Dark";
    in property <string> settings-sort-key: "name";
    in property <bool> settings-sort-ascending: true;
    in property <string> settings-thumbnail-style: "iso";
    in property <string> settings-thumbnail-lighting: "studio";
    in property <string> settings-thumbnail-aa: "msaa4x";
    in property <string> settings-update-status: "ModelRack is up to date";
    in property <string> settings-folder-label;
    in property <string> settings-density-label;
    in property <string> settings-slicer-label;
    in property <image> settings-slicer-icon-image;
    in property <bool> settings-slicer-icon-ready: false;
    in property <[SlicerCandidate]> settings-slicer-candidates;
    in property <string> settings-printer-summary;
    in property <string> settings-default-printer-label;
    in property <int> settings-printer-active-count;
    in property <[PrinterProfileChoice]> settings-printer-profiles;
    in property <[ChoiceRow]> settings-printer-makers;
    in property <[ChoiceRow]> settings-printer-models;
    in property <[ChoiceRow]> settings-printer-nozzles;
    in property <string> settings-printer-maker-label;
    in property <string> settings-printer-model-label;
    property <bool> sidebar-context-open: false;
    property <string> sidebar-context-key;
    property <string> sidebar-context-label;
    property <bool> sidebar-context-is-folder: false;
    property <length> sidebar-context-x: 0px;
    property <length> sidebar-context-y: 0px;
    property <bool> slicer-menu-open: false;
    property <bool> preview-dragging: false;
    property <length> preview-last-x: 0px;
    property <length> preview-last-y: 0px;
    property <bool> preview-fullscreen-open: false;
    property <bool> preview-plate-menu-open: false;
    property <bool> estimate-printer-menu-open: false;
    property <bool> sort-menu-open: false;
    property <bool> left-sidebar-open: true;
    property <bool> right-detail-open: true;
    property <length> left-sidebar-min-width: 180px;
    property <length> right-detail-min-width: 280px;
    property <length> left-sidebar-max-width: 380px;
    property <length> right-detail-max-width: 520px;
    property <length> left-sidebar-width: Theme.sidebar-width;
    property <length> right-detail-width: Theme.detail-width;
    property <length> visible-left-sidebar-width: left-sidebar-open ? left-sidebar-width : 0px;
    property <length> visible-right-detail-width: right-detail-open ? right-detail-width : 0px;
    property <bool> left-sidebar-resizing: false;
    property <bool> right-detail-resizing: false;
    property <length> resize-origin-x: 0px;
    property <length> resize-start-width: 0px;
    property <bool> rename-editing: false;
    property <string> rename-draft: "";

    // Callbacks
    callback open-folder();
    callback refresh-library();
    callback open-settings();
    callback close-settings();
    callback choose-settings-tab(string);
    callback choose-settings-language(string);
    callback choose-settings-theme(string);
    callback choose-settings-sort(string);
    callback choose-settings-thumbnail-style(string);
    callback choose-settings-thumbnail-lighting(string);
    callback choose-settings-thumbnail-aa(string);
    callback choose-settings-printer-maker(string);
    callback choose-settings-printer-model(string);
    callback choose-settings-printer-nozzle(string);
    callback check-updates();
    callback cycle-settings-language();
    callback toggle-settings-theme();
    callback cycle-settings-density();
    callback choose-slicer();
    callback choose-settings-slicer(string);
    callback toggle-settings-printer(string);
    callback choose-settings-default-printer(string);
    callback choose-estimate-printer(string);
    callback apply-search(string);
    callback choose-view-mode(string);
    callback choose-density(string);
    callback cycle-view-mode();
    callback cycle-density();
    callback toggle-sort();
    callback choose-filter(string);
    callback toggle-sidebar-folder(string);
    callback sidebar-context-action(string, string, string);
    callback undo-library-action();
    callback select-model(int);
    callback add-tag-to-model(string, string) -> bool;
    callback toggle-favorite();
    callback rename-model(string) -> bool;
    callback save-metadata(string, string, string);
    callback add-tags(string);
    callback remove-tag(int);
    callback adjust-printed-count(int);
    callback add-print-record(string, string, string, string, string, string, string);
    callback remove-print-record(int);
    callback open-in-slicer();
    callback choose-preview-plate(int);
    callback preview-orbit(float, float);
    callback preview-orbit-reset();
    callback window-close();
    callback window-minimize();
    callback window-fullscreen();
    callback titlebar-drag(length, length);

    title: "";
    preferred-width: 1480px;
    preferred-height: 920px;
    default-font-family: "Inter";
    background: Theme.bg-0;

    init => {
        shortcut-scope.focus();
    }

    shortcut-scope := FocusScope {
        x: 0;
        y: 0;
        width: 0px;
        height: 0px;

        KeyBinding {
            keys: @keys(Control + Z);
            activated => { undo-library-action(); }
        }

        KeyBinding {
            keys: @keys(Meta + Z);
            activated => { undo-library-action(); }
        }

        KeyBinding {
            keys: @keys(F2);
            activated => {
                if has-selection && !settings-open {
                    rename-draft = detail-name;
                    rename-editing = true;
                }
            }
        }

        KeyBinding {
            keys: @keys(Return);
            activated => {
                if has-selection && !settings-open {
                    rename-draft = detail-name;
                    rename-editing = true;
                }
            }
        }
    }

    // ─── Root layout ───
    VerticalLayout {
        // ─── Custom titlebar ───
        Rectangle {
            height: Theme.titlebar-height;
            background: Theme.bg-1;

            ta-titlebar-drag := TouchArea {
                pointer-event(event) => {
                    if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                        titlebar-drag(ta-titlebar-drag.mouse-x, ta-titlebar-drag.mouse-y);
                    }
                }
            }

            Rectangle {
                x: 0;
                y: parent.height - 1px;
                width: parent.width;
                height: 1px;
                background: Theme.line;
            }

            traffic-hover := TouchArea {
                x: 6px;
                y: (parent.height - 24px) / 2;
                width: 66px;
                height: 24px;
            }

            traffic-lights := HorizontalLayout {
                x: 12px;
                y: (parent.height - 12px) / 2;
                spacing: 8px;

                close-light := TrafficLightButton {
                    fill: #ff5f56;
                    glyph: @image-url("../assets/icons/close.svg");
                    glyph-tint: #7a1210;
                    controls-hover: traffic-hover.has-hover || close-light.hovered || minimize-light.hovered || fullscreen-light.hovered;
                    activated => { window-close(); }
                }

                minimize-light := TrafficLightButton {
                    fill: #ffbd2e;
                    glyph: @image-url("../assets/icons/minus.svg");
                    glyph-tint: #8a5a00;
                    controls-hover: traffic-hover.has-hover || close-light.hovered || minimize-light.hovered || fullscreen-light.hovered;
                    activated => { window-minimize(); }
                }

                fullscreen-light := TrafficLightButton {
                    fill: #27c93f;
                    glyph: @image-url("../assets/icons/fullscreen.svg");
                    glyph-tint: #0b6d1a;
                    controls-hover: traffic-hover.has-hover || close-light.hovered || minimize-light.hovered || fullscreen-light.hovered;
                    activated => { window-fullscreen(); }
                }
            }

            Image {
                x: 80px;
                y: (parent.height - 18px) / 2;
                width: 18px;
                height: 18px;
                source: @image-url("../assets/icons/app-mark.svg");
                image-fit: contain;
            }

            Text {
                x: 106px;
                y: (parent.height - self.height) / 2;
                text: app-title;
                color: Theme.fg-1;
                font-size: 12px;
                font-weight: 500;
            }

            Text {
                x: 178px;
                y: (parent.height - self.height) / 2;
                text: "—";
                color: Theme.fg-3;
                font-size: 12px;
            }

            Text {
                x: 196px;
                y: (parent.height - self.height) / 2;
                text: library-label;
                color: Theme.fg-2;
                font-family: "JetBrains Mono";
                font-size: 11px;
            }

            // VSCode-style layout controls
            Rectangle {
                x: parent.width - 104px;
                y: (parent.height - 26px) / 2;
                width: 26px;
                height: 26px;
                border-radius: Theme.radius-btn;
                background: ta-toggle-left.has-hover ? Theme.bg-3 : left-sidebar-open ? Theme.accent-dim : transparent;
                border-color: left-sidebar-open ? Theme.accent-line : transparent;
                border-width: left-sidebar-open ? 1px : 0px;

                Rectangle { x: 7px; y: 7px; width: 12px; height: 12px; border-color: Theme.fg-2; border-width: 1px; border-radius: 2px; background: transparent; }
                Rectangle { x: 7px; y: 7px; width: 4px; height: 12px; border-radius: 2px; background: left-sidebar-open ? Theme.accent : Theme.fg-3; }

                ta-toggle-left := TouchArea {
                    clicked => { left-sidebar-open = !left-sidebar-open; }
                }
            }

            Rectangle {
                x: parent.width - 72px;
                y: (parent.height - 26px) / 2;
                width: 26px;
                height: 26px;
                border-radius: Theme.radius-btn;
                background: ta-toggle-right.has-hover ? Theme.bg-3 : right-detail-open ? Theme.accent-dim : transparent;
                border-color: right-detail-open ? Theme.accent-line : transparent;
                border-width: right-detail-open ? 1px : 0px;

                Rectangle { x: 7px; y: 7px; width: 12px; height: 12px; border-color: Theme.fg-2; border-width: 1px; border-radius: 2px; background: transparent; }
                Rectangle { x: 15px; y: 7px; width: 4px; height: 12px; border-radius: 2px; background: right-detail-open ? Theme.accent : Theme.fg-3; }

                ta-toggle-right := TouchArea {
                    clicked => { right-detail-open = !right-detail-open; }
                }
            }

            Rectangle {
                x: parent.width - 38px;
                y: (parent.height - 26px) / 2;
                width: 26px;
                height: 26px;
                border-radius: Theme.radius-btn;
                background: ta-settings.has-hover ? Theme.bg-3 : transparent;

                SvgIcon {
                    x: (parent.width - 14px) / 2;
                    y: (parent.height - 14px) / 2;
                    width: 14px;
                    height: 14px;
                    icon: @image-url("../assets/icons/settings.svg");
                    tint: Theme.fg-2;
                }

                ta-settings := TouchArea {
                    clicked => { open-settings(); }
                }
            }
        }

        // ─── Main 3-pane area ───
        HorizontalLayout {
            // ─── Sidebar ───
            Rectangle {
                width: visible-left-sidebar-width;
                background: Theme.bg-1;
                clip: true;
                animate width { duration: left-sidebar-resizing ? 0ms : 180ms; easing: ease-in-out; }

                Rectangle {
                    x: parent.width - 1px;
                    y: 0;
                    width: 1px;
                    height: parent.height;
                    background: Theme.line;
                }

                if left-sidebar-open: sidebar-scroll := ScrollView {
                    x: 6px;
                    y: 0;
                    width: max(0px, parent.width - 12px);
                    height: parent.height;

                    VerticalLayout {
                        padding-top: 10px;
                        spacing: 1px;

                        SectionHeader { label: "LIBRARY"; inset: true; }

                        SidebarLine { icon: @image-url("../assets/icons/layers.svg"); label: "All Models"; count: all-count; selected: active-filter-key == "all"; activated => { choose-filter("all"); } }
                        SidebarLine { icon: @image-url("../assets/icons/clock.svg"); label: "Recent"; count: recent-count; selected: active-filter-key == "recent"; activated => { choose-filter("recent"); } }
                        SidebarLine { icon: @image-url("../assets/icons/star.svg"); label: "Favorites"; count: favorites-count; selected: active-filter-key == "favorites"; activated => { choose-filter("favorites"); } }
                        SidebarLine { icon: @image-url("../assets/icons/print.svg"); label: "Printed"; count: printed-count; selected: active-filter-key == "printed"; activated => { choose-filter("printed"); } }
                        SidebarLine { icon: @image-url("../assets/icons/box.svg"); label: "Ready to Print"; count: ready-count; selected: active-filter-key == "ready"; activated => { choose-filter("ready"); } }
                        SidebarLine { icon: @image-url("../assets/icons/duplicate.svg"); label: "Duplicates"; count: duplicates-count; selected: active-filter-key == "duplicates"; activated => { choose-filter("duplicates"); } }
                        SidebarLine { icon: @image-url("../assets/icons/error.svg"); label: "Parse Errors"; count: errors-count; selected: active-filter-key == "errors"; activated => { choose-filter("errors"); } }

                        Rectangle {
                            height: 1px;
                            background: Theme.line;
                        }

                        if folder-items.length > 0: SectionHeader { label: "FOLDERS"; show-add: true; }

                        for folder in folder-items: folder-row := SidebarLine {
                            icon: folder.depth == 0 ? @image-url("../assets/icons/folder-open.svg") : @image-url("../assets/icons/folder.svg");
                            label: folder.label;
                            count: folder.count;
                            depth: folder.depth;
                            reserve-leading: true;
                            expandable: folder.expandable;
                            expanded: folder.expanded;
                            selected: active-filter-key == folder.key;
                            activated => { choose-filter(folder.key); }
                            toggle-requested => { toggle-sidebar-folder(folder.key); }
                            context-requested(x, y) => {
                                sidebar-context-key = folder.key;
                                sidebar-context-label = folder.label;
                                sidebar-context-is-folder = true;
                                sidebar-context-x = folder-row.absolute-position.x - root.absolute-position.x + x + 12px;
                                sidebar-context-y = folder-row.absolute-position.y - root.absolute-position.y + y + 12px;
                                sidebar-context-open = true;
                            }
                        }

                        if tag-items.length > 0: SectionHeader { label: "TAGS"; show-add: true; }

                        for tag in tag-items: tag-row := SidebarLine {
                            icon: @image-url("../assets/icons/tag.svg");
                            label: tag.label;
                            count: tag.count;
                            drop-enabled: true;
                            selected: active-filter-key == tag.key;
                            activated => { choose-filter(tag.key); }
                            model-dropped(model, tag) => { add-tag-to-model(model, tag); }
                            context-requested(x, y) => {
                                sidebar-context-key = tag.key;
                                sidebar-context-label = tag.label;
                                sidebar-context-is-folder = false;
                                sidebar-context-x = tag-row.absolute-position.x - root.absolute-position.x + x + 12px;
                                sidebar-context-y = tag-row.absolute-position.y - root.absolute-position.y + y + 12px;
                                sidebar-context-open = true;
                            }
                        }
                    }
                }
            }

            if left-sidebar-open: Rectangle {
                width: 6px;
                background: left-resize-touch.has-hover || left-sidebar-resizing ? Theme.accent-dim : Theme.bg-2;

                Rectangle {
                    x: 2px;
                    y: 0;
                    width: 1px;
                    height: parent.height;
                    background: left-resize-touch.has-hover || left-sidebar-resizing ? Theme.accent : Theme.line;
                }

                left-resize-touch := TouchArea {
                    mouse-cursor: ew-resize;
                    pointer-event(event) => {
                        if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                            left-sidebar-resizing = true;
                            resize-origin-x = left-resize-touch.absolute-position.x - root.absolute-position.x + left-resize-touch.mouse-x;
                            resize-start-width = left-sidebar-width;
                        } else if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                            left-sidebar-resizing = false;
                        } else if (event.kind == PointerEventKind.cancel) {
                            left-sidebar-resizing = false;
                        } else if (event.kind == PointerEventKind.move && left-sidebar-resizing) {
                            left-sidebar-width = min(left-sidebar-max-width, max(left-sidebar-min-width, resize-start-width + ((left-resize-touch.absolute-position.x - root.absolute-position.x + left-resize-touch.mouse-x) - resize-origin-x)));
                        }
                    }
                }
            }

            // ─── Center content ───
            VerticalLayout {
                // Toolbar
                Rectangle {
                    height: Theme.toolbar-height;
                    background: Theme.bg-2;

                    Rectangle {
                        x: 0;
                        y: parent.height - 1px;
                        width: parent.width;
                        height: 1px;
                        background: Theme.line;
                    }

                    HorizontalLayout {
                        x: 0;
                        y: 0;
                        width: parent.width;
                        height: parent.height;
                        padding: 8px;
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 8px;
                        alignment: start;

                        // Search
                        Rectangle {
                            width: 224px;
                            height: 28px;
                            background: Theme.bg-1;
                            border-color: Theme.line;
                            border-width: 1px;
                            border-radius: Theme.radius-btn;

                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 8px;
                                spacing: 6px;
                                alignment: center;

                                SvgIcon {
                                    width: 14px;
                                    height: 14px;
                                    icon: @image-url("../assets/icons/search.svg");
                                    tint: Theme.fg-2;
                                }

                                search-field := LineEdit {
                                    horizontal-stretch: 1;
                                    placeholder-text: settings-language-key == "ko" ? "파일명, 태그, 메모 검색…" : settings-language-key == "ja" ? "ファイル名、タグ、メモを検索…" : "Search filename, tag, notes…";
                                    text <=> search-text;
                                    accepted(text) => { apply-search(text); }
                                }

                                Rectangle {
                                    width: 31px;
                                    height: 18px;
                                    background: Theme.bg-2;
                                    border-color: Theme.line-2;
                                    border-width: 1px;
                                    border-radius: 4px;

                                    Text {
                                        x: (parent.width - self.width) / 2;
                                        y: (parent.height - self.height) / 2;
                                        text: "⌘K";
                                        color: Theme.fg-3;
                                        font-family: "JetBrains Mono";
                                        font-size: 10px;
                                    }
                                }
                            }
                        }

                        // View segmented control
                        Rectangle {
                            width: 202px;
                            height: 28px;
                            background: Theme.bg-1;
                            border-color: Theme.line;
                            border-width: 1px;
                            border-radius: Theme.radius-btn;

                            Rectangle {
                                x: view-mode-label == "Masonry" ? 62px : view-mode-label == "List" ? 146px : 2px;
                                y: 2px;
                                width: view-mode-label == "Masonry" ? 82px : view-mode-label == "List" ? 54px : 58px;
                                height: 24px;
                                background: Theme.bg-3;
                                border-radius: 4px;
                                animate x { duration: 180ms; easing: ease-in-out; }
                                animate width { duration: 180ms; easing: ease-in-out; }
                            }

                            Rectangle {
                                x: 2px;
                                y: 2px;
                                width: 58px;
                                height: 24px;
                                background: transparent;

                                grid-label := Text {
                                    x: (parent.width - 16px - self.width) / 2 + 16px;
                                    y: 0;
                                    height: parent.height;
                                    text: "Grid";
                                    color: view-mode-label == "Grid" ? Theme.fg-0 : Theme.fg-1;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                }

                                SvgIcon {
                                    x: grid-label.x - 16px;
                                    y: (parent.height - 12px) / 2;
                                    width: 12px;
                                    height: 12px;
                                    icon: @image-url("../assets/icons/grid.svg");
                                    tint: view-mode-label == "Grid" ? Theme.fg-0 : Theme.fg-1;
                                }

                                TouchArea { clicked => { choose-view-mode("grid"); } }
                            }

                            Rectangle { x: 61px; y: 5px; width: 1px; height: 18px; background: Theme.line; }

                            Rectangle {
                                x: 62px;
                                y: 2px;
                                width: 82px;
                                height: 24px;
                                background: transparent;

                                masonry-label := Text {
                                    x: (parent.width - 16px - self.width) / 2 + 16px;
                                    y: 0;
                                    height: parent.height;
                                    text: "Masonry";
                                    color: view-mode-label == "Masonry" ? Theme.fg-0 : Theme.fg-1;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                }

                                SvgIcon {
                                    x: masonry-label.x - 16px;
                                    y: (parent.height - 12px) / 2;
                                    width: 12px;
                                    height: 12px;
                                    icon: @image-url("../assets/icons/masonry.svg");
                                    tint: view-mode-label == "Masonry" ? Theme.fg-0 : Theme.fg-1;
                                }

                                TouchArea { clicked => { choose-view-mode("masonry"); } }
                            }

                            Rectangle { x: 145px; y: 5px; width: 1px; height: 18px; background: Theme.line; }

                            Rectangle {
                                x: 146px;
                                y: 2px;
                                width: 54px;
                                height: 24px;
                                background: transparent;

                                list-label := Text {
                                    x: (parent.width - 16px - self.width) / 2 + 16px;
                                    y: 0;
                                    height: parent.height;
                                    text: "List";
                                    color: view-mode-label == "List" ? Theme.fg-0 : Theme.fg-1;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                }

                                SvgIcon {
                                    x: list-label.x - 16px;
                                    y: (parent.height - 12px) / 2;
                                    width: 12px;
                                    height: 12px;
                                    icon: @image-url("../assets/icons/list.svg");
                                    tint: view-mode-label == "List" ? Theme.fg-0 : Theme.fg-1;
                                }

                                TouchArea { clicked => { choose-view-mode("list"); } }
                            }
                        }

                        // Density segmented control
                        Rectangle {
                            width: 84px;
                            height: 28px;
                            background: Theme.bg-1;
                            border-color: Theme.line;
                            border-width: 1px;
                            border-radius: Theme.radius-btn;

                            Rectangle {
                                x: density-label == "M" ? 30px : density-label == "L" ? 56px : 2px;
                                y: 2px;
                                width: density-label == "M" ? 24px : 26px;
                                height: 24px;
                                background: Theme.bg-3;
                                border-radius: 4px;
                                animate x { duration: 180ms; easing: ease-in-out; }
                                animate width { duration: 180ms; easing: ease-in-out; }
                            }

                            Rectangle {
                                x: 2px;
                                y: 2px;
                                width: 26px;
                                height: 24px;
                                background: transparent;
                                Text { x: (parent.width - self.width) / 2; y: 0; height: parent.height; text: "S"; color: density-label == "S" ? Theme.fg-0 : Theme.fg-1; font-size: 12px; vertical-alignment: center; }
                                TouchArea { clicked => { choose-density("small"); } }
                            }
                            Rectangle { x: 29px; y: 5px; width: 1px; height: 18px; background: Theme.line; }
                            Rectangle {
                                x: 30px;
                                y: 2px;
                                width: 24px;
                                height: 24px;
                                background: transparent;
                                Text { x: (parent.width - self.width) / 2; y: 0; height: parent.height; text: "M"; color: density-label == "M" ? Theme.fg-0 : Theme.fg-1; font-size: 12px; vertical-alignment: center; }
                                TouchArea { clicked => { choose-density("medium"); } }
                            }
                            Rectangle { x: 55px; y: 5px; width: 1px; height: 18px; background: Theme.line; }
                            Rectangle {
                                x: 56px;
                                y: 2px;
                                width: 26px;
                                height: 24px;
                                background: transparent;
                                Text { x: (parent.width - self.width) / 2; y: 0; height: parent.height; text: "L"; color: density-label == "L" ? Theme.fg-0 : Theme.fg-1; font-size: 12px; vertical-alignment: center; }
                                TouchArea { clicked => { choose-density("large"); } }
                            }
                        }

                        Rectangle {
                            width: 1px;
                            height: 18px;
                            background: Theme.line-2;
                        }

                        // Sort dropdown + direction
                        Rectangle {
                            width: 146px;
                            height: sort-menu-open ? 178px : 28px;
                            z: 60;

                            Rectangle {
                                x: 0;
                                y: 0;
                                width: 108px;
                                height: 28px;
                                background: sort-button-touch.has-hover || sort-menu-open ? Theme.bg-3 : Theme.bg-1;
                                border-color: sort-menu-open ? Theme.accent-line : Theme.line;
                                border-width: 1px;
                                border-radius: Theme.radius-btn;

                                SvgIcon { x: 9px; y: 8px; width: 12px; height: 12px; icon: @image-url("../assets/icons/sort.svg"); tint: Theme.fg-2; }
                                Text { x: 28px; y: 7px; width: 62px; text: settings-sort-key == "date" ? "Date" : settings-sort-key == "size" ? "Size" : settings-sort-key == "triangles" ? "Triangles" : "Name"; color: Theme.fg-1; font-size: 12px; overflow: elide; }
                                SvgIcon { x: parent.width - 16px; y: 10px; width: 8px; height: 8px; icon: @image-url("../assets/icons/chevron-right.svg"); tint: Theme.fg-2; transform-rotation: sort-menu-open ? -90deg : 90deg; }
                                sort-button-touch := TouchArea { clicked => { sort-menu-open = !sort-menu-open; } }
                            }

                            Rectangle {
                                x: 109px;
                                y: 5px;
                                width: 1px;
                                height: 18px;
                                background: Theme.line-2;
                            }

                            Rectangle {
                                x: 111px;
                                y: 0;
                                width: 35px;
                                height: 28px;
                                background: sort-dir-touch.has-hover ? Theme.bg-3 : Theme.bg-1;
                                border-color: Theme.line;
                                border-width: 1px;
                                border-radius: Theme.radius-btn;

                                Text { x: 0; y: 6px; width: parent.width; text: settings-sort-ascending ? "↑" : "↓"; color: Theme.fg-1; font-size: 15px; horizontal-alignment: center; }
                                sort-dir-touch := TouchArea { clicked => { toggle-sort(); } }
                            }

                            if sort-menu-open: Rectangle {
                                x: 0;
                                y: 32px;
                                width: 146px;
                                height: 142px;
                                background: Theme.bg-1;
                                border-color: Theme.line-3;
                                border-width: 1px;
                                border-radius: 7px;
                                clip: true;

                                VerticalLayout {
                                    padding: 4px;
                                    spacing: 1px;

                                    SettingsOptionButton { width: 136px; label: "Name"; key: "name"; selected: settings-sort-key == "name"; activated(key) => { choose-settings-sort(key); sort-menu-open = false; } }
                                    SettingsOptionButton { width: 136px; label: "Date modified"; key: "date"; selected: settings-sort-key == "date"; activated(key) => { choose-settings-sort(key); sort-menu-open = false; } }
                                    SettingsOptionButton { width: 136px; label: "File size"; key: "size"; selected: settings-sort-key == "size"; activated(key) => { choose-settings-sort(key); sort-menu-open = false; } }
                                    SettingsOptionButton { width: 136px; label: "Triangles"; key: "triangles"; selected: settings-sort-key == "triangles"; activated(key) => { choose-settings-sort(key); sort-menu-open = false; } }
                                }
                            }
                        }

                        Rectangle { horizontal-stretch: 1; }

                        // Refresh
                        Rectangle {
                            width: 28px;
                            height: 28px;
                            background: ta-refresh.has-hover ? Theme.bg-3 : Theme.bg-1;
                            border-color: Theme.line;
                            border-width: 1px;
                            border-radius: Theme.radius-btn;
                            animate background { duration: 120ms; easing: ease-in-out; }

                            SvgIcon {
                                x: (parent.width - 14px) / 2;
                                y: (parent.height - 14px) / 2;
                                width: 14px;
                                height: 14px;
                                icon: @image-url("../assets/icons/refresh.svg");
                                tint: Theme.fg-1;
                            }

                            ta-refresh := TouchArea { clicked => { refresh-library(); } }
                        }

                        // Add Folder
                        Rectangle {
                            width: add-text.width + 42px;
                            height: 28px;
                            background: ta-add.has-hover ? #6fc8e0 : Theme.accent;
                            border-radius: Theme.radius-btn;

                            SvgIcon {
                                x: 10px;
                                y: (parent.height - 13px) / 2;
                                width: 13px;
                                height: 13px;
                                icon: @image-url("../assets/icons/plus.svg");
                                tint: #0e2a32;
                            }

                            add-text := Text {
                                x: 29px;
                                y: (parent.height - self.height) / 2;
                                text: settings-language-key == "ko" ? "폴더 추가" : settings-language-key == "ja" ? "フォルダ追加" : "Add Folder";
                                color: #0e2a32;
                                font-size: Theme.font-body;
                                font-weight: 500;
                            }

                            ta-add := TouchArea { clicked => { open-folder(); } }
                        }
                    }
                }

                // Filter bar
                Rectangle {
                    height: Theme.filterbar-height;
                    background: Theme.bg-2;

                    Rectangle {
                        x: 0;
                        y: parent.height - 1px;
                        width: parent.width;
                        height: 1px;
                        background: Theme.line;
                    }

                    Text {
                        x: 12px;
                        y: 0;
                        height: parent.height;
                        text: active-filter-key == "all" ? (settings-language-key == "ko" ? "전체 모델" : settings-language-key == "ja" ? "すべてのモデル" : "All models") : (settings-language-key == "ko" ? "필터링 중" : settings-language-key == "ja" ? "フィルタ中" : "Filtering");
                        color: Theme.fg-2;
                        font-size: 11px;
                        font-weight: 500;
                        vertical-alignment: center;
                    }

                    if active-filter-key != "all": FilterChip {
                        x: 78px;
                        y: (parent.height - self.height) / 2;
                        label: active-filter-key;
                        active: true;
                        dismiss => { choose-filter("all"); }
                    }

                    browser-count := Text {
                        x: parent.width - self.width - 12px;
                        y: 0;
                        height: parent.height;
                        text: browser-count-label;
                        color: Theme.fg-2;
                        font-family: "JetBrains Mono";
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }

                // Card grid area
                Rectangle {
                    background: Theme.bg-2;
                    vertical-stretch: 1;

                    if model-cards.length == 0: VerticalLayout {
                        alignment: center;

                        Rectangle {
                            height: 36px;
                            width: 36px;
                            x: (parent.width - self.width) / 2;
                            border-color: Theme.line-3;
                            border-width: 1px;
                            border-radius: 8px;
                            background: transparent;

                            SvgIcon {
                                x: (parent.width - 16px) / 2;
                                y: (parent.height - 16px) / 2;
                                width: 16px;
                                height: 16px;
                                icon: @image-url("../assets/icons/box.svg");
                                tint: Theme.fg-3;
                            }
                        }

                        Text {
                            text: browser-message;
                            color: Theme.fg-1;
                            font-size: Theme.font-body;
                            horizontal-alignment: center;
                        }
                    }

                    if model-cards.length > 0 && view-mode-label != "List": grid-flick := Flickable {
                        x: 14px;
                        y: 14px;
                        width: parent.width - 28px;
                        height: parent.height - 28px;

                        property <length> target-card-w: view-mode-label == "Masonry"
                            ? (density-label == "S" ? 132px : density-label == "L" ? 184px : 154px)
                            : (density-label == "S" ? 144px : density-label == "L" ? 208px : 168px);
                        property <length> card-w: target-card-w;
                        property <length> gap: 12px;
                        property <bool> full-layout-motion: model-cards.length <= 96;
                        property <length> render-buffer: full-layout-motion ? 1400px : 520px;
                        property <int> cols: max(1, floor((self.width + gap) / (target-card-w + gap)));
                        property <int> rows: ceil(model-cards.length / max(1, cols));
                        property <length> card-h: view-mode-label == "Masonry" ? card-w + 94px : card-w + 62px;

                        viewport-height: rows * card-h + max(0, rows - 1) * gap;
                        animate card-w { duration: full-layout-motion ? 260ms : 120ms; easing: ease-in-out; }

                        for card[index] in model-cards: ModelCard {
                            property <length> target-y: floor(card.slot-index / cols) * (grid-flick.card-h + grid-flick.gap);
                            x: mod(card.slot-index, cols) * (card-w + gap);
                            y: target-y;
                            width: card-w;
                            height: grid-flick.card-h;
                            visible: target-y + grid-flick.card-h >= grid-flick.viewport-y - grid-flick.render-buffer
                                && target-y <= grid-flick.viewport-y + grid-flick.height + grid-flick.render-buffer;
                            layout-motion: grid-flick.full-layout-motion
                                || (target-y + grid-flick.card-h >= grid-flick.viewport-y - grid-flick.render-buffer
                                    && target-y <= grid-flick.viewport-y + grid-flick.height + grid-flick.render-buffer);
                            card: card;
                            card-index: card.slot-index;
                            selected: card.slot-index == selected-card-index;
                            clicked(idx) => { rename-editing = false; select-model(idx); }
                        }
                    }

                    if model-cards.length > 0 && view-mode-label == "List": list-flick := Flickable {
                        x: 14px;
                        y: 14px;
                        width: parent.width - 28px;
                        height: parent.height - 28px;

                        property <length> row-h: density-label == "S" ? 48px : density-label == "L" ? 68px : 58px;
                        property <length> gap: 8px;

                        viewport-height: model-cards.length * (row-h + gap);

                        for card[index] in model-cards: ModelListRow {
                            x: 0;
                            y: card.slot-index * (list-flick.row-h + list-flick.gap);
                            width: list-flick.width;
                            height: list-flick.row-h;
                            card: card;
                            card-index: card.slot-index;
                            selected: card.slot-index == selected-card-index;
                            clicked(idx) => { rename-editing = false; select-model(idx); }
                        }
                    }
                }

                // Status bar
                Rectangle {
                    height: Theme.statusbar-height;
                    background: Theme.bg-1;

                    Rectangle {
                        x: 0;
                        y: 0;
                        width: parent.width;
                        height: 1px;
                        background: Theme.line;
                    }

                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 8px;
                        alignment: center;

                        Rectangle {
                            width: 6px;
                            height: 6px;
                            border-radius: 3px;
                            background: Theme.success;
                        }

                        Text {
                            text: status-text;
                            color: Theme.fg-2;
                            font-family: "JetBrains Mono";
                            font-size: Theme.font-overline;
                        }

                        if scan-progress-percent >= 0: Rectangle {
                            width: progress-text.width + 14px;
                            height: 18px;
                            background: Theme.bg-3;
                            border-color: Theme.line-2;
                            border-width: 1px;
                            border-radius: 9px;

                            progress-text := Text {
                                x: 7px;
                                y: (parent.height - self.height) / 2;
                                text: scan-progress-percent + "%";
                                color: Theme.accent;
                                font-family: "JetBrains Mono";
                                font-size: Theme.font-overline;
                                font-weight: 600;
                            }
                        }

                        Rectangle { horizontal-stretch: 1; }

                        Text {
                            text: browser-count-label;
                            color: Theme.fg-3;
                            font-family: "JetBrains Mono";
                            font-size: Theme.font-overline;
                        }

                        Text {
                            text: app-version;
                            color: Theme.fg-3;
                            font-family: "JetBrains Mono";
                            font-size: Theme.font-overline;
                        }
                    }
                }
            }

            if right-detail-open: Rectangle {
                width: 6px;
                background: right-resize-touch.has-hover || right-detail-resizing ? Theme.accent-dim : Theme.bg-2;

                Rectangle {
                    x: 3px;
                    y: 0;
                    width: 1px;
                    height: parent.height;
                    background: right-resize-touch.has-hover || right-detail-resizing ? Theme.accent : Theme.line;
                }

                right-resize-touch := TouchArea {
                    mouse-cursor: ew-resize;
                    pointer-event(event) => {
                        if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                            right-detail-resizing = true;
                            resize-origin-x = right-resize-touch.absolute-position.x - root.absolute-position.x + right-resize-touch.mouse-x;
                            resize-start-width = right-detail-width;
                        } else if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                            right-detail-resizing = false;
                        } else if (event.kind == PointerEventKind.cancel) {
                            right-detail-resizing = false;
                        } else if (event.kind == PointerEventKind.move && right-detail-resizing) {
                            right-detail-width = min(right-detail-max-width, max(right-detail-min-width, resize-start-width - ((right-resize-touch.absolute-position.x - root.absolute-position.x + right-resize-touch.mouse-x) - resize-origin-x)));
                        }
                    }
                }
            }

            // ─── Detail panel ───
            Rectangle {
                width: visible-right-detail-width;
                background: Theme.bg-1;
                clip: true;
                animate width { duration: right-detail-resizing ? 0ms : 180ms; easing: ease-in-out; }

                Rectangle {
                    x: 0;
                    y: 0;
                    width: 1px;
                    height: parent.height;
                    background: Theme.line;
                }

                if right-detail-open && !has-selection: VerticalLayout {
                    alignment: center;
                    spacing: 8px;

                    Rectangle {
                        width: 36px;
                        height: 36px;
                        x: (parent.width - self.width) / 2;
                        border-color: Theme.line-3;
                        border-width: 1px;
                        border-radius: 8px;
                        background: transparent;

                            SvgIcon {
                                x: (parent.width - 16px) / 2;
                                y: (parent.height - 16px) / 2;
                                width: 16px;
                                height: 16px;
                                icon: @image-url("../assets/icons/box.svg");
                                tint: Theme.fg-3;
                            }
                    }

                    Text {
                        text: settings-language-key == "ko" ? "모델 선택" : settings-language-key == "ja" ? "モデルを選択" : "Select a model";
                        color: Theme.fg-1;
                        font-size: Theme.font-body;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: settings-language-key == "ko" ? "썸네일을 클릭하면 상세 정보를 봅니다" : settings-language-key == "ja" ? "サムネイルをクリックして詳細を表示" : "Click a thumbnail to view details";
                        color: Theme.fg-2;
                        font-size: Theme.font-meta;
                        horizontal-alignment: center;
                    }
                }

                if right-detail-open && has-selection: VerticalLayout {
                    // Preview area
                    Rectangle {
                        height: 280px;
                        background: Theme.bg-0;

                        Rectangle {
                            x: 0;
                            y: parent.height - 1px;
                            width: parent.width;
                            height: 1px;
                            background: Theme.line;
                        }

                        CachedThumb {
                            x: 0;
                            y: 0;
                            width: parent.width;
                            height: parent.height;
                            thumb-key: selected-thumb-key;
                            cached-image: selected-thumb-image;
                            thumb-ready: selected-thumb-ready;
                        }

                        preview-drag := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            pointer-event(event) => {
                                if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                                    preview-dragging = true;
                                    preview-last-x = preview-drag.mouse-x;
                                    preview-last-y = preview-drag.mouse-y;
                                } else if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                                    preview-dragging = false;
                                } else if (event.kind == PointerEventKind.cancel) {
                                    preview-dragging = false;
                                } else if (event.kind == PointerEventKind.move && preview-dragging) {
                                    preview-orbit((preview-drag.mouse-x - preview-last-x) / 1px, (preview-drag.mouse-y - preview-last-y) / 1px);
                                    preview-last-x = preview-drag.mouse-x;
                                    preview-last-y = preview-drag.mouse-y;
                                }
                            }
                            double-clicked => {
                                preview-orbit-reset();
                            }
                        }

                        if detail-has-plates: PlateDropdown {
                            x: 8px;
                            y: 8px;
                            z: 20;
                            current-label: detail-plate-selected-label;
                            open: preview-plate-menu-open;
                            tabs: detail-plate-tabs;
                            toggled => {
                                preview-plate-menu-open = !preview-plate-menu-open;
                            }
                            activated(idx) => {
                                choose-preview-plate(idx);
                                preview-plate-menu-open = false;
                            }
                            dismissed => {
                                preview-plate-menu-open = false;
                            }
                        }

                        HorizontalLayout {
                            x: parent.width - 60px;
                            y: 8px;
                            z: 20;
                            spacing: 4px;

                            Rectangle {
                                width: 24px; height: 24px;
                                background: reset-preview.has-hover ? #000000cc : #00000080;
                                border-color: Theme.line;
                                border-width: 1px;
                                border-radius: 4px;
                                SvgIcon { x: (parent.width - 13px) / 2; y: (parent.height - 13px) / 2; width: 13px; height: 13px; icon: @image-url("../assets/icons/rotate.svg"); tint: Theme.fg-1; }
                                reset-preview := TouchArea {
                                    clicked => {
                                        preview-orbit-reset();
                                    }
                                }
                            }
                            Rectangle {
                                width: 24px; height: 24px;
                                background: fullscreen-preview.has-hover ? #000000cc : #00000080;
                                border-color: Theme.line;
                                border-width: 1px;
                                border-radius: 4px;
                                SvgIcon { x: (parent.width - 13px) / 2; y: (parent.height - 13px) / 2; width: 13px; height: 13px; icon: @image-url("../assets/icons/fullscreen.svg"); tint: Theme.fg-1; }
                                fullscreen-preview := TouchArea {
                                    clicked => {
                                        preview-fullscreen-open = true;
                                    }
                                }
                            }
                        }

                        // Axis labels
                        HorizontalLayout {
                            x: 8px;
                            y: parent.height - 24px;
                            spacing: 4px;

                            Rectangle {
                                width: 18px; height: 16px;
                                background: #00000080;
                                border-radius: 2px;
                                Text { x: 5px; y: 2px; text: "X"; color: #c95040; font-family: "JetBrains Mono"; font-size: 10px; }
                            }
                            Rectangle {
                                width: 18px; height: 16px;
                                background: #00000080;
                                border-radius: 2px;
                                Text { x: 5px; y: 2px; text: "Y"; color: #5fb87a; font-family: "JetBrains Mono"; font-size: 10px; }
                            }
                            Rectangle {
                                width: 18px; height: 16px;
                                background: #00000080;
                                border-radius: 2px;
                                Text { x: 5px; y: 2px; text: "Z"; color: #5fb8d4; font-family: "JetBrains Mono"; font-size: 10px; }
                            }
                        }

                        Text {
                            x: parent.width - self.width - 8px;
                            y: parent.height - 20px;
                            text: "orbit · drag to rotate";
                            color: Theme.fg-3;
                            font-family: "JetBrains Mono";
                            font-size: 10px;
                        }
                    }

                    // Scrollable detail sections
                    ScrollView {
                        VerticalLayout {
                            padding: 16px;
                            padding-top: 14px;
                            padding-bottom: 28px;
                            spacing: 2px;

                            // Title + path
                            if !rename-editing: Text {
                                text: detail-name;
                                color: Theme.fg-0;
                                font-size: Theme.font-heading;
                                font-weight: 600;
                                wrap: word-wrap;
                            }

                            if rename-editing: LineEdit {
                                height: 32px;
                                text: rename-draft;
                                font-size: Theme.font-heading;
                                accepted(text) => {
                                    if rename-model(text) {
                                        rename-editing = false;
                                        shortcut-scope.focus();
                                    }
                                }
                                init => {
                                    self.focus();
                                    self.select-all();
                                }
                            }

                            Text {
                                text: detail-path;
                                color: Theme.fg-2;
                                font-family: "JetBrains Mono";
                                font-size: Theme.font-overline;
                                wrap: word-wrap;
                            }

                            // Actions
                            HorizontalLayout {
                                spacing: 6px;
                                height: slicer-menu-open ? min(340px, 40px * settings-slicer-candidates.length + 108px) : 48px;
                                alignment: start;

                                Rectangle {
                                    width: 224px;
                                    height: 28px;
                                    z: 100;

                                    Rectangle {
                                        x: 0;
                                        y: 0;
                                        width: parent.width - 27px;
                                        height: 28px;
                                        background: ta-slicer.has-hover ? #6fc8e0 : Theme.accent;
                                        border-radius: Theme.radius-btn;

                                        slicer-text := Text {
                                            x: 26px;
                                            y: (parent.height - self.height) / 2;
                                            width: parent.width - self.x - 10px;
                                            text: settings-slicer-label == "System default STL opener" ? "Open in Slicer" : "Open in " + settings-slicer-label;
                                            color: #0e2a32;
                                            font-size: Theme.font-body;
                                            font-weight: 500;
                                            overflow: elide;
                                        }

                                        if settings-slicer-icon-ready: Image {
                                            x: 8px;
                                            y: (parent.height - 16px) / 2;
                                            width: 16px;
                                            height: 16px;
                                            source: settings-slicer-icon-image;
                                            image-fit: contain;
                                        }

                                        if !settings-slicer-icon-ready: SvgIcon {
                                            x: 9px;
                                            y: (parent.height - 13px) / 2;
                                            width: 13px;
                                            height: 13px;
                                            icon: @image-url("../assets/icons/slicer.svg");
                                            tint: #0e2a32;
                                        }

                                        ta-slicer := TouchArea { clicked => { open-in-slicer(); } }
                                    }

                                    Rectangle {
                                        x: parent.width - 28px;
                                        y: 0;
                                        width: 28px;
                                        height: 28px;
                                        background: ta-slicer-caret.has-hover ? #6fc8e0 : Theme.accent;
                                        border-radius: Theme.radius-btn;

                                        Rectangle {
                                            x: 0;
                                            y: 5px;
                                            width: 1px;
                                            height: parent.height - 10px;
                                            background: #0e2a3233;
                                        }

                                        SvgIcon {
                                            x: (parent.width - 10px) / 2;
                                            y: (parent.height - 10px) / 2;
                                            width: 10px;
                                            height: 10px;
                                            icon: @image-url("../assets/icons/chevron-right.svg");
                                            tint: #0e2a32;
                                            transform-origin: { x: 5px, y: 5px };
                                            transform-rotation: slicer-menu-open ? -90deg : 90deg;
                                        }

                                        ta-slicer-caret := TouchArea {
                                            clicked => { slicer-menu-open = !slicer-menu-open; }
                                        }
                                    }

                                    if slicer-menu-open: TouchArea {
                                        x: -3000px;
                                        y: -3000px;
                                        width: 7000px;
                                        height: 7000px;
                                        z: 150;
                                        clicked => { slicer-menu-open = false; }
                                    }

                                    if slicer-menu-open: Rectangle {
                                        x: 0;
                                        y: parent.height + 5px;
                                        width: 280px;
                                        height: 40px * settings-slicer-candidates.length + 64px;
                                        z: 200;
                                        background: #202329;
                                        border-color: Theme.line-3;
                                        border-width: 1px;
                                        border-radius: 8px;

                                        VerticalLayout {
                                            padding: 4px;
                                            spacing: 1px;

                                            Text {
                                                height: 24px;
                                                text: "Open with…";
                                                color: Theme.fg-3;
                                                font-size: Theme.font-overline;
                                                font-weight: 600;
                                                letter-spacing: 0.6px;
                                            }

                                            for candidate in settings-slicer-candidates: SlicerMenuItem {
                                                label: candidate.label;
                                                detail: candidate.detail;
                                                icon-image: candidate.icon-image;
                                                icon-ready: candidate.icon-ready;
                                                selected: candidate.selected;
                                                activated => {
                                                    choose-settings-slicer(candidate.path);
                                                    slicer-menu-open = false;
                                                }
                                            }

                                            Rectangle {
                                                height: 1px;
                                                background: Theme.line;
                                            }

                                            ContextMenuItem {
                                                label: "Choose another slicer…";
                                                hint: "";
                                                icon: @image-url("../assets/icons/plus.svg");
                                                activated => {
                                                    slicer-menu-open = false;
                                                    choose-slicer();
                                                }
                                            }
                                        }
                                    }
                                }

                                Rectangle {
                                    width: 28px; height: 28px;
                                    background: ta-printed.has-hover ? Theme.bg-3 : Theme.bg-1;
                                    border-color: Theme.line;
                                    border-width: 1px;
                                    border-radius: Theme.radius-btn;

                                    SvgIcon {
                                        x: (parent.width - 14px) / 2;
                                        y: (parent.height - 14px) / 2;
                                        width: 14px;
                                        height: 14px;
                                        icon: @image-url("../assets/icons/print.svg");
                                        tint: Theme.fg-2;
                                    }

                                    ta-printed := TouchArea {}
                                }

                                Rectangle {
                                    width: 28px; height: 28px;
                                    background: ta-fav.has-hover ? Theme.bg-3 : Theme.bg-1;
                                    border-color: Theme.line;
                                    border-width: 1px;
                                    border-radius: Theme.radius-btn;

                                    SvgIcon {
                                        x: (parent.width - 14px) / 2;
                                        y: (parent.height - 14px) / 2;
                                        width: 14px;
                                        height: 14px;
                                        icon: @image-url("../assets/icons/star.svg");
                                        tint: detail-fav ? #d4a84f : Theme.fg-2;
                                    }

                                    ta-fav := TouchArea { clicked => { toggle-favorite(); } }
                                }
                            }

                            // Geometry section
                            SectionHeader { label: "GEOMETRY"; }
                            DetailKV { label: "Format"; value: detail-format; }
                            DetailKV { label: "Triangles"; value: detail-tris; }
                            DetailKV { label: "Dimensions"; value: detail-dims; }
                            DetailKV { label: "Volume est."; value: detail-volume; }
                            DetailKV { label: "File size"; value: detail-filesize; }

                            // Mesh health
                            Rectangle {
                                height: 24px;

                                Text {
                                    x: 0px;
                                    y: (parent.height - self.height) / 2;
                                    text: "MESH HEALTH";
                                    color: Theme.fg-2;
                                    font-size: Theme.font-overline;
                                    font-weight: 600;
                                    letter-spacing: 0.8px;
                                }

                                Rectangle {
                                    x: parent.width - self.width;
                                    y: (parent.height - self.height) / 2;
                                    width: health-score.width + 12px;
                                    height: 18px;
                                    background: Theme.success;
                                    border-radius: 9px;

                                    health-score := Text {
                                        x: 6px;
                                        y: (parent.height - self.height) / 2;
                                        text: detail-health-score + "/100";
                                        color: #0e2618;
                                        font-family: "JetBrains Mono";
                                        font-size: 10px;
                                        font-weight: 600;
                                    }
                                }
                            }

                            Rectangle {
                                height: 44px;

                                Text {
                                    x: 0px;
                                    y: 0px;
                                    width: (parent.width - 10px) / 2;
                                    text: detail-manifold ? "✓ Manifold" : "✗ Manifold";
                                    color: detail-manifold ? Theme.success : Theme.error;
                                    font-size: 12px;
                                }

                                Text {
                                    x: (parent.width + 10px) / 2;
                                    y: 0px;
                                    width: (parent.width - 10px) / 2;
                                    text: detail-watertight ? "✓ Watertight" : "✗ Watertight";
                                    color: detail-watertight ? Theme.success : Theme.warn;
                                    font-size: 12px;
                                }

                                Text {
                                    x: 0px;
                                    y: 22px;
                                    width: (parent.width - 10px) / 2;
                                    text: detail-normals ? "✓ Normals" : "✗ Normals";
                                    color: detail-normals ? Theme.success : Theme.warn;
                                    font-size: 12px;
                                }
                            }

                            // Print estimate
                            if detail-estimate-time != "": Rectangle {
                                height: estimate-printer-menu-open && detail-estimate-has-printer-choices ? 34px + min(178px, detail-estimate-printers.length * 36px) : 30px;

                                Text {
                                    x: 0px;
                                    y: 8px;
                                    text: "PRINT ESTIMATE";
                                    color: Theme.fg-2;
                                    font-size: Theme.font-overline;
                                    font-weight: 600;
                                    letter-spacing: 0.8px;
                                }

                                if detail-estimate-has-printer-choices: EstimatePrinterDropdown {
                                    x: parent.width - self.width;
                                    y: 2px;
                                    z: 30;
                                    current-label: detail-estimate-printer-label;
                                    open: estimate-printer-menu-open;
                                    printers: detail-estimate-printers;
                                    toggled => {
                                        estimate-printer-menu-open = !estimate-printer-menu-open;
                                    }
                                    activated(key) => {
                                        choose-estimate-printer(key);
                                        estimate-printer-menu-open = false;
                                    }
                                    dismissed => {
                                        estimate-printer-menu-open = false;
                                    }
                                }
                            }
                            if detail-estimate-time != "": HorizontalLayout {
                                spacing: 8px;
                                height: 60px;

                                Rectangle {
                                    horizontal-stretch: 1;
                                    background: Theme.bg-3;
                                    border-color: Theme.line;
                                    border-width: 1px;
                                    border-radius: 6px;

                                    VerticalLayout {
                                        padding: 8px;
                                        Text { text: "TIME"; color: Theme.fg-2; font-size: Theme.font-overline; }
                                        Text { text: detail-estimate-time; color: Theme.fg-0; font-size: 16px; font-weight: 600; }
                                    }
                                }
                                Rectangle {
                                    horizontal-stretch: 1;
                                    background: Theme.bg-3;
                                    border-color: Theme.line;
                                    border-width: 1px;
                                    border-radius: 6px;

                                    VerticalLayout {
                                        padding: 8px;
                                        Text { text: "FILAMENT"; color: Theme.fg-2; font-size: Theme.font-overline; }
                                        Text { text: detail-estimate-grams; color: Theme.fg-0; font-size: 16px; font-weight: 600; }
                                    }
                                }
                                Rectangle {
                                    horizontal-stretch: 1;
                                    background: Theme.bg-3;
                                    border-color: Theme.line;
                                    border-width: 1px;
                                    border-radius: 6px;

                                    VerticalLayout {
                                        padding: 8px;
                                        Text { text: "LAYERS"; color: Theme.fg-2; font-size: Theme.font-overline; }
                                        Text { text: detail-estimate-layers; color: Theme.fg-0; font-size: 16px; font-weight: 600; }
                                    }
                                }
                            }
                            if detail-estimate-time != "": Rectangle {
                                height: 28px;
                                background: detail-bed-fit ? Theme.accent-dim : #d4a84f24;
                                border-color: detail-bed-fit ? Theme.accent-line : #d4a84f59;
                                border-width: 1px;
                                border-radius: Theme.radius-btn;

                                Text {
                                    x: 10px;
                                    y: (parent.height - self.height) / 2;
                                    text: detail-bed-fit ? "✓ Fits build plate" : "⚠ Exceeds build plate";
                                    color: detail-bed-fit ? Theme.success : Theme.warn;
                                    font-size: 11.5px;
                                    font-weight: 500;
                                }

                                Text {
                                    x: parent.width - self.width - 10px;
                                    y: (parent.height - self.height) / 2;
                                    text: detail-estimate-printer-detail;
                                    color: Theme.fg-3;
                                    font-family: "JetBrains Mono";
                                    font-size: 9.5px;
                                }
                            }

                            SectionHeader { label: "TAGS"; }
                            Rectangle {
                                height: detail-tag-chips.length == 0 ? 28px : detail-tag-chips.length * 30px;

                                if detail-tag-chips.length == 0: Text {
                                    x: 0;
                                    y: 5px;
                                    text: "No tags";
                                    color: Theme.fg-2;
                                    font-size: 11.5px;
                                }

                                VerticalLayout {
                                    spacing: 6px;

                                    for tag[index] in detail-tag-chips: Rectangle {
                                        height: 24px;
                                        background: Theme.bg-3;
                                        border-color: Theme.line;
                                        border-width: 1px;
                                        border-radius: 12px;

                                        Text {
                                            x: 10px;
                                            y: (parent.height - self.height) / 2;
                                            width: parent.width - 34px;
                                            text: tag.label;
                                            color: Theme.fg-1;
                                            font-size: 11.5px;
                                            font-family: "JetBrains Mono";
                                            overflow: elide;
                                        }

                                        Rectangle {
                                            x: parent.width - 24px;
                                            y: 2px;
                                            width: 20px;
                                            height: 20px;
                                            background: remove-tag-touch.has-hover ? Theme.bg-4 : Theme.bg-3;
                                            border-radius: 10px;

                                            Text {
                                                x: (parent.width - self.width) / 2;
                                                y: (parent.height - self.height) / 2;
                                                text: "×";
                                                color: Theme.fg-2;
                                                font-size: 12px;
                                            }

                                            remove-tag-touch := TouchArea { clicked => { remove-tag(index); } }
                                        }
                                    }
                                }
                            }

                            Rectangle {
                                height: 30px;

                                add-tag-edit := LineEdit {
                                    x: 0;
                                    y: 0;
                                    width: parent.width - 58px;
                                    height: 28px;
                                    placeholder-text: "Add tag";
                                    font-size: 12px;
                                    accepted(text) => {
                                        add-tags(text);
                                        self.text = "";
                                    }
                                }

                                Rectangle {
                                    x: parent.width - 50px;
                                    y: 1px;
                                    width: 50px;
                                    height: 26px;
                                    background: add-tag-touch.has-hover ? Theme.accent : Theme.bg-4;
                                    border-color: Theme.line;
                                    border-width: 1px;
                                    border-radius: Theme.radius-btn;

                                    Text {
                                        x: (parent.width - self.width) / 2;
                                        y: (parent.height - self.height) / 2;
                                        text: "Add";
                                        color: Theme.fg-0;
                                        font-size: 12px;
                                        font-weight: 600;
                                    }

                                    add-tag-touch := TouchArea {
                                        clicked => {
                                            add-tags(add-tag-edit.text);
                                            add-tag-edit.text = "";
                                        }
                                    }
                                }
                            }

                            tags-edit := LineEdit {
                                height: 30px;
                                text: detail-tags-input;
                                placeholder-text: "Bulk edit: rackmount, printer, jig";
                                font-size: 12px;
                                accepted(text) => { save-metadata(text, author-edit.text, notes-edit.text); }
                            }

                            SectionHeader { label: "PRINTS"; }
                            Rectangle {
                                height: 30px;

                                Text {
                                    x: 0;
                                    y: (parent.height - self.height) / 2;
                                    text: "Printed " + detail-printed-count + " times";
                                    color: Theme.fg-1;
                                    font-size: 12px;
                                }

                                Rectangle {
                                    x: parent.width - 64px;
                                    y: 3px;
                                    width: 28px;
                                    height: 24px;
                                    background: minus-print.has-hover ? Theme.bg-4 : Theme.bg-3;
                                    border-color: Theme.line;
                                    border-width: 1px;
                                    border-radius: Theme.radius-btn;

                                    Text {
                                        x: (parent.width - self.width) / 2;
                                        y: (parent.height - self.height) / 2;
                                        text: "−";
                                        color: Theme.fg-1;
                                        font-size: 14px;
                                    }

                                    minus-print := TouchArea { clicked => { adjust-printed-count(-1); } }
                                }

                                Rectangle {
                                    x: parent.width - 30px;
                                    y: 3px;
                                    width: 28px;
                                    height: 24px;
                                    background: plus-print.has-hover ? Theme.bg-4 : Theme.bg-3;
                                    border-color: Theme.line;
                                    border-width: 1px;
                                    border-radius: Theme.radius-btn;

                                    Text {
                                        x: (parent.width - self.width) / 2;
                                        y: (parent.height - self.height) / 2;
                                        text: "+";
                                        color: Theme.fg-1;
                                        font-size: 14px;
                                    }

                                    plus-print := TouchArea { clicked => { adjust-printed-count(1); } }
                                }
                            }

                            if detail-printed-count > 0: Rectangle {
                                height: 30px;

                                Text {
                                    x: 0;
                                    y: (parent.height - self.height) / 2;
                                    width: 82px;
                                    text: "history";
                                    color: Theme.fg-2;
                                    font-family: "JetBrains Mono";
                                    font-size: 10.5px;
                                }

                                Text {
                                    x: 92px;
                                    y: (parent.height - self.height) / 2;
                                    text: detail-print-history.length + " records";
                                    color: Theme.fg-0;
                                    font-size: 11.5px;
                                }
                            }

                            Rectangle {
                                height: detail-print-history.length == 0 ? 28px : detail-print-history.length * 62px;

                                if detail-print-history.length == 0: Text {
                                    x: 0;
                                    y: 5px;
                                    text: "No print records";
                                    color: Theme.fg-2;
                                    font-size: 11.5px;
                                }

                                VerticalLayout {
                                    spacing: 6px;

                                    for record[index] in detail-print-history: Rectangle {
                                        height: 56px;
                                        background: Theme.bg-2;
                                        border-color: Theme.line;
                                        border-width: 1px;
                                        border-radius: 6px;

                                        Rectangle {
                                            x: 10px;
                                            y: 18px;
                                            width: 7px;
                                            height: 7px;
                                            border-radius: 4px;
                                            background: record.success ? Theme.success : Theme.warn;
                                        }

                                        Text {
                                            x: 26px;
                                            y: 7px;
                                            width: parent.width - 62px;
                                            text: record.date + " · " + (record.material == "" ? "material unknown" : record.material);
                                            color: Theme.fg-0;
                                            font-size: 11.5px;
                                            font-family: "JetBrains Mono";
                                            overflow: elide;
                                        }

                                        Text {
                                            x: 26px;
                                            y: 24px;
                                            width: parent.width - 62px;
                                            text: (record.printer == "" ? "printer unknown" : record.printer) + " · "
                                                + (record.profile == "" ? "profile unknown" : record.profile) + " · "
                                                + (record.nozzle == "" ? "nozzle ?" : record.nozzle) + " · "
                                                + (record.layer-height == "" ? "layer ?" : record.layer-height)
                                                + (record.duration == "" ? "" : " · " + record.duration);
                                            color: Theme.fg-1;
                                            font-size: 10.5px;
                                            overflow: elide;
                                        }

                                        Text {
                                            x: 26px;
                                            y: 39px;
                                            width: parent.width - 62px;
                                            text: record.notes == "" ? "No notes" : record.notes;
                                            color: Theme.fg-2;
                                            font-size: 10.5px;
                                            overflow: elide;
                                        }

                                        Rectangle {
                                            x: parent.width - 28px;
                                            y: 9px;
                                            width: 22px;
                                            height: 24px;
                                            background: remove-print.has-hover ? Theme.bg-4 : Theme.bg-2;
                                            border-radius: Theme.radius-btn;

                                            Text {
                                                x: (parent.width - self.width) / 2;
                                                y: (parent.height - self.height) / 2;
                                                text: "×";
                                                color: Theme.fg-2;
                                                font-size: 14px;
                                            }

                                            remove-print := TouchArea { clicked => { remove-print-record(index); } }
                                        }
                                    }
                                }
                            }

                            Rectangle {
                                height: 94px;

                                material-edit := LineEdit {
                                    x: 0;
                                    y: 0;
                                    width: 82px;
                                    height: 28px;
                                    placeholder-text: "PLA";
                                    font-size: 12px;
                                }

                                printer-edit := LineEdit {
                                    x: 90px;
                                    y: 0;
                                    width: parent.width - 150px;
                                    height: 28px;
                                    placeholder-text: "Printer";
                                    font-size: 12px;
                                }

                                Rectangle {
                                    x: parent.width - 60px;
                                    y: 1px;
                                    width: 60px;
                                    height: 26px;
                                    background: add-print.has-hover ? Theme.accent : Theme.bg-4;
                                    border-color: Theme.line;
                                    border-width: 1px;
                                    border-radius: Theme.radius-btn;

                                    Text {
                                        x: (parent.width - self.width) / 2;
                                        y: (parent.height - self.height) / 2;
                                        text: "Add";
                                        color: Theme.fg-0;
                                        font-size: 12px;
                                        font-weight: 600;
                                    }

                                    add-print := TouchArea {
                                        clicked => {
                                            add-print-record(material-edit.text, printer-edit.text, profile-edit.text, nozzle-edit.text, layer-edit.text, duration-edit.text, print-note-edit.text);
                                            material-edit.text = "";
                                            printer-edit.text = "";
                                            profile-edit.text = "";
                                            nozzle-edit.text = "";
                                            layer-edit.text = "";
                                            duration-edit.text = "";
                                            print-note-edit.text = "";
                                        }
                                    }
                                }

                                profile-edit := LineEdit {
                                    x: 0;
                                    y: 32px;
                                    width: parent.width - 186px;
                                    height: 28px;
                                    placeholder-text: "Profile";
                                    font-size: 12px;
                                }

                                nozzle-edit := LineEdit {
                                    x: parent.width - 178px;
                                    y: 32px;
                                    width: 54px;
                                    height: 28px;
                                    placeholder-text: "0.4";
                                    font-size: 12px;
                                }

                                layer-edit := LineEdit {
                                    x: parent.width - 116px;
                                    y: 32px;
                                    width: 54px;
                                    height: 28px;
                                    placeholder-text: "0.2";
                                    font-size: 12px;
                                }

                                duration-edit := LineEdit {
                                    x: parent.width - 54px;
                                    y: 32px;
                                    width: 54px;
                                    height: 28px;
                                    placeholder-text: "2h";
                                    font-size: 12px;
                                }

                                print-note-edit := LineEdit {
                                    x: 0;
                                    y: 64px;
                                    width: parent.width;
                                    height: 28px;
                                    placeholder-text: "Result notes";
                                    font-size: 12px;
                                }
                            }

                            SectionHeader { label: "NOTES"; }
                            notes-edit := TextEdit {
                                height: 72px;
                                text: detail-notes == "Add notes..." ? "" : detail-notes;
                                placeholder-text: "Add notes...";
                                font-size: 12px;
                                wrap: word-wrap;
                            }

                            SectionHeader { label: "AUTHOR"; }
                            author-edit := LineEdit {
                                height: 30px;
                                text: detail-author;
                                placeholder-text: "Author or source";
                                font-size: 12px;
                                accepted(text) => { save-metadata(tags-edit.text, text, notes-edit.text); }
                            }

                            Rectangle {
                                height: 30px;

                                Rectangle {
                                    x: parent.width - 66px;
                                    y: 2px;
                                    width: 66px;
                                    height: 26px;
                                    background: save-meta.has-hover ? Theme.accent : Theme.bg-4;
                                    border-color: Theme.line;
                                    border-width: 1px;
                                    border-radius: Theme.radius-btn;

                                    Text {
                                        x: (parent.width - self.width) / 2;
                                        y: (parent.height - self.height) / 2;
                                        text: "Save";
                                        color: Theme.fg-0;
                                        font-size: 12px;
                                        font-weight: 600;
                                    }

                                    save-meta := TouchArea {
                                        clicked => {
                                            save-metadata(tags-edit.text, author-edit.text, notes-edit.text);
                                        }
                                    }
                                }
                            }

                            // File section
                            SectionHeader { label: "FILE"; }
                            DetailKV { label: "Hash (b3)"; value: detail-hash; }
                            DetailKV { label: "Modified"; value: detail-modified; }
                            DetailKV { label: "Added"; value: detail-added; }
                            DetailKV { label: "Author"; value: detail-author; }
                        }
                    }
                }
            }
        }
    }

    preview-stage := Rectangle {
        z: 260;
        x: preview-fullscreen-open ? visible-left-sidebar-width + 16px : parent.width - visible-right-detail-width;
        y: preview-fullscreen-open ? Theme.titlebar-height + 16px : Theme.titlebar-height;
        width: preview-fullscreen-open ? parent.width - visible-left-sidebar-width - visible-right-detail-width - 32px : visible-right-detail-width;
        height: preview-fullscreen-open ? parent.height - Theme.titlebar-height - 32px : 280px;
        opacity: preview-fullscreen-open ? 1 : 0;
        background: #05080bf0;
        border-color: Theme.line-3;
        border-width: preview-fullscreen-open ? 1px : 0px;
        border-radius: preview-fullscreen-open ? 14px : 0px;
        animate x { duration: 220ms; easing: ease-in-out; }
        animate y { duration: 220ms; easing: ease-in-out; }
        animate width { duration: 220ms; easing: ease-in-out; }
        animate height { duration: 220ms; easing: ease-in-out; }
        animate opacity { duration: 160ms; easing: ease-in-out; }
        animate border-radius { duration: 220ms; easing: ease-in-out; }

        CachedThumb {
            x: preview-fullscreen-open ? 28px : 0px;
            y: preview-fullscreen-open ? 44px : 0px;
            width: preview-fullscreen-open ? parent.width - 56px : parent.width;
            height: preview-fullscreen-open ? parent.height - 88px : parent.height;
            thumb-key: selected-thumb-key;
            cached-image: selected-thumb-image;
            thumb-ready: selected-thumb-ready;
            animate x { duration: 220ms; easing: ease-in-out; }
            animate y { duration: 220ms; easing: ease-in-out; }
            animate width { duration: 220ms; easing: ease-in-out; }
            animate height { duration: 220ms; easing: ease-in-out; }
        }

        if preview-fullscreen-open: fs-preview-drag := TouchArea {
            x: 28px;
            y: 44px;
            width: parent.width - 56px;
            height: parent.height - 88px;
            pointer-event(event) => {
                if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                    preview-dragging = true;
                    preview-last-x = fs-preview-drag.mouse-x;
                    preview-last-y = fs-preview-drag.mouse-y;
                } else if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                    preview-dragging = false;
                } else if (event.kind == PointerEventKind.cancel) {
                    preview-dragging = false;
                } else if (event.kind == PointerEventKind.move && preview-dragging) {
                    preview-orbit((fs-preview-drag.mouse-x - preview-last-x) / 1px, (fs-preview-drag.mouse-y - preview-last-y) / 1px);
                    preview-last-x = fs-preview-drag.mouse-x;
                    preview-last-y = fs-preview-drag.mouse-y;
                }
            }
            double-clicked => {
                preview-orbit-reset();
            }
        }

        if preview-fullscreen-open && detail-has-plates: PlateDropdown {
            x: 42px;
            y: 58px;
            z: 20;
            current-label: detail-plate-selected-label;
            open: preview-plate-menu-open;
            tabs: detail-plate-tabs;
            toggled => {
                preview-plate-menu-open = !preview-plate-menu-open;
            }
            activated(idx) => {
                choose-preview-plate(idx);
                preview-plate-menu-open = false;
            }
            dismissed => {
                preview-plate-menu-open = false;
            }
        }

        if preview-fullscreen-open: Text {
            x: 28px;
            y: 18px;
            text: detail-name;
            color: Theme.fg-0;
            font-size: 14px;
            font-weight: 700;
        }

        if preview-fullscreen-open: Text {
            x: parent.width - self.width - 68px;
            y: parent.height - 30px;
            text: "drag to orbit · double-click to reset";
            color: Theme.fg-3;
            font-family: "JetBrains Mono";
            font-size: 11px;
        }

        if preview-fullscreen-open: Rectangle {
            x: parent.width - 42px;
            y: 14px;
            width: 28px;
            height: 28px;
            background: close-fullscreen-preview.has-hover ? #ffffff24 : #00000080;
            border-color: Theme.line;
            border-width: 1px;
            border-radius: 6px;

            Text {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2 - 1px;
                text: "×";
                color: Theme.fg-1;
                font-size: 18px;
            }

            close-fullscreen-preview := TouchArea {
                clicked => {
                    preview-fullscreen-open = false;
                    preview-dragging = false;
                }
            }
        }
    }

    if sidebar-context-open: TouchArea {
        x: 0;
        y: 0;
        width: parent.width;
        height: Theme.titlebar-height;
        clicked => { sidebar-context-open = false; }
    }

    if sidebar-context-open: TouchArea {
        x: visible-left-sidebar-width;
        y: Theme.titlebar-height;
        width: parent.width - visible-left-sidebar-width;
        height: parent.height - Theme.titlebar-height;
        clicked => { sidebar-context-open = false; }
        pointer-event(event) => {
            if (event.kind == PointerEventKind.down) {
                sidebar-context-open = false;
            }
        }
    }

    if sidebar-context-open: SidebarContextMenu {
        x: sidebar-context-x + self.width > parent.width - 8px ? parent.width - self.width - 8px : sidebar-context-x;
        y: sidebar-context-y + self.height > parent.height - 8px ? parent.height - self.height - 8px : sidebar-context-y;
        target-label: sidebar-context-label;
        target-is-folder: sidebar-context-is-folder;
        action(action) => {
            shortcut-scope.focus();
            sidebar-context-open = false;
            sidebar-context-action(action, sidebar-context-key, sidebar-context-label);
        }
    }

    if left-sidebar-resizing || right-detail-resizing: TouchArea {
        z: 500;
        x: 0;
        y: Theme.titlebar-height;
        width: parent.width;
        height: parent.height - Theme.titlebar-height;
        mouse-cursor: ew-resize;

        pointer-event(event) => {
            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                left-sidebar-resizing = false;
                right-detail-resizing = false;
            } else if (event.kind == PointerEventKind.cancel) {
                left-sidebar-resizing = false;
                right-detail-resizing = false;
            } else if (event.kind == PointerEventKind.move && left-sidebar-resizing) {
                left-sidebar-width = min(left-sidebar-max-width, max(left-sidebar-min-width, resize-start-width + (self.mouse-x - resize-origin-x)));
            } else if (event.kind == PointerEventKind.move && right-detail-resizing) {
                right-detail-width = min(right-detail-max-width, max(right-detail-min-width, resize-start-width - (self.mouse-x - resize-origin-x)));
            }
        }
    }

    // ─── Settings dialog ───
    if settings-open: Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        background: #00000073;

        TouchArea {
            clicked => { close-settings(); }
        }

        Rectangle {
            x: (parent.width - 760px) / 2;
            y: (parent.height - 540px) / 2;
            width: 760px;
            height: 540px;
            background: Theme.bg-1;
            border-color: Theme.line;
            border-width: 1px;
            border-radius: 12px;
            clip: true;

            TouchArea {}

            Rectangle {
                x: 0;
                y: 0;
                width: 200px;
                height: parent.height;
                background: Theme.bg-0;

                VerticalLayout {
                    padding-top: 14px;
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 1px;

                    Rectangle {
                        height: 64px;

                        Image {
                            x: 8px;
                            y: 4px;
                            width: 44px;
                            height: 44px;
                            source: @image-url("../assets/AppIcon.iconset/icon_128x128.png");
                            image-fit: contain;
                        }

                        Text {
                            x: 62px;
                            y: 13px;
                            text: "ModelRack";
                            color: Theme.fg-0;
                            font-size: Theme.font-title;
                            font-weight: 600;
                        }

                        Text {
                            x: 62px;
                            y: 32px;
                            text: app-version;
                            color: Theme.fg-2;
                            font-family: "JetBrains Mono";
                            font-size: 11px;
                        }

                        Rectangle {
                            x: 0;
                            y: parent.height - 1px;
                            width: parent.width;
                            height: 1px;
                            background: Theme.line;
                        }
                    }

                    Rectangle { height: 6px; }

                    SettingsTabButton { icon: @image-url("../assets/icons/sparkle.svg"); label: settings-language-key == "ko" ? "일반" : settings-language-key == "ja" ? "一般" : "General"; key: "general"; selected: settings-tab == "general"; activated(tab) => { choose-settings-tab(tab); } }
                    SettingsTabButton { icon: @image-url("../assets/icons/sun.svg"); label: settings-language-key == "ko" ? "모양" : settings-language-key == "ja" ? "外観" : "Appearance"; key: "appearance"; selected: settings-tab == "appearance"; activated(tab) => { choose-settings-tab(tab); } }
                    SettingsTabButton { icon: @image-url("../assets/icons/folder.svg"); label: settings-language-key == "ko" ? "라이브러리" : settings-language-key == "ja" ? "ライブラリ" : "Library"; key: "library"; selected: settings-tab == "library"; activated(tab) => { choose-settings-tab(tab); } }
                    SettingsTabButton { icon: @image-url("../assets/icons/box.svg"); label: settings-language-key == "ko" ? "썸네일" : settings-language-key == "ja" ? "サムネイル" : "Thumbnails"; key: "thumbnails"; selected: settings-tab == "thumbnails"; activated(tab) => { choose-settings-tab(tab); } }
                    SettingsTabButton { icon: @image-url("../assets/icons/print.svg"); label: settings-language-key == "ko" ? "프린터" : settings-language-key == "ja" ? "プリンタ" : "Printers"; key: "printers"; selected: settings-tab == "printers"; activated(tab) => { choose-settings-tab(tab); } }
                    SettingsTabButton { icon: @image-url("../assets/icons/slicer.svg"); label: settings-language-key == "ko" ? "슬라이서" : settings-language-key == "ja" ? "スライサー" : "Slicer"; key: "slicer"; selected: settings-tab == "slicer"; activated(tab) => { choose-settings-tab(tab); } }
                    SettingsTabButton { icon: @image-url("../assets/icons/cmd.svg"); label: settings-language-key == "ko" ? "단축키" : settings-language-key == "ja" ? "ショートカット" : "Hotkeys"; key: "hotkeys"; selected: settings-tab == "hotkeys"; activated(tab) => { choose-settings-tab(tab); } }
                    SettingsTabButton { icon: @image-url("../assets/icons/sparkle.svg"); label: settings-language-key == "ko" ? "고급" : settings-language-key == "ja" ? "詳細" : "Advanced"; key: "advanced"; selected: settings-tab == "advanced"; activated(tab) => { choose-settings-tab(tab); } }
                    SettingsTabButton { icon: @image-url("../assets/icons/info.svg"); label: settings-language-key == "ko" ? "정보" : settings-language-key == "ja" ? "情報" : "About"; key: "about"; selected: settings-tab == "about"; activated(tab) => { choose-settings-tab(tab); } }
                }
            }

            Rectangle {
                x: 199px;
                y: 0;
                width: 1px;
                height: parent.height;
                background: Theme.line;
            }

            Rectangle {
                x: 200px;
                y: 0;
                width: parent.width - 200px;
                height: parent.height;
                background: Theme.bg-1;

                Rectangle {
                    x: 0;
                    y: 0;
                    width: parent.width;
                    height: 44px;

                    Text {
                        x: 18px;
                        y: (parent.height - self.height) / 2;
                        text: settings-tab == "general" ? "General" :
                              settings-tab == "appearance" ? "Appearance" :
                              settings-tab == "library" ? "Library" :
                              settings-tab == "thumbnails" ? "Thumbnails" :
                              settings-tab == "printers" ? "Printers" :
                              settings-tab == "slicer" ? "Slicer" :
                              settings-tab == "hotkeys" ? "Hotkeys" :
                              settings-tab == "advanced" ? "Advanced" : "About";
                        color: Theme.fg-0;
                        font-size: Theme.font-heading;
