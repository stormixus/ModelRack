    property <string> tr-default-estimate: settings-language-key == "ko" ? "기본 출력 예상" : settings-language-key == "ja" ? "既定の見積" : "Default estimate";
    property <string> tr-printer-selector: settings-language-key == "ko" ? "프린터 선택" : settings-language-key == "ja" ? "プリンタ選択" : "Printer selector";
    property <string> tr-maker-model-nozzle: settings-language-key == "ko" ? "제조사 → 모델 → 노즐" : settings-language-key == "ja" ? "メーカー → モデル → ノズル" : "Maker → model → nozzle";
    property <string> tr-maker: settings-language-key == "ko" ? "제조사" : settings-language-key == "ja" ? "メーカー" : "Maker";
    property <string> tr-model: settings-language-key == "ko" ? "모델" : settings-language-key == "ja" ? "モデル" : "Model";
    property <string> tr-nozzle: settings-language-key == "ko" ? "노즐" : settings-language-key == "ja" ? "ノズル" : "Nozzle";
    property <string> tr-default: settings-language-key == "ko" ? "기본" : settings-language-key == "ja" ? "既定" : "Default";
    property <string> tr-set-default: settings-language-key == "ko" ? "기본 설정" : settings-language-key == "ja" ? "既定に設定" : "Set default";
    property <string> tr-default-slicer: settings-language-key == "ko" ? "기본 슬라이서" : settings-language-key == "ja" ? "既定のスライサー" : "Default slicer";
    property <string> tr-detected-apps: settings-language-key == "ko" ? "감지된 앱" : settings-language-key == "ja" ? "検出したアプリ" : "Detected apps";
    property <string> tr-choices-suffix: settings-language-key == "ko" ? "개 선택지" : settings-language-key == "ja" ? " 件" : " choices";
    property <string> tr-custom-path: settings-language-key == "ko" ? "사용자 지정 경로" : settings-language-key == "ja" ? "カスタムパス" : "Custom path";
    property <string> tr-browse: settings-language-key == "ko" ? "찾아보기…" : settings-language-key == "ja" ? "参照…" : "Browse…";
    property <string> tr-after-export: settings-language-key == "ko" ? "내보낸 후" : settings-language-key == "ja" ? "エクスポート後" : "After export";
    property <string> tr-global: settings-language-key == "ko" ? "전역" : settings-language-key == "ja" ? "全体" : "GLOBAL";
    property <string> tr-view: settings-language-key == "ko" ? "보기" : settings-language-key == "ja" ? "表示" : "VIEW";
    property <string> tr-focus-search: settings-language-key == "ko" ? "검색 포커스" : settings-language-key == "ja" ? "検索にフォーカス" : "Focus search";
    property <string> tr-open-settings: settings-language-key == "ko" ? "설정 열기" : settings-language-key == "ja" ? "設定を開く" : "Open settings";
    property <string> tr-import-folder: settings-language-key == "ko" ? "폴더 가져오기" : settings-language-key == "ja" ? "フォルダを取り込む" : "Import folder";
    property <string> tr-grid-view: settings-language-key == "ko" ? "그리드 보기" : settings-language-key == "ja" ? "グリッド表示" : "Grid view";
    property <string> tr-masonry-view: settings-language-key == "ko" ? "메이슨리 보기" : settings-language-key == "ja" ? "メイソンリー表示" : "Masonry view";
    property <string> tr-list-view: settings-language-key == "ko" ? "리스트 보기" : settings-language-key == "ja" ? "リスト表示" : "List view";
    property <string> tr-gpu-rendering: settings-language-key == "ko" ? "GPU 렌더링" : settings-language-key == "ja" ? "GPUレンダリング" : "GPU rendering";
    property <string> tr-use-gpu-thumbnails: settings-language-key == "ko" ? "썸네일에 GPU 사용" : settings-language-key == "ja" ? "サムネイルにGPUを使用" : "Use GPU for thumbnails";
    property <string> tr-log-level: settings-language-key == "ko" ? "로그 레벨" : settings-language-key == "ja" ? "ログレベル" : "Log level";
    property <string> tr-cache-location: settings-language-key == "ko" ? "캐시 위치" : settings-language-key == "ja" ? "キャッシュ場所" : "Cache location";
    property <string> tr-open-logs: settings-language-key == "ko" ? "로그 열기" : settings-language-key == "ja" ? "ログを開く" : "Open logs";
    property <string> tr-reset-settings: settings-language-key == "ko" ? "설정 초기화" : settings-language-key == "ja" ? "設定をリセット" : "Reset settings";
    property <string> tr-about-subtitle: settings-language-key == "ko" ? "3D 모델 라이브러리를 위한 작업실 도구" : settings-language-key == "ja" ? "3Dモデルライブラリのための工房ツール" : "A workshop tool for your 3D model library";
    property <string> tr-version: settings-language-key == "ko" ? "버전" : settings-language-key == "ja" ? "バージョン" : "Version";
    property <string> tr-build: settings-language-key == "ko" ? "빌드" : settings-language-key == "ja" ? "ビルド" : "Build";
    property <string> tr-stack: settings-language-key == "ko" ? "스택" : settings-language-key == "ja" ? "スタック" : "Stack";
    property <string> tr-updates: settings-language-key == "ko" ? "업데이트" : settings-language-key == "ja" ? "アップデート" : "Updates";
    property <string> tr-check: settings-language-key == "ko" ? "확인" : settings-language-key == "ja" ? "確認" : "Check";
    in property <string> settings-theme-key: "dark";
    in property <string> settings-theme-label: "Dark";
    in property <string> settings-sort-key: "name";
    in property <bool> settings-sort-ascending: true;
    in property <string> settings-thumbnail-style: "iso";
    in property <string> settings-thumbnail-lighting: "studio";
    in property <string> settings-thumbnail-aa: "msaa4x";
    in property <string> settings-update-status: "ModelRack is up to date";
    in property <string> settings-folder-label;
    in property <string> settings-density-label;
    in property <string> settings-slicer-label;
    in property <image> settings-slicer-icon-image;
    in property <bool> settings-slicer-icon-ready: false;
    in property <[SlicerCandidate]> settings-slicer-candidates;
    in property <string> settings-printer-summary;
    in property <string> settings-default-printer-label;
    in property <int> settings-printer-active-count;
    in property <[PrinterProfileChoice]> settings-printer-profiles;
    in property <[ChoiceRow]> settings-printer-makers;
    in property <[ChoiceRow]> settings-printer-models;
    in property <[ChoiceRow]> settings-printer-nozzles;
    in property <string> settings-printer-maker-label;
    in property <string> settings-printer-model-label;
    property <bool> sidebar-context-open: false;
    property <string> sidebar-context-key;
    property <string> sidebar-context-label;
    property <bool> sidebar-context-is-folder: false;
    property <length> sidebar-context-x: 0px;
    property <length> sidebar-context-y: 0px;
    property <bool> model-context-open: false;
    property <int> model-context-index: -1;
    property <string> model-context-label;
    property <bool> model-context-favorite: false;
    property <int> model-context-printed-count: 0;
    property <length> model-context-x: 0px;
    property <length> model-context-y: 0px;
    property <length> model-context-menu-width: 214px;
    property <length> model-context-menu-height: model-context-printed-count > 0 ? 312px : 283px;
    property <bool> slicer-menu-open: false;
    property <bool> preview-dragging: false;
    property <length> preview-last-x: 0px;
    property <length> preview-last-y: 0px;
    property <bool> preview-fullscreen-open: false;
    property <bool> preview-plate-menu-open: false;
    property <bool> estimate-printer-menu-open: false;
    property <bool> sort-menu-open: false;
    property <bool> left-sidebar-open: true;
    property <bool> right-detail-open: true;
    property <length> left-sidebar-min-width: 180px;
    property <length> right-detail-min-width: 280px;
    property <length> left-sidebar-max-width: 380px;
    property <length> right-detail-max-width: 520px;
    property <length> left-sidebar-width: Theme.sidebar-width;
    property <length> right-detail-width: Theme.detail-width;
    property <length> visible-left-sidebar-width: left-sidebar-open ? left-sidebar-width : 0px;
    property <length> visible-right-detail-width: right-detail-open ? right-detail-width : 0px;
    property <bool> left-sidebar-resizing: false;
    property <bool> right-detail-resizing: false;
    property <length> resize-origin-x: 0px;
    property <length> resize-start-width: 0px;
    property <bool> rename-editing: false;
    property <string> rename-draft: "";

    // Callbacks
    callback open-folder();
    callback refresh-library();
    callback open-settings();
    callback close-settings();
    callback choose-settings-tab(string);
    callback choose-settings-language(string);
    callback choose-settings-theme(string);
    callback choose-settings-sort(string);
    callback choose-settings-thumbnail-style(string);
    callback choose-settings-thumbnail-lighting(string);
    callback choose-settings-thumbnail-aa(string);
    callback choose-settings-printer-maker(string);
    callback choose-settings-printer-model(string);
    callback choose-settings-printer-nozzle(string);
    callback check-updates();
    callback cycle-settings-language();
    callback toggle-settings-theme();
    callback cycle-settings-density();
    callback choose-slicer();
    callback choose-settings-slicer(string);
    callback toggle-settings-printer(string);
    callback choose-settings-default-printer(string);
    callback choose-estimate-printer(string);
    callback apply-search(string);
    callback choose-view-mode(string);
    callback choose-density(string);
    callback cycle-view-mode();
    callback cycle-density();
    callback toggle-sort();
    callback choose-filter(string);
    callback toggle-sidebar-folder(string);
    callback sidebar-context-action(string, string, string);
    callback model-context-action(string, int);
    callback undo-library-action();
    callback select-model(int);
    callback add-tag-to-model(string, string) -> bool;
    callback toggle-favorite();
    callback rename-model(string) -> bool;
    callback save-metadata(string, string, string);
    callback add-tags(string);
    callback remove-tag(int);
    callback adjust-printed-count(int);
    callback add-print-record(string, string, string, string, string, string, string);
    callback remove-print-record(int);
    callback open-in-slicer();
    callback choose-preview-plate(int);
    callback preview-orbit(float, float);
    callback preview-orbit-reset();
    callback window-close();
    callback window-minimize();
    callback window-fullscreen();
    callback titlebar-drag(length, length);

    title: "";
    preferred-width: 1480px;
    preferred-height: 920px;
    default-font-family: "Inter";
    background: Theme.bg-0;

    init => {
        shortcut-scope.focus();
    }

    shortcut-scope := FocusScope {
        x: 0;
        y: 0;
        width: 0px;
        height: 0px;

        KeyBinding {
            keys: @keys(Control + Z);
            activated => { undo-library-action(); }
        }

        KeyBinding {
            keys: @keys(Meta + Z);
            activated => { undo-library-action(); }
        }

        KeyBinding {
            keys: @keys(F2);
            activated => {
                if has-selection && !settings-open {
                    rename-draft = detail-name;
                    rename-editing = true;
                }
            }
        }

        KeyBinding {
            keys: @keys(Return);
            activated => {
                if has-selection && !settings-open {
                    rename-draft = detail-name;
                    rename-editing = true;
                }
            }
        }
    }

    // ─── Root layout ───
    VerticalLayout {
        // ─── Custom titlebar ───
        Rectangle {
            height: Theme.titlebar-height;
            background: Theme.bg-1;

            ta-titlebar-drag := TouchArea {
                pointer-event(event) => {
                    if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                        titlebar-drag(ta-titlebar-drag.mouse-x, ta-titlebar-drag.mouse-y);
                    }
                }
            }

            Rectangle {
                x: 0;
                y: parent.height - 1px;
                width: parent.width;
                height: 1px;
                background: Theme.line;
            }

            traffic-hover := TouchArea {
                x: 6px;
                y: (parent.height - 24px) / 2;
                width: 66px;
                height: 24px;
            }

            traffic-lights := HorizontalLayout {
                x: 12px;
                y: (parent.height - 12px) / 2;
                spacing: 8px;

                close-light := TrafficLightButton {
                    fill: #ff5f56;
                    glyph: @image-url("../assets/icons/close.svg");
                    glyph-tint: #7a1210;
                    controls-hover: traffic-hover.has-hover || close-light.hovered || minimize-light.hovered || fullscreen-light.hovered;
                    activated => { window-close(); }
                }

                minimize-light := TrafficLightButton {
                    fill: #ffbd2e;
                    glyph: @image-url("../assets/icons/minus.svg");
                    glyph-tint: #8a5a00;
                    controls-hover: traffic-hover.has-hover || close-light.hovered || minimize-light.hovered || fullscreen-light.hovered;
                    activated => { window-minimize(); }
                }

                fullscreen-light := TrafficLightButton {
                    fill: #27c93f;
                    glyph: @image-url("../assets/icons/fullscreen.svg");
                    glyph-tint: #0b6d1a;
                    controls-hover: traffic-hover.has-hover || close-light.hovered || minimize-light.hovered || fullscreen-light.hovered;
                    activated => { window-fullscreen(); }
                }
            }

            Image {
                x: 80px;
                y: (parent.height - 18px) / 2;
                width: 18px;
                height: 18px;
                source: @image-url("../assets/icons/app-mark.svg");
                image-fit: contain;
            }

            Text {
                x: 106px;
                y: (parent.height - self.height) / 2;
                text: app-title;
                color: Theme.fg-1;
                font-size: 12px;
                font-weight: 500;
            }

            Text {
                x: 178px;
                y: (parent.height - self.height) / 2;
                text: "—";
                color: Theme.fg-3;
                font-size: 12px;
            }

            Text {
                x: 196px;
                y: (parent.height - self.height) / 2;
                text: library-label;
                color: Theme.fg-2;
                font-family: "JetBrains Mono";
                font-size: 11px;
            }

            // VSCode-style layout controls
            Rectangle {
                x: parent.width - 104px;
                y: (parent.height - 26px) / 2;
                width: 26px;
                height: 26px;
                border-radius: Theme.radius-btn;
                background: ta-toggle-left.has-hover ? Theme.bg-3 : left-sidebar-open ? Theme.accent-dim : transparent;
                border-color: left-sidebar-open ? Theme.accent-line : transparent;
                border-width: left-sidebar-open ? 1px : 0px;

                Rectangle { x: 7px; y: 7px; width: 12px; height: 12px; border-color: Theme.fg-2; border-width: 1px; border-radius: 2px; background: transparent; }
                Rectangle { x: 7px; y: 7px; width: 4px; height: 12px; border-radius: 2px; background: left-sidebar-open ? Theme.accent : Theme.fg-3; }

                ta-toggle-left := TouchArea {
                    clicked => { left-sidebar-open = !left-sidebar-open; }
                }
            }

            Rectangle {
                x: parent.width - 72px;
                y: (parent.height - 26px) / 2;
                width: 26px;
                height: 26px;
                border-radius: Theme.radius-btn;
                background: ta-toggle-right.has-hover ? Theme.bg-3 : right-detail-open ? Theme.accent-dim : transparent;
                border-color: right-detail-open ? Theme.accent-line : transparent;
                border-width: right-detail-open ? 1px : 0px;

                Rectangle { x: 7px; y: 7px; width: 12px; height: 12px; border-color: Theme.fg-2; border-width: 1px; border-radius: 2px; background: transparent; }
                Rectangle { x: 15px; y: 7px; width: 4px; height: 12px; border-radius: 2px; background: right-detail-open ? Theme.accent : Theme.fg-3; }

                ta-toggle-right := TouchArea {
                    clicked => { right-detail-open = !right-detail-open; }
                }
            }

            Rectangle {
                x: parent.width - 38px;
                y: (parent.height - 26px) / 2;
                width: 26px;
                height: 26px;
                border-radius: Theme.radius-btn;
                background: ta-settings.has-hover ? Theme.bg-3 : transparent;

                SvgIcon {
                    x: (parent.width - 14px) / 2;
                    y: (parent.height - 14px) / 2;
                    width: 14px;
                    height: 14px;
                    icon: @image-url("../assets/icons/settings.svg");
                    tint: Theme.fg-2;
                }

                ta-settings := TouchArea {
                    clicked => { open-settings(); }
                }
            }
        }

        // ─── Main 3-pane area ───
        HorizontalLayout {
            // ─── Sidebar ───
            Rectangle {
                width: visible-left-sidebar-width;
                background: Theme.bg-1;
                clip: true;
                animate width { duration: left-sidebar-resizing ? 0ms : 180ms; easing: ease-in-out; }

                Rectangle {
                    x: parent.width - 1px;
                    y: 0;
                    width: 1px;
                    height: parent.height;
                    background: Theme.line;
                }

                if left-sidebar-open: sidebar-scroll := ScrollView {
                    x: 6px;
                    y: 0;
                    width: max(0px, parent.width - 12px);
                    height: parent.height;

                    VerticalLayout {
                        padding-top: 10px;
                        spacing: 1px;

                        SectionHeader { label: tr-library-heading; inset: true; }

                        SidebarLine { icon: @image-url("../assets/icons/layers.svg"); label: tr-all-models; count: all-count; selected: active-filter-key == "all"; activated => { choose-filter("all"); } }
                        SidebarLine { icon: @image-url("../assets/icons/clock.svg"); label: tr-recent; count: recent-count; selected: active-filter-key == "recent"; activated => { choose-filter("recent"); } }
                        SidebarLine { icon: @image-url("../assets/icons/star.svg"); label: tr-favorites; count: favorites-count; selected: active-filter-key == "favorites"; activated => { choose-filter("favorites"); } }
                        SidebarLine { icon: @image-url("../assets/icons/print.svg"); label: tr-printed; count: printed-count; selected: active-filter-key == "printed"; activated => { choose-filter("printed"); } }
                        SidebarLine { icon: @image-url("../assets/icons/box.svg"); label: tr-ready-to-print; count: ready-count; selected: active-filter-key == "ready"; activated => { choose-filter("ready"); } }
                        SidebarLine { icon: @image-url("../assets/icons/duplicate.svg"); label: tr-duplicates; count: duplicates-count; selected: active-filter-key == "duplicates"; activated => { choose-filter("duplicates"); } }
                        SidebarLine { icon: @image-url("../assets/icons/error.svg"); label: tr-parse-errors; count: errors-count; selected: active-filter-key == "errors"; activated => { choose-filter("errors"); } }

                        Rectangle {
                            height: 1px;
                            background: Theme.line;
                        }

                        if folder-items.length > 0: SectionHeader { label: tr-folders-heading; show-add: true; }

                        for folder in folder-items: folder-row := SidebarLine {
                            icon: folder.depth == 0 ? @image-url("../assets/icons/folder-open.svg") : @image-url("../assets/icons/folder.svg");
                            label: folder.label;
                            count: folder.count;
                            depth: folder.depth;
                            reserve-leading: true;
                            expandable: folder.expandable;
                            expanded: folder.expanded;
                            row-visible: folder.visible;
                            selected: active-filter-key == folder.key;
                            activated => {
                                sidebar-context-open = false;
                                model-context-open = false;
                                choose-filter(folder.key);
                            }
                            toggle-requested => { toggle-sidebar-folder(folder.key); }
                            context-requested(x, y) => {
                                sidebar-context-key = folder.key;
                                sidebar-context-label = folder.label;
                                sidebar-context-is-folder = true;
                                sidebar-context-x = x + 4px;
                                sidebar-context-y = y + 4px;
                                sidebar-context-open = true;
                                model-context-open = false;
                                slicer-menu-open = false;
                                sort-menu-open = false;
                                preview-plate-menu-open = false;
                            }
                        }

                        if tag-items.length > 0: SectionHeader { label: tr-tags-heading; show-add: true; }

                        for tag in tag-items: tag-row := SidebarLine {
                            icon: @image-url("../assets/icons/tag.svg");
                            label: tag.label;
                            count: tag.count;
                            drop-enabled: true;
                            selected: active-filter-key == tag.key;
                            activated => {
                                sidebar-context-open = false;
                                model-context-open = false;
                                choose-filter(tag.key);
                            }
                            model-dropped(model, tag) => { add-tag-to-model(model, tag); }
                            context-requested(x, y) => {
                                sidebar-context-key = tag.key;
                                sidebar-context-label = tag.label;
                                sidebar-context-is-folder = false;
                                sidebar-context-x = x + 4px;
                                sidebar-context-y = y + 4px;
                                sidebar-context-open = true;
                                model-context-open = false;
                                slicer-menu-open = false;
                                sort-menu-open = false;
                                preview-plate-menu-open = false;
                            }
                        }
                    }
                }
            }

            if left-sidebar-open: Rectangle {
                width: 6px;
                background: left-resize-touch.has-hover || left-sidebar-resizing ? Theme.accent-dim : Theme.bg-2;

                Rectangle {
                    x: 2px;
                    y: 0;
                    width: 1px;
                    height: parent.height;
                    background: left-resize-touch.has-hover || left-sidebar-resizing ? Theme.accent : Theme.line;
                }

                left-resize-touch := TouchArea {
                    mouse-cursor: ew-resize;
                    pointer-event(event) => {
                        if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                            left-sidebar-resizing = true;
                            resize-origin-x = left-resize-touch.absolute-position.x - root.absolute-position.x + left-resize-touch.mouse-x;
                            resize-start-width = left-sidebar-width;
                        } else if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                            left-sidebar-resizing = false;
                        } else if (event.kind == PointerEventKind.cancel) {
                            left-sidebar-resizing = false;
                        } else if (event.kind == PointerEventKind.move && left-sidebar-resizing) {
                            left-sidebar-width = min(left-sidebar-max-width, max(left-sidebar-min-width, resize-start-width + ((left-resize-touch.absolute-position.x - root.absolute-position.x + left-resize-touch.mouse-x) - resize-origin-x)));
                        }
                    }
                }
            }

            // ─── Center content ───
            center-content := Rectangle {
                horizontal-stretch: 1;

                VerticalLayout {
                    width: parent.width;
                    height: parent.height;

                // Toolbar
                Rectangle {
                    height: Theme.toolbar-height;
                    background: Theme.bg-2;

                    Rectangle {
                        x: 0;
                        y: parent.height - 1px;
                        width: parent.width;
                        height: 1px;
                        background: Theme.line;
                    }

                    HorizontalLayout {
                        x: 0;
                        y: 0;
                        width: parent.width;
                        height: parent.height;
                        padding: 8px;
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 8px;
                        alignment: start;

                        // Search
                        Rectangle {
                            width: 224px;
                            height: 28px;
                            background: Theme.bg-1;
                            border-color: Theme.line;
                            border-width: 1px;
                            border-radius: Theme.radius-btn;
                            clip: true;

                            SvgIcon {
                                x: 10px;
                                y: (parent.height - self.height) / 2;
                                width: 14px;
                                height: 14px;
                                icon: @image-url("../assets/icons/search.svg");
                                tint: Theme.fg-2;
                            }

                            Text {
                                x: 32px;
                                y: 0;
                                width: parent.width - 78px;
                                height: parent.height;
                                text: search-text == "" && search-field.preedit-text == "" ? settings-language-key == "ko" ? "파일명, 태그, 메모 검색…" : settings-language-key == "ja" ? "ファイル名、タグ、メモを検索…" : "Search filename, tag, notes…" : "";
                                color: Theme.fg-2;
                                font-size: 12px;
                                vertical-alignment: center;
                                overflow: elide;
                            }

                            search-field := TextInput {
                                x: 32px;
                                y: 0;
                                width: parent.width - 78px;
                                height: parent.height;
                                text <=> search-text;
                                color: Theme.fg-0;
                                font-size: 12px;
                                vertical-alignment: center;
                                selection-background-color: Theme.accent;
                                selection-foreground-color: #0e2a32;
                                accepted => { apply-search(self.text); }
                            }

                            Rectangle {
                                x: parent.width - self.width - 8px;
                                y: (parent.height - self.height) / 2;
                                width: 31px;
                                height: 18px;
                                background: Theme.bg-2;
                                border-color: Theme.line-2;
                                border-width: 1px;
                                border-radius: 4px;

                                Text {
                                    x: (parent.width - self.width) / 2;
                                    y: (parent.height - self.height) / 2;
                                    text: "⌘K";
                                    color: Theme.fg-3;
                                    font-family: "JetBrains Mono";
                                    font-size: 10px;
                                }
                            }
                        }

                        // View segmented control
                        Rectangle {
                            width: 202px;
                            height: 28px;
                            background: Theme.bg-1;
                            border-color: Theme.line;
                            border-width: 1px;
                            border-radius: Theme.radius-btn;

                            Rectangle {
                                x: view-mode-label == "Masonry" ? 62px : view-mode-label == "List" ? 146px : 2px;
                                y: 2px;
                                width: view-mode-label == "Masonry" ? 82px : view-mode-label == "List" ? 54px : 58px;
                                height: 24px;
                                background: Theme.bg-3;
                                border-radius: 4px;
                                animate x { duration: 180ms; easing: ease-in-out; }
                                animate width { duration: 180ms; easing: ease-in-out; }
                            }

                            Rectangle {
                                x: 2px;
                                y: 2px;
                                width: 58px;
                                height: 24px;
                                background: transparent;

                                grid-label := Text {
                                    x: (parent.width - 16px - self.width) / 2 + 16px;
                                    y: 0;
                                    height: parent.height;
                                    text: tr-grid;
                                    color: view-mode-label == "Grid" ? Theme.fg-0 : Theme.fg-1;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                }

                                SvgIcon {
                                    x: grid-label.x - 16px;
                                    y: (parent.height - 12px) / 2;
                                    width: 12px;
                                    height: 12px;
                                    icon: @image-url("../assets/icons/grid.svg");
                                    tint: view-mode-label == "Grid" ? Theme.fg-0 : Theme.fg-1;
                                }

                                TouchArea { clicked => { choose-view-mode("grid"); } }
                            }

                            Rectangle { x: 61px; y: 5px; width: 1px; height: 18px; background: Theme.line; }

                            Rectangle {
                                x: 62px;
                                y: 2px;
                                width: 82px;
                                height: 24px;
                                background: transparent;

                                masonry-label := Text {
                                    x: (parent.width - 16px - self.width) / 2 + 16px;
                                    y: 0;
                                    height: parent.height;
                                    text: tr-masonry;
                                    color: view-mode-label == "Masonry" ? Theme.fg-0 : Theme.fg-1;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                }

                                SvgIcon {
                                    x: masonry-label.x - 16px;
                                    y: (parent.height - 12px) / 2;
                                    width: 12px;
                                    height: 12px;
                                    icon: @image-url("../assets/icons/masonry.svg");
                                    tint: view-mode-label == "Masonry" ? Theme.fg-0 : Theme.fg-1;
                                }

                                TouchArea { clicked => { choose-view-mode("masonry"); } }
                            }

                            Rectangle { x: 145px; y: 5px; width: 1px; height: 18px; background: Theme.line; }

                            Rectangle {
                                x: 146px;
                                y: 2px;
                                width: 54px;
                                height: 24px;
                                background: transparent;

                                list-label := Text {
                                    x: (parent.width - 16px - self.width) / 2 + 16px;
                                    y: 0;
                                    height: parent.height;
                                    text: tr-list;
                                    color: view-mode-label == "List" ? Theme.fg-0 : Theme.fg-1;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                }

                                SvgIcon {
                                    x: list-label.x - 16px;
                                    y: (parent.height - 12px) / 2;
                                    width: 12px;
                                    height: 12px;
                                    icon: @image-url("../assets/icons/list.svg");
                                    tint: view-mode-label == "List" ? Theme.fg-0 : Theme.fg-1;
                                }

                                TouchArea { clicked => { choose-view-mode("list"); } }
                            }
                        }

                        // Density segmented control
                        Rectangle {
                            width: 84px;
                            height: 28px;
                            background: Theme.bg-1;
                            border-color: Theme.line;
                            border-width: 1px;
                            border-radius: Theme.radius-btn;

                            Rectangle {
                                x: density-label == "M" ? 30px : density-label == "L" ? 56px : 2px;
                                y: 2px;
                                width: density-label == "M" ? 24px : 26px;
                                height: 24px;
                                background: Theme.bg-3;
                                border-radius: 4px;
                                animate x { duration: 180ms; easing: ease-in-out; }
                                animate width { duration: 180ms; easing: ease-in-out; }
                            }

                            Rectangle {
                                x: 2px;
                                y: 2px;
                                width: 26px;
                                height: 24px;
                                background: transparent;
                                Text { x: (parent.width - self.width) / 2; y: 0; height: parent.height; text: "S"; color: density-label == "S" ? Theme.fg-0 : Theme.fg-1; font-size: 12px; vertical-alignment: center; }
                                TouchArea { clicked => { choose-density("small"); } }
                            }
                            Rectangle { x: 29px; y: 5px; width: 1px; height: 18px; background: Theme.line; }
                            Rectangle {
                                x: 30px;
                                y: 2px;
                                width: 24px;
                                height: 24px;
                                background: transparent;
                                Text { x: (parent.width - self.width) / 2; y: 0; height: parent.height; text: "M"; color: density-label == "M" ? Theme.fg-0 : Theme.fg-1; font-size: 12px; vertical-alignment: center; }
                                TouchArea { clicked => { choose-density("medium"); } }
                            }
                            Rectangle { x: 55px; y: 5px; width: 1px; height: 18px; background: Theme.line; }
                            Rectangle {
                                x: 56px;
                                y: 2px;
                                width: 26px;
                                height: 24px;
                                background: transparent;
                                Text { x: (parent.width - self.width) / 2; y: 0; height: parent.height; text: "L"; color: density-label == "L" ? Theme.fg-0 : Theme.fg-1; font-size: 12px; vertical-alignment: center; }
                                TouchArea { clicked => { choose-density("large"); } }
                            }
                        }

                        Rectangle {
                            width: 1px;
                            height: 18px;
                            background: Theme.line-2;
                        }

                        // Grouped sort dropdown + direction
                        Rectangle {
                            width: 150px;
                            height: sort-menu-open ? 272px : 28px;
                            z: 60;

                            Rectangle {
                                x: 0;
                                y: 0;
                                width: 150px;
                                height: 28px;
                                background: sort-button-touch.has-hover || sort-dir-touch.has-hover || sort-menu-open ? Theme.bg-3 : Theme.bg-1;
                                border-color: sort-menu-open ? Theme.accent-line : Theme.line;
                                border-width: 1px;
                                border-radius: Theme.radius-btn;

                                SvgIcon { x: 9px; y: 8px; width: 12px; height: 12px; icon: @image-url("../assets/icons/sort.svg"); tint: Theme.fg-2; }
                                Text {
                                    x: 28px;
                                    y: 7px;
                                    width: 78px;
                                    text: settings-sort-key == "modified" || settings-sort-key == "date" ? tr-sort-modified : settings-sort-key == "added" ? tr-sort-added : settings-sort-key == "format" ? tr-format : settings-sort-key == "size" ? tr-file-size : settings-sort-key == "triangles" ? tr-triangles : settings-sort-key == "dimensions" ? tr-dimensions : settings-sort-key == "volume" ? tr-volume-est : tr-name;
                                    color: Theme.fg-1;
                                    font-size: 12px;
                                    overflow: elide;
                                }
                                SvgIcon { x: 108px; y: 10px; width: 8px; height: 8px; icon: @image-url("../assets/icons/chevron-right.svg"); tint: Theme.fg-2; transform-rotation: sort-menu-open ? -90deg : 90deg; }

                                Rectangle { x: 119px; y: 5px; width: 1px; height: 18px; background: Theme.line-2; }
                                Text { x: 120px; y: 6px; width: 29px; text: settings-sort-ascending ? "↑" : "↓"; color: Theme.fg-1; font-size: 15px; horizontal-alignment: center; }

                                sort-button-touch := TouchArea { x: 0; y: 0; width: 120px; height: parent.height; clicked => { sort-menu-open = !sort-menu-open; slicer-menu-open = false; preview-plate-menu-open = false; estimate-printer-menu-open = false; model-context-open = false; sidebar-context-open = false; } }
                                sort-dir-touch := TouchArea { x: 120px; y: 0; width: 30px; height: parent.height; clicked => { toggle-sort(); } }
                            }
                        }

                        Rectangle { horizontal-stretch: 1; }

                        // Refresh
                        Rectangle {
                            width: 28px;
                            height: 28px;
                            background: ta-refresh.has-hover ? Theme.bg-3 : Theme.bg-1;
                            border-color: Theme.line;
                            border-width: 1px;
                            border-radius: Theme.radius-btn;
                            animate background { duration: 120ms; easing: ease-in-out; }

                            SvgIcon {
                                x: (parent.width - 14px) / 2;
                                y: (parent.height - 14px) / 2;
                                width: 14px;
                                height: 14px;
                                icon: @image-url("../assets/icons/refresh.svg");
                                tint: Theme.fg-1;
                            }

                            ta-refresh := TouchArea { clicked => { refresh-library(); } }
                        }

                        // Add Folder
                        Rectangle {
                            width: add-text.width + 42px;
                            height: 28px;
                            background: ta-add.has-hover ? #6fc8e0 : Theme.accent;
                            border-radius: Theme.radius-btn;

                            SvgIcon {
                                x: 10px;
                                y: (parent.height - 13px) / 2;
                                width: 13px;
                                height: 13px;
                                icon: @image-url("../assets/icons/plus.svg");
                                tint: #0e2a32;
                            }

                            add-text := Text {
                                x: 29px;
                                y: (parent.height - self.height) / 2;
                                text: settings-language-key == "ko" ? "폴더 추가" : settings-language-key == "ja" ? "フォルダ追加" : "Add Folder";
                                color: #0e2a32;
                                font-size: Theme.font-body;
                                font-weight: 500;
                            }

                            ta-add := TouchArea { clicked => { open-folder(); } }
                        }
                    }
                }

                // Filter bar
                Rectangle {
                    height: Theme.filterbar-height;
                    background: Theme.bg-2;

                    Rectangle {
                        x: 0;
                        y: parent.height - 1px;
                        width: parent.width;
                        height: 1px;
                        background: Theme.line;
                    }

                    Text {
                        x: 12px;
                        y: 0;
                        height: parent.height;
                        text: active-filter-key == "all" ? (settings-language-key == "ko" ? "전체 모델" : settings-language-key == "ja" ? "すべてのモデル" : "All models") : (settings-language-key == "ko" ? "필터링 중" : settings-language-key == "ja" ? "フィルタ中" : "Filtering");
                        color: Theme.fg-2;
                        font-size: 11px;
                        font-weight: 500;
                        vertical-alignment: center;
                    }

                    if active-filter-key != "all": FilterChip {
                        x: 78px;
                        y: (parent.height - self.height) / 2;
                        label: active-filter-key;
                        active: true;
                        dismiss => { choose-filter("all"); }
                    }

                    browser-count := Text {
                        x: parent.width - self.width - 12px;
                        y: 0;
                        height: parent.height;
                        text: browser-count-label;
                        color: Theme.fg-2;
                        font-family: "JetBrains Mono";
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }

                // Card grid area
                Rectangle {
                    background: Theme.bg-2;
                    vertical-stretch: 1;

                    if model-cards.length == 0: VerticalLayout {
                        alignment: center;

                        Rectangle {
                            height: 36px;
                            width: 36px;
                            x: (parent.width - self.width) / 2;
                            border-color: Theme.line-3;
                            border-width: 1px;
                            border-radius: 8px;
                            background: transparent;

                            SvgIcon {
                                x: (parent.width - 16px) / 2;
                                y: (parent.height - 16px) / 2;
                                width: 16px;
                                height: 16px;
                                icon: @image-url("../assets/icons/box.svg");
                                tint: Theme.fg-3;
                            }
                        }

                        Text {
                            text: browser-message;
                            color: Theme.fg-1;
                            font-size: Theme.font-body;
                            horizontal-alignment: center;
                        }
                    }

                    if model-cards.length > 0 && view-mode-label != "List": grid-flick := Flickable {
                        x: 14px;
                        y: 14px;
                        width: parent.width - 28px;
                        height: parent.height - 28px;

                        property <length> target-card-w: view-mode-label == "Masonry"
                            ? (density-label == "S" ? 132px : density-label == "L" ? 184px : 154px)
                            : (density-label == "S" ? 144px : density-label == "L" ? 208px : 168px);
                        property <length> card-w: target-card-w;
                        property <length> gap: 12px;
                        property <bool> full-layout-motion: model-cards.length <= 96;
                        property <length> render-buffer: full-layout-motion ? 1400px : 520px;
                        property <int> cols: max(1, floor((self.width + gap) / (target-card-w + gap)));
                        property <int> rows: ceil(model-cards.length / max(1, cols));
                        property <length> card-h: view-mode-label == "Masonry" ? card-w + 94px : card-w + 62px;

                        viewport-height: rows * card-h + max(0, rows - 1) * gap;
                        animate card-w { duration: full-layout-motion ? 260ms : 120ms; easing: ease-in-out; }

                        for card[index] in model-cards: model-card := ModelCard {
                            property <length> target-y: floor(card.slot-index / cols) * (grid-flick.card-h + grid-flick.gap);
                            x: mod(card.slot-index, cols) * (card-w + gap);
                            y: target-y;
                            width: card-w;
                            height: grid-flick.card-h;
                            visible: target-y + grid-flick.card-h >= grid-flick.viewport-y - grid-flick.render-buffer
                                && target-y <= grid-flick.viewport-y + grid-flick.height + grid-flick.render-buffer;
                            layout-motion: grid-flick.full-layout-motion
                                || (target-y + grid-flick.card-h >= grid-flick.viewport-y - grid-flick.render-buffer
                                    && target-y <= grid-flick.viewport-y + grid-flick.height + grid-flick.render-buffer);
                            card: card;
                            card-index: card.slot-index;
                            selected: card.slot-index == selected-card-index;
                            clicked(idx) => {
                                rename-editing = false;
                                model-context-open = false;
                                sidebar-context-open = false;
                                select-model(idx);
                            }
                            context-requested(idx, x, y) => {
                                rename-editing = false;
                                select-model(idx);
                                model-context-index = idx;
                                model-context-label = card.title;
                                model-context-favorite = card.favorite;
                                model-context-printed-count = card.printed-count;
                                model-context-x = x + 2px;
                                model-context-y = y + 2px;
                                model-context-open = true;
                                sidebar-context-open = false;
                                slicer-menu-open = false;
                                sort-menu-open = false;
                                preview-plate-menu-open = false;
                            }
                        }
                    }

                    if model-cards.length > 0 && view-mode-label == "List": list-flick := Flickable {
                        x: 14px;
                        y: 14px;
                        width: parent.width - 28px;
                        height: parent.height - 28px;

                        property <length> row-h: density-label == "S" ? 48px : density-label == "L" ? 68px : 58px;
                        property <length> gap: 8px;

                        viewport-height: model-cards.length * (row-h + gap);

                        for card[index] in model-cards: model-row := ModelListRow {
                            x: 0;
                            y: card.slot-index * (list-flick.row-h + list-flick.gap);
                            width: list-flick.width;
                            height: list-flick.row-h;
                            card: card;
                            card-index: card.slot-index;
                            selected: card.slot-index == selected-card-index;
                            clicked(idx) => {
                                rename-editing = false;
                                model-context-open = false;
                                sidebar-context-open = false;
                                select-model(idx);
                            }
                            context-requested(idx, x, y) => {
                                rename-editing = false;
                                select-model(idx);
                                model-context-index = idx;
                                model-context-label = card.title;
                                model-context-favorite = card.favorite;
                                model-context-printed-count = card.printed-count;
                                model-context-x = x + 2px;
                                model-context-y = y + 2px;
                                model-context-open = true;
                                sidebar-context-open = false;
                                slicer-menu-open = false;
                                sort-menu-open = false;
                                preview-plate-menu-open = false;
                            }
                        }
                    }
                }

                // Status bar
                Rectangle {
                    height: Theme.statusbar-height;
                    background: Theme.bg-1;

                    Rectangle {
                        x: 0;
                        y: 0;
                        width: parent.width;
                        height: 1px;
                        background: Theme.line;
                    }

                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        spacing: 8px;
                        alignment: center;

                        Rectangle {
                            width: 6px;
                            height: 6px;
                            border-radius: 3px;
                            background: Theme.success;
                        }

                        Text {
                            text: status-text;
                            color: Theme.fg-2;
                            font-family: "JetBrains Mono";
                            font-size: Theme.font-overline;
                        }

                        if scan-progress-percent >= 0: Rectangle {
                            width: progress-text.width + 14px;
                            height: 18px;
                            background: Theme.bg-3;
                            border-color: Theme.line-2;
                            border-width: 1px;
                            border-radius: 9px;

                            progress-text := Text {
                                x: 7px;
                                y: (parent.height - self.height) / 2;
                                text: scan-progress-percent + "%";
                                color: Theme.accent;
                                font-family: "JetBrains Mono";
                                font-size: Theme.font-overline;
                                font-weight: 600;
                            }
                        }

                        Rectangle { horizontal-stretch: 1; }

                        Text {
                            text: browser-count-label;
                            color: Theme.fg-3;
                            font-family: "JetBrains Mono";
                            font-size: Theme.font-overline;
                        }

                        Text {
                            text: app-version;
                            color: Theme.fg-3;
                            font-family: "JetBrains Mono";
                            font-size: Theme.font-overline;
                        }
                    }
                }
                }

                if sort-menu-open: Rectangle {
                    x: 555px;
                    y: 40px;
                    width: 150px;
                    height: 236px;
                    z: 400;
                    background: Theme.bg-1;
                    border-color: Theme.line-3;
                    border-width: 1px;
                    border-radius: 7px;
                    clip: true;

                    VerticalLayout {
                        padding: 4px;
                        spacing: 1px;

                        SettingsOptionButton { width: 140px; label: tr-name; key: "name"; selected: settings-sort-key == "name"; activated(key) => { choose-settings-sort(key); sort-menu-open = false; } }
                        SettingsOptionButton { width: 140px; label: tr-sort-modified; key: "modified"; selected: settings-sort-key == "modified" || settings-sort-key == "date"; activated(key) => { choose-settings-sort(key); sort-menu-open = false; } }
                        SettingsOptionButton { width: 140px; label: tr-sort-added; key: "added"; selected: settings-sort-key == "added"; activated(key) => { choose-settings-sort(key); sort-menu-open = false; } }
                        SettingsOptionButton { width: 140px; label: tr-format; key: "format"; selected: settings-sort-key == "format"; activated(key) => { choose-settings-sort(key); sort-menu-open = false; } }
                        SettingsOptionButton { width: 140px; label: tr-triangles; key: "triangles"; selected: settings-sort-key == "triangles"; activated(key) => { choose-settings-sort(key); sort-menu-open = false; } }
                        SettingsOptionButton { width: 140px; label: tr-dimensions; key: "dimensions"; selected: settings-sort-key == "dimensions"; activated(key) => { choose-settings-sort(key); sort-menu-open = false; } }
                        SettingsOptionButton { width: 140px; label: tr-volume-est; key: "volume"; selected: settings-sort-key == "volume"; activated(key) => { choose-settings-sort(key); sort-menu-open = false; } }
                        SettingsOptionButton { width: 140px; label: tr-file-size; key: "size"; selected: settings-sort-key == "size"; activated(key) => { choose-settings-sort(key); sort-menu-open = false; } }
                    }
                }
            }

            if right-detail-open: Rectangle {
                width: 6px;
                background: right-resize-touch.has-hover || right-detail-resizing ? Theme.accent-dim : Theme.bg-2;

                Rectangle {
                    x: 3px;
                    y: 0;
                    width: 1px;
                    height: parent.height;
                    background: right-resize-touch.has-hover || right-detail-resizing ? Theme.accent : Theme.line;
                }

                right-resize-touch := TouchArea {
                    mouse-cursor: ew-resize;
                    pointer-event(event) => {
                        if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                            right-detail-resizing = true;
                            resize-origin-x = right-resize-touch.absolute-position.x - root.absolute-position.x + right-resize-touch.mouse-x;
                            resize-start-width = right-detail-width;
                        } else if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                            right-detail-resizing = false;
                        } else if (event.kind == PointerEventKind.cancel) {
                            right-detail-resizing = false;
                        } else if (event.kind == PointerEventKind.move && right-detail-resizing) {
                            right-detail-width = min(right-detail-max-width, max(right-detail-min-width, resize-start-width - ((right-resize-touch.absolute-position.x - root.absolute-position.x + right-resize-touch.mouse-x) - resize-origin-x)));
                        }
                    }
                }
            }

            // ─── Detail panel ───
            Rectangle {
                width: visible-right-detail-width;
                background: Theme.bg-1;
                clip: true;
                animate width { duration: right-detail-resizing ? 0ms : 180ms; easing: ease-in-out; }

                Rectangle {
                    x: 0;
                    y: 0;
                    width: 1px;
                    height: parent.height;
                    background: Theme.line;
                }

                if right-detail-open && !has-selection: VerticalLayout {
                    alignment: center;
                    spacing: 8px;

                    Rectangle {
                        width: 36px;
                        height: 36px;
                        x: (parent.width - self.width) / 2;
                        border-color: Theme.line-3;
                        border-width: 1px;
                        border-radius: 8px;
                        background: transparent;

                            SvgIcon {
                                x: (parent.width - 16px) / 2;
                                y: (parent.height - 16px) / 2;
                                width: 16px;
                                height: 16px;
                                icon: @image-url("../assets/icons/box.svg");
                                tint: Theme.fg-3;
                            }
                    }

                    Text {
                        text: settings-language-key == "ko" ? "모델 선택" : settings-language-key == "ja" ? "モデルを選択" : "Select a model";
                        color: Theme.fg-1;
                        font-size: Theme.font-body;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: settings-language-key == "ko" ? "썸네일을 클릭하면 상세 정보를 봅니다" : settings-language-key == "ja" ? "サムネイルをクリックして詳細を表示" : "Click a thumbnail to view details";
                        color: Theme.fg-2;
                        font-size: Theme.font-meta;
                        horizontal-alignment: center;
                    }
                }

                if right-detail-open && has-selection: VerticalLayout {
                    // Preview area
                    Rectangle {
                        height: 280px;
                        background: Theme.bg-0;

                        Rectangle {
                            x: 0;
                            y: parent.height - 1px;
                            width: parent.width;
                            height: 1px;
                            background: Theme.line;
                        }

                        CachedThumb {
                            x: 0;
                            y: 0;
                            width: parent.width;
                            height: parent.height;
                            thumb-key: selected-thumb-key;
                            cached-image: selected-thumb-image;
                            thumb-ready: selected-thumb-ready;
                        }

                        preview-drag := TouchArea {
                            width: parent.width;
                            height: parent.height;
                            pointer-event(event) => {
                                if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                                    preview-dragging = true;
                                    preview-last-x = preview-drag.mouse-x;
                                    preview-last-y = preview-drag.mouse-y;
                                } else if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                                    preview-dragging = false;
                                } else if (event.kind == PointerEventKind.cancel) {
                                    preview-dragging = false;
                                } else if (event.kind == PointerEventKind.move && preview-dragging) {
                                    preview-orbit((preview-drag.mouse-x - preview-last-x) / 1px, (preview-drag.mouse-y - preview-last-y) / 1px);
                                    preview-last-x = preview-drag.mouse-x;
                                    preview-last-y = preview-drag.mouse-y;
                                }
                            }
                            double-clicked => {
                                preview-orbit-reset();
                            }
                        }

                        if detail-has-plates: PlateDropdown {
                            x: 8px;
                            y: 8px;
                            z: 20;
                            current-label: detail-plate-selected-label;
                            open: preview-plate-menu-open;
                            tabs: detail-plate-tabs;
                            toggled => {
                                preview-plate-menu-open = !preview-plate-menu-open;
                            }
                            activated(idx) => {
                                choose-preview-plate(idx);
                                preview-plate-menu-open = false;
                            }
                            dismissed => {
                                preview-plate-menu-open = false;
                            }
                        }

                        HorizontalLayout {
                            x: parent.width - 60px;
                            y: 8px;
                            z: 20;
                            spacing: 4px;

                            Rectangle {
                                width: 24px; height: 24px;
                                background: reset-preview.has-hover ? Theme.bg-3 : Theme.bg-2;
                                border-color: Theme.line-2;
                                border-width: 1px;
                                border-radius: 4px;
                                SvgIcon { x: (parent.width - 13px) / 2; y: (parent.height - 13px) / 2; width: 13px; height: 13px; icon: @image-url("../assets/icons/rotate.svg"); tint: Theme.fg-1; }
                                reset-preview := TouchArea {
                                    clicked => {
                                        preview-orbit-reset();
                                    }
                                }
                            }
                            Rectangle {
                                width: 24px; height: 24px;
                                background: fullscreen-preview.has-hover ? Theme.bg-3 : Theme.bg-2;
                                border-color: Theme.line-2;
                                border-width: 1px;
                                border-radius: 4px;
                                SvgIcon { x: (parent.width - 13px) / 2; y: (parent.height - 13px) / 2; width: 13px; height: 13px; icon: @image-url("../assets/icons/fullscreen.svg"); tint: Theme.fg-1; }
                                fullscreen-preview := TouchArea {
                                    clicked => {
                                        preview-fullscreen-open = true;
                                    }
                                }
                            }
                        }

                        // Axis labels
                        HorizontalLayout {
                            x: 8px;
                            y: parent.height - 24px;
                            spacing: 4px;

                            Rectangle {
                                width: 18px; height: 16px;
                                background: Theme.bg-2;
                                border-color: Theme.line-2;
                                border-width: 1px;
                                border-radius: 2px;
                                Text { x: 5px; y: 2px; text: "X"; color: #c95040; font-family: "JetBrains Mono"; font-size: 10px; }
                            }
                            Rectangle {
                                width: 18px; height: 16px;
                                background: Theme.bg-2;
                                border-color: Theme.line-2;
                                border-width: 1px;
                                border-radius: 2px;
                                Text { x: 5px; y: 2px; text: "Y"; color: #5fb87a; font-family: "JetBrains Mono"; font-size: 10px; }
                            }
                            Rectangle {
                                width: 18px; height: 16px;
                                background: Theme.bg-2;
                                border-color: Theme.line-2;
                                border-width: 1px;
                                border-radius: 2px;
                                Text { x: 5px; y: 2px; text: "Z"; color: #5fb8d4; font-family: "JetBrains Mono"; font-size: 10px; }
                            }
                        }

                        Text {
                            x: parent.width - self.width - 8px;
                            y: parent.height - 20px;
                            text: tr-orbit-hint;
                            color: Theme.fg-3;
                            font-family: "JetBrains Mono";
                            font-size: 10px;
                        }
                    }

                    // Scrollable detail sections
                    ScrollView {
                        VerticalLayout {
                            padding: 16px;
                            padding-top: 14px;
                            padding-bottom: 28px;
                            spacing: 2px;

                            // Title + path
                            if !rename-editing: Text {
                                text: detail-name;
                                color: Theme.fg-0;
                                font-size: Theme.font-heading;
                                font-weight: 600;
                                wrap: word-wrap;
                            }

                            if rename-editing: LineEdit {
                                height: 32px;
                                text: rename-draft;
                                font-size: Theme.font-heading;
                                accepted(text) => {
                                    if rename-model(text) {
                                        rename-editing = false;
                                        shortcut-scope.focus();
                                    }
                                }
                                init => {
                                    self.focus();
                                    self.select-all();
                                }
                            }

                            Text {
                                text: detail-path;
                                color: Theme.fg-2;
                                font-family: "JetBrains Mono";
                                font-size: Theme.font-overline;
                                wrap: word-wrap;
                            }

                            // Actions
                            HorizontalLayout {
                                spacing: 6px;
                                height: slicer-menu-open ? min(340px, 40px * settings-slicer-candidates.length + 108px) : 48px;
                                alignment: start;

                                Rectangle {
                                    width: 224px;
                                    height: 28px;
                                    z: 100;

                                    Rectangle {
                                        x: 0;
                                        y: 0;
                                        width: parent.width - 27px;
                                        height: 28px;
                                        background: ta-slicer.has-hover ? #6fc8e0 : Theme.accent;
                                        border-radius: Theme.radius-btn;

                                        slicer-text := Text {
                                            x: 26px;
                                            y: (parent.height - self.height) / 2;
                                            width: parent.width - self.x - 10px;
                                            text: settings-slicer-label == "System default STL opener" ? tr-open-in-slicer : tr-open-with-prefix + settings-slicer-label + tr-open-with-suffix;
                                            color: #0e2a32;
                                            font-size: Theme.font-body;
                                            font-weight: 500;
                                            overflow: elide;
                                        }

                                        if settings-slicer-icon-ready: Image {
                                            x: 8px;
                                            y: (parent.height - 16px) / 2;
                                            width: 16px;
                                            height: 16px;
                                            source: settings-slicer-icon-image;
                                            image-fit: contain;
                                        }

                                        if !settings-slicer-icon-ready: SvgIcon {
                                            x: 9px;
                                            y: (parent.height - 13px) / 2;
                                            width: 13px;
                                            height: 13px;
                                            icon: @image-url("../assets/icons/slicer.svg");
                                            tint: #0e2a32;
                                        }

                                        ta-slicer := TouchArea { clicked => { open-in-slicer(); } }
                                    }

                                    Rectangle {
                                        x: parent.width - 28px;
                                        y: 0;
                                        width: 28px;
                                        height: 28px;
                                        background: ta-slicer-caret.has-hover ? #6fc8e0 : Theme.accent;
                                        border-radius: Theme.radius-btn;

                                        Rectangle {
                                            x: 0;
                                            y: 5px;
                                            width: 1px;
                                            height: parent.height - 10px;
                                            background: #0e2a3233;
                                        }

                                        SvgIcon {
                                            x: (parent.width - 10px) / 2;
                                            y: (parent.height - 10px) / 2;
                                            width: 10px;
                                            height: 10px;
                                            icon: @image-url("../assets/icons/chevron-right.svg");
                                            tint: #0e2a32;
                                            transform-origin: { x: 5px, y: 5px };
                                            transform-rotation: slicer-menu-open ? -90deg : 90deg;
                                        }

                                        ta-slicer-caret := TouchArea {
                                            clicked => { slicer-menu-open = !slicer-menu-open; }
                                        }
                                    }

                                    if slicer-menu-open: TouchArea {
                                        x: -3000px;
                                        y: -3000px;
                                        width: 7000px;
                                        height: 7000px;
                                        z: 150;
                                        clicked => { slicer-menu-open = false; }
                                    }

                                    if slicer-menu-open: Rectangle {
                                        x: 0;
                                        y: parent.height + 5px;
                                        width: 280px;
                                        height: 40px * settings-slicer-candidates.length + 64px;
                                        z: 200;
                                        background: #202329;
                                        border-color: Theme.line-3;
                                        border-width: 1px;
                                        border-radius: 8px;

                                        VerticalLayout {
                                            padding: 4px;
                                            spacing: 1px;

                                            Text {
                                                height: 24px;
                                                text: tr-open-with-menu;
                                                color: Theme.fg-3;
                                                font-size: Theme.font-overline;
                                                font-weight: 600;
                                                letter-spacing: 0.6px;
                                            }

                                            for candidate in settings-slicer-candidates: SlicerMenuItem {
                                                label: candidate.label;
                                                detail: candidate.detail;
                                                icon-image: candidate.icon-image;
                                                icon-ready: candidate.icon-ready;
                                                selected: candidate.selected;
                                                activated => {
                                                    choose-settings-slicer(candidate.path);
                                                    slicer-menu-open = false;
                                                }
                                            }

                                            Rectangle {
                                                height: 1px;
                                                background: Theme.line;
                                            }

                                            ContextMenuItem {
                                                label: tr-choose-another-slicer;
                                                hint: "";
                                                icon: @image-url("../assets/icons/plus.svg");
                                                activated => {
                                                    slicer-menu-open = false;
                                                    choose-slicer();
                                                }
                                            }
                                        }
                                    }
                                }

                                Rectangle {
                                    width: 28px; height: 28px;
                                    background: ta-printed.has-hover ? Theme.bg-3 : Theme.bg-1;
                                    border-color: Theme.line;
                                    border-width: 1px;
                                    border-radius: Theme.radius-btn;

                                    SvgIcon {
                                        x: (parent.width - 14px) / 2;
                                        y: (parent.height - 14px) / 2;
                                        width: 14px;
                                        height: 14px;
                                        icon: @image-url("../assets/icons/print.svg");
                                        tint: Theme.fg-2;
                                    }

                                    ta-printed := TouchArea {}
                                }

                                Rectangle {
                                    width: 28px; height: 28px;
                                    background: ta-fav.has-hover ? Theme.bg-3 : Theme.bg-1;
                                    border-color: Theme.line;
                                    border-width: 1px;
                                    border-radius: Theme.radius-btn;

                                    SvgIcon {
                                        x: (parent.width - 14px) / 2;
                                        y: (parent.height - 14px) / 2;
                                        width: 14px;
                                        height: 14px;
                                        icon: @image-url("../assets/icons/star.svg");
                                        tint: detail-fav ? #d4a84f : Theme.fg-2;
                                    }

                                    ta-fav := TouchArea { clicked => { toggle-favorite(); } }
                                }
                            }

                            // Geometry section
                            SectionHeader { label: tr-geometry; }
                            DetailKV { label: tr-format; value: detail-format; }
                            DetailKV { label: tr-triangles; value: detail-tris; }
                            DetailKV { label: tr-dimensions; value: detail-dims; }
                            DetailKV { label: tr-volume-est; value: detail-volume; }
                            DetailKV { label: tr-file-size; value: detail-filesize; }

                            // Mesh health
                            Rectangle {
                                height: 24px;

                                Text {
                                    x: 0px;
                                    y: (parent.height - self.height) / 2;
                                    text: tr-mesh-health;
                                    color: Theme.fg-2;
                                    font-size: Theme.font-overline;
                                    font-weight: 600;
                                    letter-spacing: 0.8px;
                                }

                                Rectangle {
                                    x: parent.width - self.width;
                                    y: (parent.height - self.height) / 2;
                                    width: health-score.width + 12px;
                                    height: 18px;
                                    background: Theme.success;
                                    border-radius: 9px;

                                    health-score := Text {
                                        x: 6px;
                                        y: (parent.height - self.height) / 2;
                                        text: detail-health-score + "/100";
                                        color: #0e2618;
                                        font-family: "JetBrains Mono";
                                        font-size: 10px;
                                        font-weight: 600;
                                    }
                                }
                            }

                            Rectangle {
                                height: 44px;

                                Text {
                                    x: 0px;
                                    y: 0px;
                                    width: (parent.width - 10px) / 2;
                                    text: (detail-manifold ? "✓ " : "✗ ") + tr-manifold;
                                    color: detail-manifold ? Theme.success : Theme.error;
                                    font-size: 12px;
                                }

                                Text {
                                    x: (parent.width + 10px) / 2;
                                    y: 0px;
                                    width: (parent.width - 10px) / 2;
                                    text: (detail-watertight ? "✓ " : "✗ ") + tr-watertight;
                                    color: detail-watertight ? Theme.success : Theme.warn;
                                    font-size: 12px;
                                }

                                Text {
                                    x: 0px;
                                    y: 22px;
                                    width: (parent.width - 10px) / 2;
                                    text: (detail-normals ? "✓ " : "✗ ") + tr-normals;
                                    color: detail-normals ? Theme.success : Theme.warn;
                                    font-size: 12px;
                                }
                            }

                            // Print estimate
                            if detail-estimate-time != "": Rectangle {
                                height: estimate-printer-menu-open && detail-estimate-has-printer-choices ? 34px + min(178px, detail-estimate-printers.length * 36px) : 30px;

                                Text {
                                    x: 0px;
                                    y: 8px;
                                    text: tr-print-estimate;
                                    color: Theme.fg-2;
                                    font-size: Theme.font-overline;
                                    font-weight: 600;
                                    letter-spacing: 0.8px;
                                }

                                if detail-estimate-has-printer-choices: EstimatePrinterDropdown {
                                    x: parent.width - self.width;
                                    y: 2px;
                                    z: 30;
                                    current-label: detail-estimate-printer-label;
                                    open: estimate-printer-menu-open;
                                    printers: detail-estimate-printers;
                                    toggled => {
                                        estimate-printer-menu-open = !estimate-printer-menu-open;
                                    }
                                    activated(key) => {
                                        choose-estimate-printer(key);
                                        estimate-printer-menu-open = false;
                                    }
                                    dismissed => {
                                        estimate-printer-menu-open = false;
                                    }
                                }
                            }
                            if detail-estimate-time != "": HorizontalLayout {
                                spacing: 8px;
                                height: 60px;

                                Rectangle {
                                    horizontal-stretch: 1;
                                    background: Theme.bg-3;
                                    border-color: Theme.line;
                                    border-width: 1px;
                                    border-radius: 6px;

                                    VerticalLayout {
                                        padding: 8px;
                                        Text { text: tr-time; color: Theme.fg-2; font-size: Theme.font-overline; }
                                        Text { text: detail-estimate-time; color: Theme.fg-0; font-size: 16px; font-weight: 600; }
                                    }
                                }
                                Rectangle {
                                    horizontal-stretch: 1;
                                    background: Theme.bg-3;
                                    border-color: Theme.line;
                                    border-width: 1px;
                                    border-radius: 6px;

                                    VerticalLayout {
                                        padding: 8px;
                                        Text { text: tr-filament; color: Theme.fg-2; font-size: Theme.font-overline; }
                                        Text { text: detail-estimate-grams; color: Theme.fg-0; font-size: 16px; font-weight: 600; }
                                    }
                                }
                                Rectangle {
                                    horizontal-stretch: 1;
                                    background: Theme.bg-3;
                                    border-color: Theme.line;
                                    border-width: 1px;
                                    border-radius: 6px;

                                    VerticalLayout {
                                        padding: 8px;
                                        Text { text: tr-layers; color: Theme.fg-2; font-size: Theme.font-overline; }
                                        Text { text: detail-estimate-layers; color: Theme.fg-0; font-size: 16px; font-weight: 600; }
                                    }
                                }
                            }
                            if detail-estimate-time != "": Rectangle {
                                height: 28px;
                                background: detail-bed-fit ? Theme.accent-dim : #d4a84f24;
                                border-color: detail-bed-fit ? Theme.accent-line : #d4a84f59;
                                border-width: 1px;
                                border-radius: Theme.radius-btn;

                                Text {
                                    x: 10px;
                                    y: (parent.height - self.height) / 2;
                                    text: (detail-bed-fit ? "✓ " : "⚠ ") + (detail-bed-fit ? tr-fits-build-plate : tr-exceeds-build-plate);
                                    color: detail-bed-fit ? Theme.success : Theme.warn;
                                    font-size: 11.5px;
                                    font-weight: 500;
                                }

                                Text {
                                    x: parent.width - self.width - 10px;
                                    y: (parent.height - self.height) / 2;
                                    text: detail-estimate-printer-detail;
                                    color: Theme.fg-3;
                                    font-family: "JetBrains Mono";
                                    font-size: 9.5px;
                                }
                            }

                            SectionHeader { label: tr-tags-heading; }
                            Rectangle {
                                height: detail-tag-chips.length == 0 ? 28px : detail-tag-chips.length * 30px;

                                if detail-tag-chips.length == 0: Text {
                                    x: 0;
                                    y: 5px;
                                    text: tr-no-tags;
                                    color: Theme.fg-2;
                                    font-size: 11.5px;
                                }

                                VerticalLayout {
                                    spacing: 6px;

                                    for tag[index] in detail-tag-chips: Rectangle {
                                        height: 24px;
                                        background: Theme.bg-3;
                                        border-color: Theme.line;
                                        border-width: 1px;
                                        border-radius: 12px;

                                        Text {
                                            x: 10px;
                                            y: (parent.height - self.height) / 2;
                                            width: parent.width - 34px;
                                            text: tag.label;
                                            color: Theme.fg-1;
                                            font-size: 11.5px;
                                            font-family: "JetBrains Mono";
                                            overflow: elide;
                                        }

                                        Rectangle {
                                            x: parent.width - 24px;
                                            y: 2px;
                                            width: 20px;
                                            height: 20px;
                                            background: remove-tag-touch.has-hover ? Theme.bg-4 : Theme.bg-3;
                                            border-radius: 10px;

                                            Text {
                                                x: (parent.width - self.width) / 2;
                                                y: (parent.height - self.height) / 2;
                                                text: "×";
                                                color: Theme.fg-2;
                                                font-size: 12px;
                                            }

                                            remove-tag-touch := TouchArea { clicked => { remove-tag(index); } }
                                        }
                                    }
                                }
                            }

                            Rectangle {
                                height: 30px;

                                add-tag-edit := ThemedLineEdit {
                                    x: 0;
                                    y: 0;
                                    width: parent.width - 58px;
                                    height: 28px;
                                    placeholder-text: tr-add-tag;
                                    font-size: 12px;
                                    accepted(text) => {
                                        add-tags(text);
                                        self.text = "";
                                    }
                                }

                                Rectangle {
                                    x: parent.width - 50px;
                                    y: 1px;
                                    width: 50px;
                                    height: 26px;
                                    background: add-tag-touch.has-hover ? Theme.accent : Theme.bg-4;
                                    border-color: Theme.line;
                                    border-width: 1px;
                                    border-radius: Theme.radius-btn;

                                    Text {
                                        x: (parent.width - self.width) / 2;
                                        y: (parent.height - self.height) / 2;
                                        text: tr-add;
                                        color: Theme.fg-0;
                                        font-size: 12px;
                                        font-weight: 600;
                                    }

                                    add-tag-touch := TouchArea {
                                        clicked => {
                                            add-tags(add-tag-edit.text);
                                            add-tag-edit.text = "";
                                        }
                                    }
                                }
                            }

                            tags-edit := ThemedLineEdit {
                                height: 30px;
                                text: detail-tags-input;
                                placeholder-text: tr-bulk-edit-placeholder;
                                font-size: 12px;
                                accepted(text) => { save-metadata(text, author-edit.text, notes-edit.text); }
                            }

                            SectionHeader { label: tr-prints-heading; }
                            Rectangle {
                                height: 30px;

                                Text {
                                    x: 0;
                                    y: (parent.height - self.height) / 2;
                                    text: tr-printed-prefix + detail-printed-count + tr-printed-suffix;
                                    color: Theme.fg-1;
                                    font-size: 12px;
                                }

                                Rectangle {
                                    x: parent.width - 64px;
                                    y: 3px;
                                    width: 28px;
                                    height: 24px;
                                    background: minus-print.has-hover ? Theme.bg-4 : Theme.bg-3;
                                    border-color: Theme.line;
                                    border-width: 1px;
                                    border-radius: Theme.radius-btn;

                                    Text {
                                        x: (parent.width - self.width) / 2;
                                        y: (parent.height - self.height) / 2;
                                        text: "−";
                                        color: Theme.fg-1;
                                        font-size: 14px;
                                    }

                                    minus-print := TouchArea { clicked => { adjust-printed-count(-1); } }
                                }

                                Rectangle {
                                    x: parent.width - 30px;
                                    y: 3px;
                                    width: 28px;
                                    height: 24px;
                                    background: plus-print.has-hover ? Theme.bg-4 : Theme.bg-3;
                                    border-color: Theme.line;
                                    border-width: 1px;
                                    border-radius: Theme.radius-btn;

                                    Text {
                                        x: (parent.width - self.width) / 2;
                                        y: (parent.height - self.height) / 2;
                                        text: "+";
                                        color: Theme.fg-1;
                                        font-size: 14px;
                                    }

                                    plus-print := TouchArea { clicked => { adjust-printed-count(1); } }
                                }
                            }

                            if detail-printed-count > 0: Rectangle {
                                height: 30px;

                                Text {
                                    x: 0;
                                    y: (parent.height - self.height) / 2;
                                    width: 82px;
                                    text: tr-history;
                                    color: Theme.fg-2;
                                    font-family: "JetBrains Mono";
                                    font-size: 10.5px;
                                }

                                Text {
                                    x: 92px;
                                    y: (parent.height - self.height) / 2;
                                    text: detail-print-history.length + tr-records-suffix;
                                    color: Theme.fg-0;
                                    font-size: 11.5px;
                                }
                            }

                            Rectangle {
                                height: detail-print-history.length == 0 ? 28px : detail-print-history.length * 62px;

                                if detail-print-history.length == 0: Text {
                                    x: 0;
                                    y: 5px;
                                    text: tr-no-print-records;
                                    color: Theme.fg-2;
                                    font-size: 11.5px;
                                }

                                VerticalLayout {
                                    spacing: 6px;

                                    for record[index] in detail-print-history: Rectangle {
                                        height: 56px;
                                        background: Theme.bg-2;
                                        border-color: Theme.line;
                                        border-width: 1px;
                                        border-radius: 6px;

                                        Rectangle {
                                            x: 10px;
                                            y: 18px;
                                            width: 7px;
                                            height: 7px;
                                            border-radius: 4px;
                                            background: record.success ? Theme.success : Theme.warn;
                                        }

                                        Text {
                                            x: 26px;
                                            y: 7px;
                                            width: parent.width - 62px;
                                            text: record.date + " · " + (record.material == "" ? tr-material-unknown : record.material);
                                            color: Theme.fg-0;
                                            font-size: 11.5px;
                                            font-family: "JetBrains Mono";
                                            overflow: elide;
                                        }

                                        Text {
                                            x: 26px;
                                            y: 24px;
                                            width: parent.width - 62px;
                                            text: (record.printer == "" ? tr-printer-unknown : record.printer) + " · "
                                                 + (record.profile == "" ? tr-profile-unknown : record.profile) + " · "
                                                 + (record.nozzle == "" ? tr-nozzle-unknown : record.nozzle) + " · "
                                                 + (record.layer-height == "" ? tr-layer-unknown : record.layer-height)
                                                + (record.duration == "" ? "" : " · " + record.duration);
                                            color: Theme.fg-1;
                                            font-size: 10.5px;
                                            overflow: elide;
                                        }

                                        Text {
                                            x: 26px;
                                            y: 39px;
                                            width: parent.width - 62px;
                                            text: record.notes == "" ? tr-no-notes : record.notes;
                                            color: Theme.fg-2;
                                            font-size: 10.5px;
                                            overflow: elide;
                                        }

                                        Rectangle {
                                            x: parent.width - 28px;
                                            y: 9px;
                                            width: 22px;
                                            height: 24px;
                                            background: remove-print.has-hover ? Theme.bg-4 : Theme.bg-2;
                                            border-radius: Theme.radius-btn;

                                            Text {
                                                x: (parent.width - self.width) / 2;
                                                y: (parent.height - self.height) / 2;
                                                text: "×";
                                                color: Theme.fg-2;
                                                font-size: 14px;
                                            }

                                            remove-print := TouchArea { clicked => { remove-print-record(index); } }
                                        }
                                    }
                                }
                            }

                            Rectangle {
                                height: 94px;

                                material-edit := ThemedLineEdit {
                                    x: 0;
                                    y: 0;
                                    width: 82px;
                                    height: 28px;
                                    placeholder-text: "PLA";
                                    font-size: 12px;
                                }

                                printer-edit := ThemedLineEdit {
                                    x: 90px;
                                    y: 0;
                                    width: parent.width - 150px;
                                    height: 28px;
                                    placeholder-text: tr-printer-placeholder;
                                    font-size: 12px;
                                }

                                Rectangle {
                                    x: parent.width - 60px;
                                    y: 1px;
                                    width: 60px;
                                    height: 26px;
                                    background: add-print.has-hover ? Theme.accent : Theme.bg-4;
                                    border-color: Theme.line;
                                    border-width: 1px;
                                    border-radius: Theme.radius-btn;

                                    Text {
                                        x: (parent.width - self.width) / 2;
                                        y: (parent.height - self.height) / 2;
                                        text: tr-add;
                                        color: Theme.fg-0;
                                        font-size: 12px;
                                        font-weight: 600;
                                    }

                                    add-print := TouchArea {
                                        clicked => {
                                            add-print-record(material-edit.text, printer-edit.text, profile-edit.text, nozzle-edit.text, layer-edit.text, duration-edit.text, print-note-edit.text);
                                            material-edit.text = "";
                                            printer-edit.text = "";
                                            profile-edit.text = "";
                                            nozzle-edit.text = "";
                                            layer-edit.text = "";
                                            duration-edit.text = "";
                                            print-note-edit.text = "";
                                        }
                                    }
                                }

                                profile-edit := ThemedLineEdit {
                                    x: 0;
                                    y: 32px;
                                    width: parent.width - 186px;
                                    height: 28px;
                                    placeholder-text: tr-profile-placeholder;
                                    font-size: 12px;
                                }

                                nozzle-edit := ThemedLineEdit {
                                    x: parent.width - 178px;
                                    y: 32px;
                                    width: 54px;
                                    height: 28px;
                                    placeholder-text: "0.4";
                                    font-size: 12px;
                                }

                                layer-edit := ThemedLineEdit {
                                    x: parent.width - 116px;
                                    y: 32px;
                                    width: 54px;
                                    height: 28px;
                                    placeholder-text: "0.2";
                                    font-size: 12px;
                                }

                                duration-edit := ThemedLineEdit {
                                    x: parent.width - 54px;
                                    y: 32px;
                                    width: 54px;
                                    height: 28px;
                                    placeholder-text: "2h";
                                    font-size: 12px;
                                }

                                print-note-edit := ThemedLineEdit {
                                    x: 0;
                                    y: 64px;
                                    width: parent.width;
                                    height: 28px;
                                    placeholder-text: tr-result-notes;
                                    font-size: 12px;
                                }
                            }

                            SectionHeader { label: tr-notes-heading; }
                            notes-edit := ThemedTextEdit {
                                height: 72px;
                                text: detail-notes == "Add notes..." ? "" : detail-notes;
                                placeholder-text: tr-add-notes;
                                font-size: 12px;
                                wrap: word-wrap;
                            }

                            SectionHeader { label: tr-author-heading; }
                            author-edit := ThemedLineEdit {
                                height: 30px;
                                text: detail-author;
                                placeholder-text: tr-author-or-source;
                                font-size: 12px;
                                accepted(text) => { save-metadata(tags-edit.text, text, notes-edit.text); }
                            }

                            Rectangle {
                                height: 30px;

                                Rectangle {
                                    x: parent.width - 66px;
                                    y: 2px;
                                    width: 66px;
                                    height: 26px;
                                    background: save-meta.has-hover ? Theme.accent : Theme.bg-4;
                                    border-color: Theme.line;
                                    border-width: 1px;
                                    border-radius: Theme.radius-btn;

                                    Text {
                                        x: (parent.width - self.width) / 2;
                                        y: (parent.height - self.height) / 2;
                                        text: tr-save;
                                        color: Theme.fg-0;
                                        font-size: 12px;
                                        font-weight: 600;
                                    }

                                    save-meta := TouchArea {
                                        clicked => {
                                            save-metadata(tags-edit.text, author-edit.text, notes-edit.text);
                                        }
                                    }
                                }
                            }

                            // File section
                            SectionHeader { label: tr-file-heading; }
                            DetailKV { label: "Hash (b3)"; value: detail-hash; }
                            DetailKV { label: tr-modified; value: detail-modified; }
                            DetailKV { label: tr-added; value: detail-added; }
                            DetailKV { label: tr-author; value: detail-author; }
                        }
                    }
                }
            }
        }
    }

    preview-stage := Rectangle {
        z: 260;
        x: preview-fullscreen-open ? visible-left-sidebar-width + 16px : parent.width - visible-right-detail-width;
        y: preview-fullscreen-open ? Theme.titlebar-height + 16px : Theme.titlebar-height;
        width: preview-fullscreen-open ? parent.width - visible-left-sidebar-width - visible-right-detail-width - 32px : visible-right-detail-width;
        height: preview-fullscreen-open ? parent.height - Theme.titlebar-height - 32px : 280px;
        opacity: preview-fullscreen-open ? 1 : 0;
        background: #05080bf0;
        border-color: Theme.line-3;
        border-width: preview-fullscreen-open ? 1px : 0px;
        border-radius: preview-fullscreen-open ? 14px : 0px;
        animate x { duration: 220ms; easing: ease-in-out; }
        animate y { duration: 220ms; easing: ease-in-out; }
        animate width { duration: 220ms; easing: ease-in-out; }
        animate height { duration: 220ms; easing: ease-in-out; }
        animate opacity { duration: 160ms; easing: ease-in-out; }
        animate border-radius { duration: 220ms; easing: ease-in-out; }

        CachedThumb {
            x: preview-fullscreen-open ? 28px : 0px;
            y: preview-fullscreen-open ? 44px : 0px;
            width: preview-fullscreen-open ? parent.width - 56px : parent.width;
            height: preview-fullscreen-open ? parent.height - 88px : parent.height;
            thumb-key: selected-thumb-key;
            cached-image: selected-thumb-image;
            thumb-ready: selected-thumb-ready;
            animate x { duration: 220ms; easing: ease-in-out; }
            animate y { duration: 220ms; easing: ease-in-out; }
            animate width { duration: 220ms; easing: ease-in-out; }
            animate height { duration: 220ms; easing: ease-in-out; }
        }

        if preview-fullscreen-open: fs-preview-drag := TouchArea {
            x: 28px;
            y: 44px;
            width: parent.width - 56px;
            height: parent.height - 88px;
            pointer-event(event) => {
                if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                    preview-dragging = true;
                    preview-last-x = fs-preview-drag.mouse-x;
                    preview-last-y = fs-preview-drag.mouse-y;
                } else if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                    preview-dragging = false;
                } else if (event.kind == PointerEventKind.cancel) {
                    preview-dragging = false;
                } else if (event.kind == PointerEventKind.move && preview-dragging) {
                    preview-orbit((fs-preview-drag.mouse-x - preview-last-x) / 1px, (fs-preview-drag.mouse-y - preview-last-y) / 1px);
                    preview-last-x = fs-preview-drag.mouse-x;
                    preview-last-y = fs-preview-drag.mouse-y;
                }
            }
            double-clicked => {
                preview-orbit-reset();
            }
        }

        if preview-fullscreen-open && detail-has-plates: PlateDropdown {
            x: 42px;
            y: 58px;
            z: 20;
            current-label: detail-plate-selected-label;
            open: preview-plate-menu-open;
            tabs: detail-plate-tabs;
            toggled => {
                preview-plate-menu-open = !preview-plate-menu-open;
            }
            activated(idx) => {
                choose-preview-plate(idx);
                preview-plate-menu-open = false;
            }
            dismissed => {
                preview-plate-menu-open = false;
            }
        }

        if preview-fullscreen-open: Text {
            x: 28px;
            y: 18px;
            text: detail-name;
            color: Theme.fg-0;
            font-size: 14px;
            font-weight: 700;
        }

        if preview-fullscreen-open: Text {
            x: parent.width - self.width - 68px;
            y: parent.height - 30px;
            text: tr-fullscreen-orbit-hint;
            color: Theme.fg-3;
            font-family: "JetBrains Mono";
            font-size: 11px;
        }

        if preview-fullscreen-open: Rectangle {
            x: parent.width - 42px;
            y: 14px;
            width: 28px;
            height: 28px;
            background: close-fullscreen-preview.has-hover ? #ffffff24 : #00000080;
            border-color: Theme.line;
            border-width: 1px;
            border-radius: 6px;

            Text {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2 - 1px;
                text: "×";
                color: Theme.fg-1;
                font-size: 18px;
            }

            close-fullscreen-preview := TouchArea {
                clicked => {
                    preview-fullscreen-open = false;
                    preview-dragging = false;
                }
            }
        }
    }

    if sidebar-context-open: SidebarContextMenu {
        x: sidebar-context-x + self.width > parent.width - 8px ? parent.width - self.width - 8px : sidebar-context-x;
        y: sidebar-context-y + self.height > parent.height - 8px ? parent.height - self.height - 8px : sidebar-context-y;
        target-label: sidebar-context-label;
        target-is-folder: sidebar-context-is-folder;
        filter-folder-label: tr-filter-this-folder;
        filter-tag-label: tr-filter-this-tag;
        remove-library-label: tr-remove-from-library;
        reveal-finder-label: tr-reveal-in-finder;
        rescan-folder-label: tr-rescan-folder;
        delete-folder-label: tr-delete-folder;
        copy-path-label: tr-copy-path;
        copy-tag-label: tr-copy-tag;
        action(action) => {
            shortcut-scope.focus();
            sidebar-context-open = false;
            sidebar-context-action(action, sidebar-context-key, sidebar-context-label);
        }
    }

    if model-context-open: ModelContextMenu {
        z: 520;
        menu-width: model-context-menu-width;
        menu-height: model-context-menu-height;
        x: min(parent.width - model-context-menu-width - 8px, max(8px, model-context-x));
        y: min(parent.height - model-context-menu-height - 8px, max(Theme.titlebar-height + 8px, model-context-y));
        target-label: model-context-label;
        favorite: model-context-favorite;
        printed-count: model-context-printed-count;
        rename-label: tr-rename-model;
        open-label: tr-open-in-slicer;
        reveal-label: tr-reveal-in-finder;
        details-label: tr-show-details;
        add-favorite-label: tr-add-favorite;
        remove-favorite-label: tr-remove-favorite;
        add-print-label: tr-add-print-count;
        remove-print-label: tr-remove-print-count;
        copy-name-label: tr-copy-file-name;
        copy-path-label: tr-copy-file-path;
        action(action) => {
            shortcut-scope.focus();
            model-context-open = false;
            rename-editing = false;
            select-model(model-context-index);
            if action == "rename" {
                right-detail-open = true;
                rename-draft = detail-name;
                rename-editing = true;
            } else if action == "details" {
                right-detail-open = true;
            } else {
                model-context-action(action, model-context-index);
            }
        }
    }

    if left-sidebar-resizing || right-detail-resizing: TouchArea {
        z: 500;
        x: 0;
        y: Theme.titlebar-height;
        width: parent.width;
        height: parent.height - Theme.titlebar-height;
        mouse-cursor: ew-resize;

        pointer-event(event) => {
            if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                left-sidebar-resizing = false;
                right-detail-resizing = false;
            } else if (event.kind == PointerEventKind.cancel) {
                left-sidebar-resizing = false;
                right-detail-resizing = false;
            } else if (event.kind == PointerEventKind.move && left-sidebar-resizing) {
                left-sidebar-width = min(left-sidebar-max-width, max(left-sidebar-min-width, resize-start-width + (self.mouse-x - resize-origin-x)));
            } else if (event.kind == PointerEventKind.move && right-detail-resizing) {
                right-detail-width = min(right-detail-max-width, max(right-detail-min-width, resize-start-width - (self.mouse-x - resize-origin-x)));
            }
        }
    }

    // ─── Settings dialog ───
    if settings-open: Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        background: #00000073;

        TouchArea {
            clicked => { close-settings(); }
        }

        Rectangle {
            x: (parent.width - 760px) / 2;
            y: (parent.height - 540px) / 2;
            width: 760px;
            height: 540px;
            background: Theme.bg-1;
            border-color: Theme.line;
            border-width: 1px;
            border-radius: 12px;
            clip: true;

            TouchArea {}

            Rectangle {
                x: 0;
                y: 0;
                width: 200px;
                height: parent.height;
                background: Theme.bg-0;

                VerticalLayout {
                    padding-top: 14px;
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 1px;

                    Rectangle {
                        height: 64px;

                        Image {
                            x: 8px;
                            y: 4px;
                            width: 44px;
                            height: 44px;
                            source: @image-url("../assets/AppIcon.iconset/icon_128x128.png");
                            image-fit: contain;
                        }

                        Text {
                            x: 62px;
                            y: 13px;
                            text: "ModelRack";
                            color: Theme.fg-0;
                            font-size: Theme.font-title;
                            font-weight: 600;
                        }

                        Text {
                            x: 62px;
                            y: 32px;
                            text: app-version;
                            color: Theme.fg-2;
                            font-family: "JetBrains Mono";
                            font-size: 11px;
                        }

                        Rectangle {
                            x: 0;
                            y: parent.height - 1px;
                            width: parent.width;
                            height: 1px;
                            background: Theme.line;
                        }
                    }

                    Rectangle { height: 6px; }

                    SettingsTabButton { icon: @image-url("../assets/icons/sparkle.svg"); label: tr-settings-general; key: "general"; selected: settings-tab == "general"; activated(tab) => { choose-settings-tab(tab); } }
                    SettingsTabButton { icon: @image-url("../assets/icons/sun.svg"); label: tr-settings-appearance; key: "appearance"; selected: settings-tab == "appearance"; activated(tab) => { choose-settings-tab(tab); } }
                    SettingsTabButton { icon: @image-url("../assets/icons/folder.svg"); label: tr-settings-library; key: "library"; selected: settings-tab == "library"; activated(tab) => { choose-settings-tab(tab); } }
                    SettingsTabButton { icon: @image-url("../assets/icons/box.svg"); label: tr-settings-thumbnails; key: "thumbnails"; selected: settings-tab == "thumbnails"; activated(tab) => { choose-settings-tab(tab); } }
                    SettingsTabButton { icon: @image-url("../assets/icons/print.svg"); label: tr-settings-printers; key: "printers"; selected: settings-tab == "printers"; activated(tab) => { choose-settings-tab(tab); } }
                    SettingsTabButton { icon: @image-url("../assets/icons/slicer.svg"); label: tr-settings-slicer; key: "slicer"; selected: settings-tab == "slicer"; activated(tab) => { choose-settings-tab(tab); } }
                    SettingsTabButton { icon: @image-url("../assets/icons/cmd.svg"); label: tr-settings-hotkeys; key: "hotkeys"; selected: settings-tab == "hotkeys"; activated(tab) => { choose-settings-tab(tab); } }
                    SettingsTabButton { icon: @image-url("../assets/icons/sparkle.svg"); label: tr-settings-advanced; key: "advanced"; selected: settings-tab == "advanced"; activated(tab) => { choose-settings-tab(tab); } }
                    SettingsTabButton { icon: @image-url("../assets/icons/info.svg"); label: tr-settings-about; key: "about"; selected: settings-tab == "about"; activated(tab) => { choose-settings-tab(tab); } }
                }
            }

            Rectangle {
                x: 199px;
                y: 0;
                width: 1px;
                height: parent.height;
                background: Theme.line;
            }

            Rectangle {
                x: 200px;
                y: 0;
                width: parent.width - 200px;
                height: parent.height;
                background: Theme.bg-1;

                Rectangle {
                    x: 0;
                    y: 0;
                    width: parent.width;
                    height: 44px;

                    Text {
                        x: 18px;
                        y: (parent.height - self.height) / 2;
                        text: tr-settings-title;
                        color: Theme.fg-0;
                        font-size: Theme.font-heading;
                        font-weight: 600;
                    }

                    Rectangle {
                        x: parent.width - 42px;
                        y: 10px;
                        width: 24px;
                        height: 24px;
                        background: settings-close-touch.has-hover ? Theme.bg-3 : transparent;
                        border-radius: 5px;

                        SvgIcon {
                            x: 6px;
                            y: 6px;
                            width: 12px;
                            height: 12px;
                            icon: @image-url("../assets/icons/close.svg");
                            tint: settings-close-touch.has-hover ? Theme.fg-0 : Theme.fg-2;
                        }

                        settings-close-touch := TouchArea { clicked => { close-settings(); } }
                    }

                    Rectangle {
                        x: 0;
                        y: parent.height - 1px;
                        width: parent.width;
                        height: 1px;
                        background: Theme.line;
                    }
                }

                ScrollView {
                    x: 0;
                    y: 44px;
                    width: parent.width;
                    height: parent.height - 44px;

                    VerticalLayout {
                        padding-top: 18px;
                        padding-left: 22px;
                        padding-right: 22px;
                        padding-bottom: 18px;
                        spacing: 0px;

                        if settings-tab == "general": Rectangle {
                            height: 54px;
                            Rectangle { x: 0; y: parent.height - 1px; width: parent.width; height: 1px; background: Theme.line; }
                            Text { x: 0; y: 18px; width: 180px; text: tr-language; color: Theme.fg-1; font-size: Theme.font-body; }
                            SettingsSegment { x: 196px; y: 12px; button-width: 74px; a-label: tr-english; a-key: "en"; b-label: "한국어"; b-key: "ko"; c-label: "日本語"; c-key: "ja"; selected-key: settings-language-key; activated(key) => { choose-settings-language(key); } }
                        }
                        if settings-tab == "general": Rectangle {
                            height: 58px;
                            Rectangle { x: 0; y: parent.height - 1px; width: parent.width; height: 1px; background: Theme.line; }
                            Text { x: 0; y: 13px; width: 180px; text: tr-on-startup; color: Theme.fg-1; font-size: Theme.font-body; }
                            Text { x: 0; y: 31px; width: 180px; text: tr-startup-hint; color: Theme.fg-3; font-size: Theme.font-meta; overflow: elide; }
                            SettingsSegment { x: 196px; y: 14px; button-width: 104px; a-label: tr-last-library; a-key: "last"; b-label: tr-empty-state; b-key: "empty"; selected-key: "last"; activated(key) => { } }
                        }
                        if settings-tab == "general": Rectangle {
                            height: 54px;
                            Rectangle { x: 0; y: parent.height - 1px; width: parent.width; height: 1px; background: Theme.line; }
                            Text { x: 0; y: 18px; width: 180px; text: tr-default-view; color: Theme.fg-1; font-size: Theme.font-body; }
                            SettingsSegment { x: 196px; y: 12px; button-width: 78px; a-label: tr-grid; a-key: "grid"; b-label: tr-masonry; b-key: "masonry"; c-label: tr-list; c-key: "list"; selected-key: view-mode-label == "Grid" ? "grid" : view-mode-label == "Masonry" ? "masonry" : "list"; activated(key) => { choose-view-mode(key); } }
                        }
                        if settings-tab == "general": Rectangle {
                            height: 54px;
                            Rectangle { x: 0; y: parent.height - 1px; width: parent.width; height: 1px; background: Theme.line; }
                            Text { x: 0; y: 18px; width: 180px; text: tr-default-sort; color: Theme.fg-1; font-size: Theme.font-body; }
                            SettingsSegment { x: 196px; y: 12px; button-width: 88px; a-label: tr-name; a-key: "name"; b-label: tr-sort-modified; b-key: "modified"; c-label: tr-sort-added; c-key: "added"; d-label: tr-triangles; d-key: "triangles"; selected-key: settings-sort-key; activated(key) => { choose-settings-sort(key); } }
                        }
                        if settings-tab == "general": Rectangle {
                            height: 54px;
                            Rectangle { x: 0; y: parent.height - 1px; width: parent.width; height: 1px; background: Theme.line; }
                            Text { x: 0; y: 18px; width: 180px; text: tr-date-format; color: Theme.fg-1; font-size: Theme.font-body; }
                            SettingsSegment { x: 196px; y: 12px; button-width: 92px; a-label: tr-auto; a-key: "auto"; b-label: "2026-05-08"; b-key: "iso"; c-label: tr-us-date-example; c-key: "us"; selected-key: "auto"; activated(key) => { } }
                        }
                        if settings-tab == "general": Rectangle {
                            height: 54px;
                            Rectangle { x: 0; y: parent.height - 1px; width: parent.width; height: 1px; background: Theme.line; }
                            Text { x: 0; y: 18px; width: 180px; text: tr-show-file-extensions; color: Theme.fg-1; font-size: Theme.font-body; }
                            SettingsToggle { x: 196px; y: 17px; on: true; interactive: false; }
                        }

