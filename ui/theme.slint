// ModelRack design tokens — dark theme (from Claude Design mockup)

export global Theme {
    // Background elevation steps
    in-out property <color> bg-0: #15171b;
    in-out property <color> bg-1: #1b1e23;
    in-out property <color> bg-2: #202329;
    in-out property <color> bg-3: #292d34;
    in-out property <color> bg-4: #343943;
    in-out property <color> bg-5: #46505c;

    // Foreground text levels
    in-out property <color> fg-0: #f0f2f5;
    in-out property <color> fg-1: #c0c5cc;
    in-out property <color> fg-2: #8c929b;
    in-out property <color> fg-3: #606771;

    // Accent (teal default)
    in-out property <color> accent: #5fb8d4;
    in-out property <color> accent-dim: #5fb8d42e;
    in-out property <color> accent-line: #5fb8d459;
    in-out property <color> accent-dark: #1a3a44;

    // Semantic
    in-out property <color> warn: #d4a84f;
    in-out property <color> error: #c95040;
    in-out property <color> success: #5fb87a;

    // Lines / borders
    in-out property <color> line: #ffffff0f;
    in-out property <color> line-2: #ffffff1a;
    in-out property <color> line-3: #ffffff29;

    // Typography sizes
    out property <length> font-overline: 10.5px;
    out property <length> font-meta: 11.5px;
    out property <length> font-body: 12.5px;
    out property <length> font-title: 13px;
    out property <length> font-heading: 14px;
    out property <length> font-large: 20px;

    // Spacing / radius
    out property <length> radius-card: 6px;
    out property <length> radius-btn: 5px;
    out property <length> radius-pill: 20px;

    // Layout sizes
    out property <length> sidebar-width: 220px;
    out property <length> detail-width: 320px;
    out property <length> titlebar-height: 36px;
    out property <length> toolbar-height: 44px;
    out property <length> filterbar-height: 36px;
    out property <length> statusbar-height: 26px;
}
